---
import "../styles/yumiki.css";
import { nav, sns, img } from "../data/yumiki.ts";

interface Props { title?: string; description?: string; }
const {
  title = "YUMIKI WORLD — 弓木奈於 非公式ファンサイト",
  description = "乃木坂46・弓木奈於さんの魅力をまとめた非公式ファンサイト『YUMIKI WORLD』。",
} = Astro.props;
const { pathname } = Astro.url;
const isActive = (href: string) => href === "/yumiki/" ? pathname === "/yumiki/" || pathname === "/yumiki" : pathname.startsWith(href);
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <!-- 非公式ファンサイトのため検索エンジンには載せない -->
    <meta name="robots" content="noindex, nofollow" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@500;600;700&family=Yomogi&family=Zen+Maru+Gothic:wght@400;500;700;900&display=swap" rel="stylesheet" />
    <!-- JS有効時のみリビールを隠す＝JS無効/失敗でも本文が必ず見える（空白防止） -->
    <script is:inline>document.documentElement.classList.add("js")</script>
  </head>
  <body class="yumiki">
    <div class="yumiki-bg" aria-hidden="true"></div>
    <div class="y-grain" aria-hidden="true"></div>

    <header class="y-header">
      <div class="y-container y-header-inner">
        <a href="/yumiki/" class="y-logo">YUMIKI<span class="heart">♡</span>WORLD</a>
        <nav class="y-nav" id="yNav" aria-label="弓木サイト ナビ">
          {nav.map((n) => (
            <a href={n.href} class:list={[{ active: isActive(n.href) }]}>{n.emoji} {n.label}</a>
          ))}
          <a href="/works" class="y-back">← ポートフォリオへ</a>
        </nav>
        <button class="y-burger" id="yBurger" aria-label="メニュー" aria-controls="yNav" aria-expanded="false"><span></span><span></span><span></span></button>
      </div>
    </header>

    <main><slot /></main>

    <footer class="y-footer">
      <div class="y-container">
        <a href="/yumiki/" class="y-logo">YUMIKI<span class="heart">♡</span>WORLD</a>
        <div class="y-sns">
          {sns.map((s) => (
            <a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.label}><img src={img(s.icon)} alt={s.label} /></a>
          ))}
        </div>
        <p class="y-disclaimer">
          © 2026 YUMIKI WORLD ／ 本ページは弓木奈於さんを応援する非公式ファン制作サイトです。<br />
          掲載している画像・情報の著作権は各権利者に帰属します。問題がある場合は速やかに対応します。
        </p>
        <p style="margin-top:1rem"><a href="/works" class="y-btn y-btn--soft">← 制作者のポートフォリオに戻る</a></p>
      </div>
    </footer>

    <script>
      const nav = document.getElementById("yNav");
      const burger = document.getElementById("yBurger");
      const setMenu = (open: boolean) => {
        nav?.classList.toggle("open", open);
        burger?.setAttribute("aria-expanded", String(open));
        // メニュー展開中は背景(body)のスクロールを固定して操作の競合を防ぐ
        document.body.style.overflow = open ? "hidden" : "";
      };
      burger?.addEventListener("click", () => setMenu(!nav?.classList.contains("open")));
      nav?.querySelectorAll("a").forEach((a) => a.addEventListener("click", () => setMenu(false)));

      const els = document.querySelectorAll(".y-reveal");
      if ("IntersectionObserver" in window && els.length) {
        const io = new IntersectionObserver((es) => es.forEach((e) => { if (e.isIntersecting) { e.target.classList.add("is-visible"); io.unobserve(e.target); } }), { threshold: 0.12 });
        els.forEach((el) => io.observe(el));
      } else { els.forEach((el) => el.classList.add("is-visible")); }

      // カーソル追従キラキラ（遊び心）。fine pointer かつ motion 許可時のみ・間引き＆自動破棄で軽量。
      const fine = window.matchMedia("(pointer: fine)").matches;
      const okMotion = !window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (fine && okMotion) {
        const glyphs = ["✦", "♡", "✿", "⭐️", "♪"];
        const colors = ["#ff9fb2", "#ffc2d1", "#ffd98a", "#9fe3c5", "#cdbcff", "#a9d8ff"];
        let i = 0, last = 0;
        window.addEventListener("pointermove", (e) => {
          const now = e.timeStamp;
          if (now - last < 70) return;            // 時間間引き（DOM肥大防止）
          last = now;
          const s = document.createElement("span");
          s.className = "y-trail";
          s.textContent = glyphs[i % glyphs.length];
          s.style.left = e.clientX + "px";
          s.style.top = e.clientY + "px";
          s.style.color = colors[i % colors.length];
          i++;
          document.body.appendChild(s);
          window.setTimeout(() => s.remove(), 700);
        }, { passive: true });
      }
    </script>
  </body>
</html>
