---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Cursor from "../components/Cursor.astro";

interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Osaki Ryoma — Portfolio",
  description = "愛知工業大学 情報科学部 メディア情報専攻・水野慎士研究室。CG・映像・グラフィック・画像処理・Web を横断する大崎稜馬のポートフォリオ。",
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/og.png" />
    <meta property="og:url" content={Astro.url.href} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="/og.png" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Zen+Kaku+Gothic+New:wght@400;500;700;900&display=swap"
      rel="stylesheet"
    />

    <!-- ダーク既定。light保存時のみ切替（チラつき防止で先行適用） -->
    <script is:inline>
      (() => {
        const s = localStorage.getItem("theme");
        if (s === "light") document.documentElement.setAttribute("data-theme", "light");
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="sr-only">本文へスキップ</a>
    <Cursor />
    <Header />
    <main id="main"><slot /></main>
    <Footer />

    <script>
      // スクロールで要素を立ち上げ
      const els = document.querySelectorAll(".reveal");
      if ("IntersectionObserver" in window && els.length) {
        const io = new IntersectionObserver(
          (entries) => entries.forEach((e) => {
            if (e.isIntersecting) { e.target.classList.add("is-visible"); io.unobserve(e.target); }
          }),
          { threshold: 0.12 }
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add("is-visible"));
      }
    </script>
  </body>
</html>

<style>
  main { padding-top: 0; }
</style>
