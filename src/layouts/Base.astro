---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Cursor from "../components/Cursor.astro";

interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Osaki Ryoma — Portfolio",
  description = "愛知工業大学 情報科学部 メディア情報専攻・水野慎士研究室。CG・映像・グラフィック・画像処理・Web を横断する大崎稜馬のポートフォリオ。",
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/og.png" />
    <meta property="og:url" content={Astro.url.href} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="/og.png" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Zen+Kaku+Gothic+New:wght@400;700;900&display=swap"
      rel="stylesheet"
    />

    <!-- ダーク既定。light保存時のみ切替（チラつき防止で先行適用）＋初回イントロ判定 -->
    <script is:inline>
      (() => {
        const s = localStorage.getItem("theme");
        if (s === "light") document.documentElement.setAttribute("data-theme", "light");
        try {
          const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
          if (!reduce && !sessionStorage.getItem("introSeen")) {
            document.documentElement.classList.add("intro");
            sessionStorage.setItem("introSeen", "1");
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <span class="scroll-progress" id="scrollProgress" aria-hidden="true"></span>
    <div class="site-intro" aria-hidden="true">
      <div class="intro-glow" aria-hidden="true"></div>
      <div class="intro-mark">
        <span class="intro-bar"></span>
        <span class="intro-name"><span class="spectrum-text">OSAKI</span></span>
        <span class="intro-tag">Creative Portfolio</span>
      </div>
    </div>
    <a href="#main" class="sr-only">本文へスキップ</a>
    <Cursor />
    <Header />
    <main id="main"><slot /></main>
    <Footer />

    <script>
      // スクロールで要素を立ち上げ
      const els = document.querySelectorAll(".reveal");
      if ("IntersectionObserver" in window && els.length) {
        const io = new IntersectionObserver(
          (entries) => entries.forEach((e) => {
            if (e.isIntersecting) { e.target.classList.add("is-visible"); io.unobserve(e.target); }
          }),
          { threshold: 0.12 }
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add("is-visible"));
      }

      // スクロール進捗バー
      const bar = document.getElementById("scrollProgress");
      if (bar) {
        const onScrollBar = () => {
          const h = document.documentElement;
          const max = h.scrollHeight - h.clientHeight;
          bar.style.transform = `scaleX(${max > 0 ? Math.min(1, h.scrollTop / max) : 0})`;
        };
        onScrollBar();
        addEventListener("scroll", onScrollBar, { passive: true });
        addEventListener("resize", onScrollBar);
      }

      // スクロールで移ろうアクセント色：data-accent を持つ区画が画面中央の帯に入ると --page-accent を切替
      // → 進捗バー・カーソルグローがその色を帯び、分野（＝色）の間を旅するように移ろう
      const accentEls = document.querySelectorAll<HTMLElement>("[data-accent]");
      if ("IntersectionObserver" in window && accentEls.length) {
        const rootEl = document.documentElement;
        const ao = new IntersectionObserver(
          (entries) => entries.forEach((e) => {
            const t = e.target as HTMLElement;
            if (e.isIntersecting && t.dataset.accent) rootEl.style.setProperty("--page-accent", t.dataset.accent);
          }),
          { rootMargin: "-45% 0px -45% 0px", threshold: 0 }
        );
        accentEls.forEach((el) => ao.observe(el));
      }

      // イントロ：アニメ後にクラス除去（body の overflow を戻す）／早期スキップ
      if (document.documentElement.classList.contains("intro")) {
        const clearIntro = () => document.documentElement.classList.remove("intro");
        setTimeout(clearIntro, 2200);
        addEventListener("pointerdown", clearIntro, { once: true });
        addEventListener("keydown", clearIntro, { once: true });
      }

      // 作品動画は preload="none"。画面に入る直前にだけ読み込み→再生する。
      // → 画面外の動画は1バイトもDLしないので、worksページが激軽になる（省電力・省データ）
      const vids = document.querySelectorAll<HTMLVideoElement>("video[loop]");
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (!reduce && "IntersectionObserver" in window && vids.length) {
        const vio = new IntersectionObserver(
          (entries) => entries.forEach((e) => {
            const v = e.target as HTMLVideoElement;
            if (e.isIntersecting) { v.preload = "auto"; v.play().catch(() => {}); }
            else { v.pause(); }
          }),
          { threshold: 0.1, rootMargin: "250px 0px" }
        );
        vids.forEach((v) => vio.observe(v));
      }
      // reduce-motion時は観測しない＝ポスター静止のまま（DLなし）
    </script>
  </body>
</html>

<style>
  main { padding-top: 0; }
</style>
