---
import { works } from "../data/works.ts";
const year = new Date().getFullYear();
// 既定: 本垢Instagram / GitHub / Email。裏垢は非掲載。
const socials = [
  { label: "Instagram", href: "https://www.instagram.com/ryoma_v_dome" },
  { label: "GitHub", href: "https://github.com/ryoo-ma638" },
  { label: "Email", href: "mailto:ryoma630@gmail.com" },
];
// Let's Create 背景：作品サムネを斜め2行・逆方向に流すショーケース
const showcase = works.filter((w) => w.thumb);
const rowA = showcase.filter((_, i) => i % 2 === 0);
const rowB = showcase.filter((_, i) => i % 2 === 1);
---
<footer class="site-footer">
  <div class="footer-glow" aria-hidden="true"></div>
  <span class="footer-mark display" aria-hidden="true">OSAKI</span>

  <div class="footer-showcase" aria-hidden="true">
    <div class="fs-row fs-row--a">
      {[...rowA, ...rowA].map((w) => (<span class="fs-card"><img src={w.thumb} alt="" loading="lazy" decoding="async" /></span>))}
    </div>
    <div class="fs-row fs-row--b">
      {[...rowB, ...rowB].map((w) => (<span class="fs-card"><img src={w.thumb} alt="" loading="lazy" decoding="async" /></span>))}
    </div>
  </div>

  <div class="container">
    <span class="spectrum-bar reveal"></span>

    <div class="cta reveal">
      <p class="eyebrow">Get in touch</p>
      <a href="/contact" class="cta-big display">
        LET’S<br /><span class="spectrum-text">CREATE.</span>
      </a>
      <p class="cta-sub">何かをつくりたい、その入口になれたら。</p>
    </div>

    <div class="footer-grid">
      <div class="reveal">
        <a href="/" class="logo display">OSAKI<span class="logo-dot"></span></a>
        <p class="tagline">CG・映像・グラフィック・画像処理・Web を横断するものづくり。</p>
      </div>
      <nav class="footer-nav reveal" aria-label="フッターナビ">
        <span class="col-label">Menu</span>
        <a href="/works">Works</a>
        <a href="/about">About</a>
        <a href="/ceed">CEED</a>
        <a href="/contact">Contact</a>
      </nav>
      <ul class="footer-social reveal">
        <span class="col-label">Social</span>
        {socials.map((s) => (
          <li><a href={s.href} target={s.href.startsWith("http") ? "_blank" : null} rel="noopener noreferrer">{s.label} <span aria-hidden="true">↗</span></a></li>
        ))}
      </ul>
    </div>

    <div class="footer-bottom">
      <p>© {year} Osaki Ryoma</p>
      <p class="muted">Built with Astro</p>
    </div>
  </div>
</footer>

<style>
  .site-footer { position: relative; padding-block: var(--space-5) var(--space-3); margin-top: var(--space-6); border-top: 1px solid var(--line); background: var(--bg-2); overflow: hidden; }
  .footer-glow { position: absolute; inset: 0; z-index: 0; pointer-events: none;
    background: radial-gradient(60% 70% at 15% 120%, color-mix(in srgb, var(--c-violet) 22%, transparent), transparent 60%),
      radial-gradient(50% 60% at 95% 0%, color-mix(in srgb, var(--c-cyan) 16%, transparent), transparent 60%);
    filter: blur(20px); }
  .footer-mark { position: absolute; left: 50%; bottom: -0.18em; transform: translateX(-50%); z-index: 0; pointer-events: none;
    font-size: clamp(5rem, 26vw, 22rem); font-weight: 700; line-height: 1; letter-spacing: -0.04em; white-space: nowrap;
    color: transparent; -webkit-text-stroke: 1px color-mix(in srgb, var(--fg) 8%, transparent); opacity: 0.6; }
  .site-footer .container { position: relative; z-index: 1; }

  /* Let's Create：作品サムネを斜め2行・逆方向に流すショーケース */
  .footer-showcase { position: relative; z-index: 1; display: flex; flex-direction: column;
    gap: clamp(0.55rem, 1.4vw, 0.9rem); margin-bottom: var(--space-5); padding-block: clamp(0.4rem, 2vw, 1.1rem);
    transform: rotate(-3.5deg) scale(1.08); transform-origin: center;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 9%, #000 91%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 9%, #000 91%, transparent); }
  .fs-row { display: flex; gap: clamp(0.55rem, 1.4vw, 0.9rem); width: max-content; will-change: transform; }
  .fs-row--a { animation: fs-left 55s linear infinite; }
  .fs-row--b { animation: fs-right 70s linear infinite; }
  .fs-card { flex: 0 0 auto; width: clamp(116px, 15vw, 178px); aspect-ratio: 16 / 10;
    border-radius: 12px; overflow: hidden; border: 1px solid var(--line); background: var(--bg-3); box-shadow: 0 8px 24px rgba(0,0,0,0.28); }
  .fs-card img { width: 100%; height: 100%; object-fit: cover; display: block; opacity: 0.82; transition: opacity 0.3s var(--ease); }
  .footer-showcase:hover .fs-card img { opacity: 0.96; }
  @keyframes fs-left { from { transform: translateX(0); } to { transform: translateX(-50%); } }
  @keyframes fs-right { from { transform: translateX(-50%); } to { transform: translateX(0); } }
  @media (prefers-reduced-motion: reduce) { .fs-row--a, .fs-row--b { animation: none; } }

  .spectrum-bar { margin-bottom: var(--space-5); }
  .cta { margin-bottom: var(--space-5); }
  .cta-big { display: inline-block; font-size: var(--fs-mega); font-weight: 700; line-height: 0.92; letter-spacing: -0.03em; margin-top: 0.6rem; transition: transform 0.4s var(--ease); }
  .cta-big:hover { transform: translateX(0.6rem); }
  .cta-sub { margin-top: 1.2rem; color: var(--fg-soft); font-size: var(--fs-small); }

  .footer-grid { display: grid; gap: var(--space-4); grid-template-columns: 1fr; padding-block: var(--space-4); border-top: 1px solid var(--line); }
  @media (min-width: 760px) { .footer-grid { grid-template-columns: 1.6fr 1fr 1fr; } }
  .logo { font-size: 1.5rem; display: inline-flex; align-items: center; }
  .logo-dot { width: 9px; height: 9px; border-radius: 50%; background: var(--spectrum); margin-left: 3px; margin-top: 8px; }
  .tagline { color: var(--muted); margin-top: 0.7rem; max-width: 34ch; font-size: var(--fs-small); }

  .col-label { display: block; font-family: var(--font-display); font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted); margin-bottom: 1rem; }
  .footer-nav, .footer-social { display: flex; flex-direction: column; gap: 0.7rem; }
  .footer-nav a, .footer-social a { color: var(--fg-soft); font-size: 1.05rem; width: fit-content; transition: color 0.25s var(--ease); }
  .footer-nav a:hover, .footer-social a:hover { color: var(--fg); }

  .footer-bottom { display: flex; justify-content: space-between; gap: 1rem; flex-wrap: wrap; padding-top: var(--space-3); border-top: 1px solid var(--line); font-size: 0.8rem; color: var(--muted); }
</style>
