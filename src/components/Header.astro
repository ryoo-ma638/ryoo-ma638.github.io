---
const { pathname } = Astro.url;
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
const links = [
  { href: "/", label: "Home", num: "01" },
  { href: "/works", label: "Works", num: "02" },
  { href: "/about", label: "About", num: "03" },
  { href: "/ceed", label: "CEED", num: "04" },
  { href: "/contact", label: "Contact", num: "05" },
];
---
<header class="site-header" id="siteHeader">
  <div class="container header-inner">
    <a href="/" class="logo display" aria-label="ホームへ">
      <span class="logo-horse" aria-hidden="true"></span><span class="logo-word">OSAKI</span><span class="logo-dot"></span>
    </a>

    <nav class="nav" id="nav" aria-label="メインナビゲーション">
      {links.map((l) => (
        <a href={l.href} class:list={["nav-link", "display", { active: isActive(l.href) }]}>
          <span class="nav-num">{l.num}</span>{l.label}
        </a>
      ))}
    </nav>

    <div class="header-actions">
      <button id="themeToggle" class="icon-btn" aria-label="テーマ切り替え" title="ライト/ダーク切り替え">
        <svg class="sun" width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
        <svg class="moon" width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
      <button id="navToggle" class="nav-toggle" aria-label="メニュー" aria-expanded="false"><span></span><span></span></button>
    </div>
  </div>
  <span class="header-line"></span>
</header>

<style>
  .site-header { position: fixed; inset: 0 0 auto 0; z-index: 100; }
  /* フロスト背景は擬似要素に分離する。ヘッダー自身に backdrop-filter を付けると、子孫の
     position:fixed なモバイルメニュー(.nav)の“含有ブロック”になり、スクロール後にメニューを開くと
     ヘッダーの箱に閉じ込められて崩れる（iOS Safari では backdrop-filter:none に戻しても含有ブロックが
     再計算されず効かない）。擬似要素は .nav の祖先ではないので含有ブロックを作らず、確実に防げる。 */
  .site-header::before {
    content: ""; position: absolute; inset: 0; z-index: -1; pointer-events: none;
    background: color-mix(in srgb, var(--bg) 72%, transparent);
    backdrop-filter: saturate(160%) blur(14px); -webkit-backdrop-filter: saturate(160%) blur(14px);
    opacity: 0; transition: opacity 0.4s var(--ease);
  }
  .site-header.scrolled::before { opacity: 1; }
  .header-inner { display: flex; align-items: center; justify-content: space-between; height: clamp(58px, 15vw, 78px); }
  .header-line { position: absolute; left: 0; bottom: 0; height: 1px; width: 100%; background: var(--line); opacity: 0; transition: opacity 0.4s var(--ease); }
  .site-header.scrolled .header-line { opacity: 1; }

  .logo { font-size: 1.4rem; font-weight: 700; letter-spacing: 0.04em; display: inline-flex; align-items: center; position: relative; }
  .logo-word, .logo-dot { position: relative; z-index: 1; }
  /* 名刺の馬ワイヤーフレームを背面に敷き、その上に OSAKI を重ねる。サイト共通の --spectrum で
     虹色に発光させてブランド（つくって、光を放つ）に統一。mask の形＝馬、色＝スペクトラム。 */
  .logo-horse { position: absolute; left: 43%; top: 50%; transform: translate(-50%, -50%); z-index: 0; pointer-events: none;
    width: 3.6em; height: 1.9em; opacity: 0.62;
    background: var(--spectrum); background-size: 200% auto; animation: hue 8s linear infinite;
    -webkit-mask: url(/assets/horse-wire.png) center / contain no-repeat; mask: url(/assets/horse-wire.png) center / contain no-repeat; }
  @media (prefers-reduced-motion: reduce) { .logo-horse { animation: none; } }
  /* スマホはヘッダーが狭いのでロゴ全体を縮小（馬が主張しすぎないように） */
  @media (max-width: 600px) {
    .logo { font-size: 1.16rem; }
    .logo-horse { width: 3.25em; height: 1.68em; opacity: 0.55; }
  }
  /* PCはロゴを少し右へ寄せ、左上の装飾フレームから離して余白を持たせる */
  @media (min-width: 821px) { .logo { margin-left: clamp(1rem, 3vw, 2.6rem); } }
  .logo-dot { width: 9px; height: 9px; border-radius: 50%; background: var(--spectrum); margin-left: 3px; margin-top: 8px; background-size: 200% auto; animation: hue 8s linear infinite; }

  .nav { display: flex; gap: 2rem; }
  .nav-link { font-size: 0.95rem; font-weight: 500; color: var(--fg-soft); position: relative; padding: 0.3rem 0; display: inline-flex; align-items: baseline; gap: 0.35rem; transition: color 0.3s var(--ease); }
  .nav-num { font-size: 0.65rem; color: var(--muted); }
  .nav-link::after { content: ""; position: absolute; left: 0; bottom: -2px; height: 2px; width: 100%; background: var(--spectrum); transform: scaleX(0); transform-origin: left; transition: transform 0.35s var(--ease); }
  .nav-link:hover, .nav-link.active { color: var(--fg); }
  .nav-link:hover::after, .nav-link.active::after { transform: scaleX(1); }

  .header-actions { display: flex; align-items: center; gap: 0.6rem; }
  .icon-btn { display: grid; place-items: center; width: 42px; height: 42px; border-radius: 50%; color: var(--fg); transition: background 0.25s var(--ease); }
  .icon-btn:hover { background: var(--bg-3); }
  .icon-btn .moon { display: none; }
  :global(:root:not([data-theme="light"])) .icon-btn .sun { display: none; }
  :global(:root:not([data-theme="light"])) .icon-btn .moon { display: block; }

  .nav-toggle { display: none; flex-direction: column; gap: 6px; width: 42px; height: 42px; align-items: center; justify-content: center; }
  .nav-toggle span { width: 24px; height: 2px; background: var(--fg); border-radius: 2px; transition: transform 0.35s var(--ease), opacity 0.35s var(--ease); }
  .nav-toggle[aria-expanded="true"] span:nth-child(1) { transform: translateY(4px) rotate(45deg); }
  .nav-toggle[aria-expanded="true"] span:nth-child(2) { transform: translateY(-4px) rotate(-45deg); }

  @media (max-width: 820px) {
    .nav {
      position: fixed; inset: 0; z-index: 100; flex-direction: column; justify-content: center; align-items: flex-start; gap: 0.2rem;
      background:
        radial-gradient(80% 50% at 100% 0%, color-mix(in srgb, var(--c-violet) 14%, transparent), transparent 60%),
        radial-gradient(70% 50% at 0% 100%, color-mix(in srgb, var(--c-cyan) 12%, transparent), transparent 60%),
        var(--bg);
      padding: 6rem 2rem 2.5rem;
      clip-path: circle(0% at calc(100% - 42px) 36px); transition: clip-path 0.6s var(--ease);
    }
    .nav.open { clip-path: circle(150% at calc(100% - 42px) 36px); }
    .nav-link { font-size: clamp(2rem, 11vw, 3rem); font-weight: 700; color: var(--fg); padding: 0.55rem 0; gap: 0.7rem; }
    .nav-num { font-size: 0.85rem; align-self: flex-start; margin-top: 0.6rem; }
    .nav-link::after { bottom: 0.35rem; height: 3px; }
    .nav-toggle { display: flex; z-index: 101; }
  }
</style>

<script>
  const header = document.getElementById("siteHeader");
  const onScroll = () => header?.classList.toggle("scrolled", scrollY > 8);
  onScroll(); addEventListener("scroll", onScroll, { passive: true });

  const root = document.documentElement;
  document.getElementById("themeToggle")?.addEventListener("click", () => {
    const isLight = root.getAttribute("data-theme") === "light";
    if (isLight) { root.removeAttribute("data-theme"); localStorage.setItem("theme", "dark"); }
    else { root.setAttribute("data-theme", "light"); localStorage.setItem("theme", "light"); }
  });

  const nav = document.getElementById("nav");
  const toggle = document.getElementById("navToggle");
  toggle?.addEventListener("click", () => {
    const open = nav?.classList.toggle("open");
    toggle.setAttribute("aria-expanded", String(!!open));
    document.body.style.overflow = open ? "hidden" : "";
  });
  nav?.querySelectorAll("a").forEach((a) => a.addEventListener("click", () => {
    nav.classList.remove("open"); toggle?.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  }));
</script>
