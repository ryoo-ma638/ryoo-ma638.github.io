---
// 動く背景：スペクトラムの「光の粒子」がゆっくり漂う canvas フィールド（控えめ）。
// ・省電力：DPR上限2／粒子数は画面サイズで自動／タブ非表示で停止／固定全面
// ・可読性優先：加算合成＋低alphaの淡い光。本文の後ろ（z-index:-1）。
// ・reduced-motion：アニメせず静止描画。
---

<canvas class="bg-field" id="bgField" aria-hidden="true"></canvas>

<style>
  .bg-field { position: fixed; inset: 0; z-index: -1; pointer-events: none; opacity: 0.62; }
  :root[data-theme="light"] .bg-field { opacity: 0.26; }
</style>

<script>
  (() => {
    const canvas = document.getElementById("bgField") as HTMLCanvasElement | null;
    if (!canvas) return;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;
    const mq = matchMedia("(prefers-reduced-motion: reduce)");

    const SPECTRUM = ["#7b5cff", "#2a9dff", "#19d3c5", "#4ade80", "#ffd23f", "#ff8a3d", "#ff3b6b"];
    const hexRgb = (h: string) => ({ r: parseInt(h.slice(1, 3), 16), g: parseInt(h.slice(3, 5), 16), b: parseInt(h.slice(5, 7), 16) });

    let W = 0, H = 0, dpr = 1, raf = 0, running = false;
    let particles: any[] = [];
    let sprites: HTMLCanvasElement[] = [];

    function makeSprite(hex: string) {
      const { r, g, b } = hexRgb(hex);
      const R = 64;
      const s = document.createElement("canvas");
      s.width = s.height = R * 2;
      const c = s.getContext("2d")!;
      const grd = c.createRadialGradient(R, R, 0, R, R, R);
      grd.addColorStop(0, `rgba(${r},${g},${b},0.9)`);
      grd.addColorStop(0.35, `rgba(${r},${g},${b},0.32)`);
      grd.addColorStop(1, `rgba(${r},${g},${b},0)`);
      c.fillStyle = grd;
      c.fillRect(0, 0, R * 2, R * 2);
      return s;
    }

    function resize() {
      dpr = Math.min(devicePixelRatio || 1, 1.5);
      W = innerWidth; H = innerHeight;
      canvas.width = Math.floor(W * dpr);
      canvas.height = Math.floor(H * dpr);
      canvas.style.width = W + "px";
      canvas.style.height = H + "px";
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    function init() {
      const count = Math.max(6, Math.min(22, Math.round((W * H) / 64000)));
      particles = [];
      for (let i = 0; i < count; i++) {
        particles.push({
          x: Math.random() * W,
          y: Math.random() * H,
          r: 1.2 + Math.random() * 3.0,
          vy: -0.04 - Math.random() * 0.13,
          sway: 0.2 + Math.random() * 0.5,
          swaySpeed: 0.004 + Math.random() * 0.009,
          a: 0.07 + Math.random() * 0.2,
          tw: Math.random() * Math.PI * 2,
          tws: 0.004 + Math.random() * 0.01,
          ci: i % SPECTRUM.length,
        });
      }
    }

    function draw() {
      ctx.clearRect(0, 0, W, H);
      ctx.globalCompositeOperation = "lighter";
      for (const p of particles) {
        p.tw += p.tws;
        p.y += p.vy;
        p.x += Math.sin(p.tw) * p.sway * 0.35;
        if (p.y < -30) { p.y = H + 30; p.x = Math.random() * W; }
        if (p.x < -30) p.x = W + 30; else if (p.x > W + 30) p.x = -30;
        const alpha = p.a * (0.45 + 0.55 * Math.sin(p.tw));
        if (alpha <= 0) continue;
        const size = p.r * 17;
        ctx.globalAlpha = alpha;
        ctx.drawImage(sprites[p.ci], p.x - size / 2, p.y - size / 2, size, size);
      }
      ctx.globalAlpha = 1;
      ctx.globalCompositeOperation = "source-over";
    }

    function loop() { draw(); raf = requestAnimationFrame(loop); }
    function start() { if (running) return; running = true; raf = requestAnimationFrame(loop); }
    function stop() { running = false; cancelAnimationFrame(raf); }

    function boot() {
      resize();
      sprites = SPECTRUM.map(makeSprite);
      init();
      if (mq.matches) draw(); else start();
    }

    let rt: number;
    addEventListener("resize", () => { clearTimeout(rt); rt = window.setTimeout(() => { resize(); init(); if (mq.matches) draw(); }, 200); }, { passive: true });
    document.addEventListener("visibilitychange", () => { if (document.hidden) stop(); else if (!mq.matches) start(); });
    mq.addEventListener?.("change", () => { stop(); if (mq.matches) draw(); else start(); });

    boot();
  })();
</script>
