---
// 共通ライトボックス。任意の要素に data-gallery='["/a.jpg","/b.jpg"]' を付けるとクリックで拡大表示。
// data-index で初期表示、data-caption でキャプション（任意）。
---
<div id="lightbox" class="lb" aria-hidden="true" role="dialog" aria-modal="true" aria-label="画像ビューア">
  <button class="lb-btn lb-close" aria-label="閉じる">✕</button>
  <button class="lb-btn lb-prev" aria-label="前の画像">‹</button>
  <figure class="lb-figure">
    <img id="lb-img" src="" alt="" />
    <figcaption id="lb-cap" class="lb-cap"></figcaption>
  </figure>
  <button class="lb-btn lb-next" aria-label="次の画像">›</button>
  <div class="lb-counter"><span id="lb-cur">1</span> / <span id="lb-total">1</span></div>
</div>

<style>
  .lb {
    position: fixed; inset: 0; z-index: 1000; display: none;
    place-items: center; padding: clamp(1rem, 4vw, 3rem);
    background: color-mix(in srgb, #05050a 88%, transparent);
    backdrop-filter: blur(14px) saturate(120%);
    opacity: 0; transition: opacity 0.35s var(--ease, cubic-bezier(0.16, 1, 0.3, 1));
  }
  .lb.open { display: grid; opacity: 1; }
  .lb-figure { margin: 0; max-width: min(1100px, 92vw); max-height: 88vh; display: grid; gap: 0.8rem; justify-items: center; }
  .lb-figure img {
    max-width: 100%; max-height: 82vh; width: auto; height: auto;
    object-fit: contain; border-radius: var(--radius-sm, 12px);
    border: 1px solid var(--line, rgba(255,255,255,0.14)); box-shadow: 0 30px 80px rgba(0,0,0,0.6);
    background: var(--bg-2, #14121a);
    transform: scale(0.96); opacity: 0; transition: transform 0.4s var(--ease, cubic-bezier(0.16, 1, 0.3, 1)), opacity 0.4s var(--ease, cubic-bezier(0.16, 1, 0.3, 1));
  }
  .lb.show-img img { transform: none; opacity: 1; }
  .lb-cap { color: var(--fg-soft, #cfc9d6); font-size: var(--fs-small, 0.85rem); text-align: center; max-width: 60ch; }

  .lb-btn {
    position: fixed; z-index: 1001; display: grid; place-items: center;
    width: 52px; height: 52px; border-radius: 50%; color: #fff;
    background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.18);
    font-size: 1.6rem; line-height: 1; backdrop-filter: blur(6px);
    transition: background 0.25s var(--ease, cubic-bezier(0.16, 1, 0.3, 1)), transform 0.25s var(--ease, cubic-bezier(0.16, 1, 0.3, 1));
  }
  .lb-btn:hover { background: rgba(255,255,255,0.2); transform: scale(1.08); }
  .lb-close { top: clamp(1rem, 3vw, 2rem); right: clamp(1rem, 3vw, 2rem); color: #0b0a12; background: #fff; border: none; box-shadow: 0 8px 24px rgba(0,0,0,0.45); }
  .lb-close:hover { background: var(--accent-ink, var(--y-peach, #5a3df0)); color: #fff; transform: scale(1.1) rotate(90deg); }
  .lb-prev { left: clamp(0.5rem, 3vw, 2rem); top: 50%; transform: translateY(-50%); }
  .lb-next { right: clamp(0.5rem, 3vw, 2rem); top: 50%; transform: translateY(-50%); }
  .lb-prev:hover, .lb-next:hover { transform: translateY(-50%) scale(1.08); }
  .lb-counter {
    position: fixed; bottom: clamp(1rem, 3vw, 2rem); left: 50%; transform: translateX(-50%);
    font-family: var(--font-display); font-size: 0.85rem; letter-spacing: 0.1em; color: rgba(255,255,255,0.8);
    background: rgba(0,0,0,0.4); padding: 0.4rem 1rem; border-radius: 999px;
  }
  .lb.single .lb-prev, .lb.single .lb-next, .lb.single .lb-counter { display: none; }

  /* トリガー側の見え方（クリック可能の合図） */
  :global([data-gallery]) { cursor: zoom-in; }
  @media (prefers-reduced-motion: reduce) { .lb, .lb-figure img { transition: none; } }
</style>

<script>
  const lb = document.getElementById("lightbox");
  if (lb) {
    const img = document.getElementById("lb-img") as HTMLImageElement;
    const cap = document.getElementById("lb-cap")!;
    const cur = document.getElementById("lb-cur")!;
    const total = document.getElementById("lb-total")!;
    let list: string[] = [];
    let caption = "";
    let i = 0;
    let lastFocused: HTMLElement | null = null;
    const lockScroll = () => { const b = document.body; const n = (parseInt(b.dataset.scrollLock || "0", 10)) + 1; b.dataset.scrollLock = String(n); b.style.overflow = "hidden"; };
    const unlockScroll = () => { const b = document.body; const n = Math.max(0, (parseInt(b.dataset.scrollLock || "0", 10)) - 1); b.dataset.scrollLock = String(n); if (n === 0) b.style.overflow = ""; };
    const focusables = () => Array.from(lb.querySelectorAll('button, a[href], [tabindex]:not([tabindex="-1"])')).filter((el) => (el as HTMLElement).offsetParent !== null) as HTMLElement[];
    const onTrap = (e: KeyboardEvent) => { if (e.key !== "Tab") return; const f = focusables(); if (!f.length) return; const first = f[0], last = f[f.length - 1]; if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); } else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); } };

    const show = () => {
      lb.classList.remove("show-img");
      img.src = list[i];
      cur.textContent = String(i + 1);
      total.textContent = String(list.length);
      cap.textContent = list.length > 1 ? `${caption}（${i + 1}/${list.length}）` : caption;
      lb.classList.toggle("single", list.length <= 1);
      requestAnimationFrame(() => requestAnimationFrame(() => lb.classList.add("show-img")));
      // 次の画像を先読み
      if (list.length > 1) { const n = new Image(); n.src = list[(i + 1) % list.length]; }
    };
    const open = (arr: string[], start: number, capText: string) => {
      list = arr; i = start; caption = capText || "";
      lastFocused = document.activeElement as HTMLElement;
      lb.classList.add("open"); lb.setAttribute("aria-hidden", "false");
      lockScroll();
      lb.addEventListener("keydown", onTrap as EventListener);
      show();
      const cb = lb.querySelector(".lb-close") as HTMLElement | null; cb?.focus();
    };
    const close = () => {
      // フォーカスがLightbox内に残っていると aria-hidden が無効になる→先に外す
      const fa = document.activeElement as HTMLElement | null;
      if (fa && lb.contains(fa) && fa.blur) fa.blur();
      lb.classList.remove("open");
      lb.removeEventListener("keydown", onTrap as EventListener);
      lb.setAttribute("aria-hidden", "true");
      unlockScroll();
      lastFocused?.focus?.();
    };
    const step = (d: number) => { if (list.length) { i = (i + d + list.length) % list.length; show(); } };

    document.addEventListener("click", (e) => {
      const t = (e.target as HTMLElement).closest("[data-gallery]") as HTMLElement | null;
      if (t) {
        e.preventDefault();
        try {
          const arr = JSON.parse(t.dataset.gallery || "[]");
          if (arr.length) open(arr, Number(t.dataset.index || 0), t.dataset.caption || "");
        } catch {}
      }
    });
    document.addEventListener("keydown", (e) => {
      if (!lb.classList.contains("open")) return;
      // capture フェーズ＋伝播停止で、背後のモーダル(詳細/相関図)のEscより先に“最前面のLightboxだけ”閉じる
      if (e.key === "Escape") { e.stopImmediatePropagation(); close(); }
      else if (e.key === "ArrowRight") step(1);
      else if (e.key === "ArrowLeft") step(-1);
    }, true);
    // Enter/Space でもトリガー（アクセシビリティ）
    document.addEventListener("keydown", (e) => {
      if ((e.key === "Enter" || e.key === " ") && document.activeElement?.hasAttribute("data-gallery")) {
        e.preventDefault();
        (document.activeElement as HTMLElement).click();
      }
    });
    lb.querySelector(".lb-close")!.addEventListener("click", close);
    lb.querySelector(".lb-prev")!.addEventListener("click", () => step(-1));
    lb.querySelector(".lb-next")!.addEventListener("click", () => step(1));
    lb.addEventListener("click", (e) => { if (e.target === lb || (e.target as HTMLElement).classList.contains("lb-figure")) close(); });
  }
</script>
