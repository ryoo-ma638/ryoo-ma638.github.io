---
// 作品の没入型ディテール・モーダル。任意要素に data-work="<slug>" を付けるとクリックで開く。
import { works, categoryLabels } from "../data/works.ts";
const data = works.map((w) => ({
  slug: w.slug,
  title: w.title,
  cat: categoryLabels[w.category].ja,
  color: categoryLabels[w.category].color,
  status: w.status ?? null,
  summary: w.summary,
  goal: w.goal ?? null,
  approach: w.approach ?? null,
  tools: w.tools ?? [],
  duration: w.duration ?? null,
  thumb: w.thumb ?? null,
  video: w.video ?? null,
  gallery: w.gallery ?? null,
  slideGroups: w.slideGroups ?? null,
  audio: w.audio ?? null,
  link: w.link ?? null,
  links: w.links ?? null,
}));
---

<div id="workModal" class="wm" aria-hidden="true" role="dialog" aria-modal="true" aria-label="作品詳細">
  <button class="wm-close" aria-label="閉じる">✕</button>
  <div class="wm-panel" role="document">
    <div class="wm-media" id="wmMedia"></div>
    <div class="wm-info">
      <div class="wm-tags"><span class="wm-tag" id="wmTag"></span><span class="wm-status" id="wmStatus"></span></div>
      <h2 id="wmTitle" class="display"></h2>
      <p class="wm-summary" id="wmSummary"></p>
      <div class="wm-audio" id="wmAudio" aria-label="試聴"></div>
      <div class="wm-kv" id="wmGoal"><span>狙い</span><p></p></div>
      <div class="wm-kv" id="wmApproach"><span>工夫</span><p></p></div>
      <dl class="wm-meta" id="wmMeta"></dl>
      <div class="wm-press" id="wmPress" aria-label="掲載メディア"></div>
      <div class="wm-gallery" id="wmGallery" aria-label="関連画像"></div>
      <div class="wm-slides" id="wmSlides" aria-label="スライド・資料"></div>
      <a class="btn btn--primary wm-link" id="wmLink" href="#">サイトを見る →</a>
      <a class="wm-permalink" id="wmPermalink" href="#">この作品の個別ページを開く <span aria-hidden="true">↗</span></a>
    </div>
  </div>
</div>

<style>
  .wm { position: fixed; inset: 0; z-index: 900; display: none; padding: clamp(0.5rem, 3vw, 2.5rem);
    background: color-mix(in srgb, #05050a 86%, transparent); backdrop-filter: blur(16px) saturate(120%);
    opacity: 0; transition: opacity 0.4s var(--ease); overflow-y: auto; -webkit-overflow-scrolling: touch; }
  /* モーダル全体（.wm）を唯一のスクロール領域にし、パネルは自然な高さで丸ごとスクロール */
  .wm.open { display: flex; justify-content: center; opacity: 1; }
  .wm-panel { width: min(900px, 100%); margin: auto; background: var(--bg-2); border: 1px solid var(--line); border-radius: var(--radius);
    overflow: hidden; display: flex; flex-direction: column; box-shadow: 0 40px 100px rgba(0,0,0,0.6);
    transform: translateY(24px) scale(0.985); transition: transform 0.45s var(--ease); }
  .wm.open .wm-panel { transform: none; }

  /* メディアは大きく・くっきり（ぼかし背景は使わない） */
  .wm-media { background: #0b0a12; display: grid; place-items: center; padding: 0.6rem; cursor: zoom-in; flex: 0 0 auto; }
  .wm-media img, .wm-media video { width: auto; height: auto; max-width: 100%; max-height: 62vh; object-fit: contain; border-radius: 6px; display: block; }

  .wm-info { padding: clamp(1.4rem, 3vw, 2.2rem); }

  /* PC：左右2カラム（メディア｜情報）。クリックした瞬間に、タイトル・概要・狙いが目に入るように。
     情報側だけを内部スクロールにして、メディアは常に見えたまま＝二重スクロールの違和感を出さない。 */
  @media (min-width: 900px) {
    .wm.open { align-items: center; }
    .wm-panel { flex-direction: row; align-items: stretch; width: min(1200px, 100%); max-height: 86vh; }
    .wm-media { flex: 1.2 1 0; min-width: 0; padding: 1.1rem; border-right: 1px solid var(--line); }
    .wm-media img, .wm-media video { max-height: calc(86vh - 2.2rem); }
    .wm-info { flex: 1 1 0; min-width: 0; min-height: 0; max-height: 86vh; overflow-y: auto; -webkit-overflow-scrolling: touch; scrollbar-width: thin; }
    .wm-info::-webkit-scrollbar { width: 8px; }
    .wm-info::-webkit-scrollbar-thumb { background: var(--line); border-radius: 999px; }
    .wm-info::-webkit-scrollbar-track { background: transparent; }
  }
  .wm-tags { display: inline-flex; gap: 0.5rem; align-items: center; margin-bottom: 0.9rem; flex-wrap: wrap; }
  .wm-tag { font-size: 0.7rem; font-weight: 700; padding: 0.32rem 0.8rem; border-radius: 999px; color: #06060a; background: var(--c, #fff); }
  .wm-status { font-size: 0.7rem; font-weight: 700; padding: 0.3rem 0.8rem; border-radius: 999px; color: var(--fg); border: 1.5px solid var(--line); }
  .wm-status:empty, .wm-tag:empty { display: none; }
  .wm-info h2 { font-size: clamp(1.5rem, 3.4vw, 2.4rem); line-height: 1.1; margin-bottom: 0.9rem; }
  .wm-summary { color: var(--fg); margin-bottom: 1.2rem; }
  .wm-kv { display: grid; grid-template-columns: 3.5rem 1fr; gap: 0.7rem; color: var(--fg-soft); font-size: var(--fs-small); margin-bottom: 0.7rem; }
  .wm-kv span { font-weight: 700; color: var(--fg); }
  .wm-kv[hidden] { display: none; }
  .wm-meta { display: flex; gap: 2rem; margin: 1.1rem 0; flex-wrap: wrap; }
  .wm-meta div { display: grid; gap: 0.2rem; }
  .wm-meta dt { font-family: var(--font-display); font-size: 0.66rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); }
  .wm-meta dd { font-weight: 700; font-size: var(--fs-small); }
  .wm-audio { display: flex; flex-direction: column; gap: 0.7rem; margin: 0.4rem 0 0.2rem; }
  .wm-audio[hidden] { display: none; }
  .wm-track { background: var(--bg-3); border: 1px solid var(--line); border-radius: 12px; padding: 0.7rem 0.85rem; }
  .wm-track-head { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem; flex-wrap: wrap; }
  .wm-track-ic { color: var(--c-violet); font-size: 1.1rem; line-height: 1; }
  .wm-track-title { font-weight: 700; font-size: 0.98rem; }
  .wm-track-note { font-size: 0.74rem; color: var(--muted); }
  .wm-track audio { width: 100%; height: 36px; display: block; }
  .wm-gallery { display: flex; gap: 0.6rem; flex-wrap: wrap; margin-top: 0.5rem; }
  .wm-gallery img { width: 84px; height: 60px; object-fit: cover; border-radius: 8px; border: 1px solid var(--line); cursor: zoom-in; transition: transform 0.25s var(--ease), border-color 0.25s var(--ease); }
  .wm-gallery img:hover { transform: translateY(-3px); border-color: var(--accent-ink); }

  /* 横スクロールのスライドグループ（発表資料・カード等を発表/種類ごとに分けて閲覧） */
  .wm-slides { display: flex; flex-direction: column; gap: 1.1rem; margin-top: 0.6rem; }
  .wm-slides:empty { display: none; }
  .wm-sgroup-title { font-size: 0.92rem; font-weight: 700; margin: 0 0 0.55rem; display: flex; align-items: baseline; gap: 0.6rem; }
  .wm-sgroup-title span { font-size: 0.7rem; font-weight: 500; color: var(--muted); }
  .wm-strip { display: flex; gap: 0.7rem; overflow-x: auto; scroll-snap-type: x mandatory; padding-bottom: 0.6rem; scrollbar-width: thin; -webkit-overflow-scrolling: touch; }
  .wm-strip::-webkit-scrollbar { height: 7px; }
  .wm-strip::-webkit-scrollbar-thumb { background: var(--line); border-radius: 999px; }
  .wm-slide { flex: 0 0 auto; width: clamp(240px, 72%, 420px); aspect-ratio: 16 / 10; object-fit: contain; border-radius: 10px; border: 1px solid var(--line); background: #eef0f4; cursor: zoom-in; scroll-snap-align: start; transition: border-color 0.25s var(--ease); }
  .wm-slide:hover { border-color: var(--accent-ink); }
  .wm-link { margin-top: 1.4rem; }
  .wm-link[hidden] { display: none; }
  /* 個別ページ(/works/slug)への内部リンク＝共有・検索・ブラウザ戻り用の独立URLへ誘導 */
  .wm-permalink { display: block; width: fit-content; margin-top: 0.9rem; font-family: var(--font-display); font-size: 0.8rem; font-weight: 700;
    color: var(--fg-soft); border-bottom: 1px solid var(--line); padding-bottom: 2px; transition: color 0.25s var(--ease), border-color 0.25s var(--ease); }
  .wm-permalink:hover { color: var(--fg); border-color: var(--accent-ink); }

  .wm-close { position: fixed; top: clamp(0.8rem, 2.5vw, 1.6rem); right: clamp(0.8rem, 2.5vw, 1.6rem); z-index: 901;
    width: 50px; height: 50px; border-radius: 50%; display: grid; place-items: center; color: #0b0a12; font-size: 1.5rem; font-weight: 700;
    background: #fff; border: none; box-shadow: 0 8px 24px rgba(0,0,0,0.45); transition: transform 0.3s var(--ease), background 0.25s var(--ease); }
  .wm-close:hover { transform: scale(1.1) rotate(90deg); background: var(--accent-ink); color: #fff; }
  @media (prefers-reduced-motion: reduce) { .wm, .wm-panel { transition: none; } }
</style>

<!-- JSで動的生成される要素（media/gallery/audio/slide）はAstroのスコープ付きCSSが効かないため、
     #workModal 配下に限定したグローバルCSSで確実にスタイルを当てる -->
<style is:global>
  /* メイン画像/動画：contain＋高さ上限で「左右に余白・全体表示」を保証（JS生成なのでスコープCSSは当たらない） */
  #workModal .wm-media img, #workModal .wm-media video { width: auto; height: auto; max-width: 100%; max-height: 62vh; object-fit: contain; border-radius: 6px; display: block; }
  @media (min-width: 900px) {
    #workModal .wm-media img, #workModal .wm-media video { max-height: calc(86vh - 2.2rem); }
  }

  #workModal .wm-gallery img { width: 84px; height: 60px; object-fit: cover; border-radius: 8px; border: 1px solid var(--line); cursor: zoom-in; transition: transform 0.25s var(--ease), border-color 0.25s var(--ease); }
  #workModal .wm-gallery img:hover { transform: translateY(-3px); border-color: var(--accent-ink); }

  #workModal .wm-track { background: var(--bg-3); border: 1px solid var(--line); border-radius: 12px; padding: 0.7rem 0.85rem; }
  #workModal .wm-track-head { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem; flex-wrap: wrap; }
  #workModal .wm-track-ic { color: var(--c-violet); font-size: 1.1rem; line-height: 1; }
  #workModal .wm-track-title { font-weight: 700; font-size: 0.98rem; }
  #workModal .wm-track-note { font-size: 0.74rem; color: var(--muted); }
  #workModal .wm-track audio { width: 100%; height: 36px; display: block; }

  #workModal .wm-sgroup-title { font-size: 0.92rem; font-weight: 700; margin: 0 0 0.55rem; display: flex; align-items: baseline; gap: 0.6rem; }
  #workModal .wm-sgroup-title span { font-size: 0.7rem; font-weight: 500; color: var(--muted); }
  #workModal .wm-strip { display: flex; gap: 0.7rem; overflow-x: auto; scroll-snap-type: x mandatory; padding-bottom: 0.6rem; scrollbar-width: thin; -webkit-overflow-scrolling: touch; }
  #workModal .wm-strip::-webkit-scrollbar { height: 7px; }
  #workModal .wm-strip::-webkit-scrollbar-thumb { background: var(--line); border-radius: 999px; }
  #workModal .wm-slide { flex: 0 0 auto; width: clamp(240px, 72%, 420px); aspect-ratio: 16 / 10; object-fit: contain; border-radius: 10px; border: 1px solid var(--line); background: #eef0f4; cursor: zoom-in; scroll-snap-align: start; transition: border-color 0.25s var(--ease); }
  #workModal .wm-slide:hover { border-color: var(--accent-ink); }

  #workModal .wm-press { display: flex; flex-wrap: wrap; align-items: center; gap: 0.5rem; margin: 1.1rem 0 0.2rem; }
  #workModal .wm-press[hidden] { display: none; }
  #workModal .wm-press-label { font-size: 0.78rem; font-weight: 700; color: var(--fg-soft); }
  #workModal .wm-press-link { font-size: 0.8rem; font-weight: 700; color: var(--accent-ink); border: 1px solid var(--line); border-radius: 999px; padding: 0.34rem 0.85rem; transition: border-color 0.25s var(--ease), transform 0.25s var(--ease); }
  #workModal .wm-press-link:hover { border-color: var(--accent-ink); transform: translateY(-2px); }
</style>

<script is:inline define:vars={{ data }}>
  (() => {
    const modal = document.getElementById("workModal");
    if (!modal) return;
    const byId = Object.fromEntries(data.map((w) => [w.slug, w]));
    const $ = (id) => document.getElementById(id);
    const esc = (s) => String(s == null ? "" : s);

    // 焦点トラップ＆参照カウント方式のスクロールロック（Lightbox と整合させ早期解除を防ぐ）
    let lastFocused = null;
    const lockScroll = () => { const b = document.body; const n = (parseInt(b.dataset.scrollLock || "0", 10)) + 1; b.dataset.scrollLock = String(n); b.style.overflow = "hidden"; };
    const unlockScroll = () => { const b = document.body; const n = Math.max(0, (parseInt(b.dataset.scrollLock || "0", 10)) - 1); b.dataset.scrollLock = String(n); if (n === 0) b.style.overflow = ""; };
    const focusables = () => Array.from(modal.querySelectorAll('button, a[href], [tabindex]:not([tabindex="-1"]), audio[controls], video[controls]')).filter((el) => el.offsetParent !== null);
    const onTrap = (e) => { if (e.key !== "Tab") return; const f = focusables(); if (!f.length) return; const first = f[0], last = f[f.length - 1]; if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); } else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); } };

    function open(slug) {
      const w = byId[slug];
      if (!w) return;
      const media = $("wmMedia");
      const lbList = w.gallery && w.gallery.length ? w.gallery : (w.thumb ? [w.thumb] : []);
      media.style.setProperty("--mbg", w.thumb ? `url(${w.thumb})` : "none");
      media.dataset.gallery = JSON.stringify(lbList);
      media.dataset.caption = w.title;
      if (w.video) media.innerHTML = `<video src="${w.video}" poster="${esc(w.thumb)}" autoplay muted loop playsinline></video>`;
      else if (w.thumb) media.innerHTML = `<img src="${w.thumb}" alt="${esc(w.title)}">`;
      else media.innerHTML = '<span style="position:relative;z-index:1;color:var(--muted)">準備中</span>';

      $("wmTag").textContent = w.cat;
      $("wmTag").style.setProperty("--c", w.color);
      $("wmStatus").textContent = w.status || "";
      $("wmTitle").textContent = w.title;
      $("wmSummary").textContent = w.summary || "";

      const au = $("wmAudio"); au.innerHTML = "";
      if (w.audio && w.audio.length) {
        w.audio.forEach((t) => {
          au.insertAdjacentHTML("beforeend",
            `<div class="wm-track"><div class="wm-track-head"><span class="wm-track-ic" aria-hidden="true">♪</span><span class="wm-track-title">${esc(t.title)}</span>${t.note ? `<span class="wm-track-note">${esc(t.note)}</span>` : ""}</div><audio controls preload="none" src="${esc(t.src)}"></audio></div>`);
        });
        au.hidden = false;
      } else au.hidden = true;

      const goal = $("wmGoal"); goal.hidden = !w.goal; goal.querySelector("p").textContent = esc(w.goal);
      const appr = $("wmApproach"); appr.hidden = !w.approach; appr.querySelector("p").textContent = esc(w.approach);

      const meta = $("wmMeta"); meta.innerHTML = "";
      if (w.tools && w.tools.length) meta.insertAdjacentHTML("beforeend", `<div><dt>使用ツール</dt><dd>${w.tools.join(" / ")}</dd></div>`);
      if (w.duration) meta.insertAdjacentHTML("beforeend", `<div><dt>制作時間</dt><dd>${esc(w.duration)}</dd></div>`);

      const press = $("wmPress"); press.innerHTML = "";
      if (w.links && w.links.length) {
        press.insertAdjacentHTML("beforeend", '<span class="wm-press-label">📰 掲載メディア</span>');
        w.links.forEach((l) => {
          press.insertAdjacentHTML("beforeend", `<a class="wm-press-link" href="${esc(l.href)}" target="_blank" rel="noopener noreferrer">${esc(l.label)} <span aria-hidden="true">↗</span></a>`);
        });
        press.hidden = false;
      } else press.hidden = true;

      const gal = $("wmGallery"); gal.innerHTML = "";
      if (w.gallery && w.gallery.length) {
        w.gallery.forEach((src, i) => {
          gal.insertAdjacentHTML("beforeend", `<img src="${src}" alt="" loading="lazy" data-gallery='${JSON.stringify(w.gallery)}' data-index="${i}" data-caption="${esc(w.title)}">`);
        });
      }

      const sg = $("wmSlides"); sg.innerHTML = "";
      if (w.slideGroups && w.slideGroups.length) {
        w.slideGroups.forEach((grp) => {
          const imgs = grp.images.map((src, i) =>
            `<img class="wm-slide" src="${src}" alt="" loading="lazy" data-gallery='${JSON.stringify(grp.images)}' data-index="${i}" data-caption="${esc(grp.title)}">`).join("");
          sg.insertAdjacentHTML("beforeend",
            `<div class="wm-sgroup"><h4 class="wm-sgroup-title">${esc(grp.title)}${grp.images.length > 1 ? `<span>${grp.images.length}枚 ・ 横スクロール →</span>` : ""}</h4><div class="wm-strip">${imgs}</div></div>`);
        });
      }
      const link = $("wmLink");
      if (w.link) { link.hidden = false; link.href = w.link; const ext = /^https?:/.test(w.link); link.target = ext ? "_blank" : ""; link.rel = ext ? "noopener noreferrer" : ""; } else link.hidden = true;
      $("wmPermalink").href = `/works/${w.slug}`;

      lastFocused = document.activeElement;
      modal.classList.add("open");
      modal.setAttribute("aria-hidden", "false");
      lockScroll();
      modal.addEventListener("keydown", onTrap);
      const cb = modal.querySelector(".wm-close"); if (cb) cb.focus();
    }
    function close() {
      // フォーカスがモーダル内に残っていると aria-hidden が無効になる→先に外す
      const fa = document.activeElement;
      if (fa && modal.contains(fa) && fa.blur) fa.blur();
      modal.classList.remove("open");
      modal.removeEventListener("keydown", onTrap);
      modal.setAttribute("aria-hidden", "true");
      unlockScroll();
      const v = modal.querySelector("video"); if (v) v.pause();
      modal.querySelectorAll("audio").forEach((a) => a.pause());
      if (lastFocused && lastFocused.focus) lastFocused.focus();
    }

    document.addEventListener("click", (e) => {
      const t = e.target.closest("[data-work]");
      if (t) { e.preventDefault(); open(t.dataset.work); }
    });
    document.addEventListener("keydown", (e) => {
      const a = document.activeElement;
      if ((e.key === "Enter" || e.key === " ") && a && a.hasAttribute && a.hasAttribute("data-work")) {
        e.preventDefault(); a.click();
      }
    });
    modal.querySelector(".wm-close").addEventListener("click", close);
    modal.addEventListener("click", (e) => { if (e.target === modal) close(); });
    document.addEventListener("keydown", (e) => {
      // ライトボックスが開いている時はそちらを優先（lightbox 側で処理）
      const lbOpen = document.getElementById("lightbox")?.classList.contains("open");
      if (e.key === "Escape" && modal.classList.contains("open") && !lbOpen) close();
    });
  })();
</script>
