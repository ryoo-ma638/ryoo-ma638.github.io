---
import Base from "../layouts/Base.astro";
import { featuredWorks, categoryLabels, works } from "../data/works.ts";

const counts: Record<string, number> = {};
for (const k of Object.keys(categoryLabels)) {
  counts[k] = works.filter((w) => w.category === k).length;
}
// 各分野の代表作サムネ（Fields のホバープレビュー用＝分野を実作品に紐づける＝脱テンプレ）
const fieldThumb: Record<string, string | undefined> = {};
for (const k of Object.keys(categoryLabels)) {
  fieldThumb[k] = works.find((w) => w.category === k && w.thumb)?.thumb;
}
// ヒーロー背景の斜めキネティック文字（複数本が斜めに流れる）
const kineticA = ["CG", "VIDEO", "3DCG", "MOTION", "INTERACTION", "VISION"];
const kineticB = ["GRAPHIC", "WEB", "GAME", "SLIDES", "CREATE", "DESIGN"];

// 「活動と挑戦」＝つくる以外の幅（すべて実績ベース・色＝多分野）。トップで“色々手を出している”を一目で伝える。
const activities = [
  { c: "var(--c-violet)", k: "課外", t: "ビール売り子", d: "バンテリンドームナゴヤで、ビールの売り子として活動。球場の時間を、もっと楽しく。", link: "https://uriko-v-dome-ryoma.vercel.app", linkLabel: "応援サイトへ" },
  { c: "var(--c-blue)", k: "役割", t: "学生団体 CEED 副部長", d: "60名規模の運営・新歓・イベント企画。“誰も置いてけぼりにしない”を大切に。", link: "/ceed", linkLabel: "CEEDの活動へ" },
  { c: "var(--c-green)", k: "出展", t: "東京ゲームショウ ほか", d: "『虫歯アニマルズ』でTGS・ゲームマーケット・安城Eフェスに出展。", link: "/works#mushiba-animals", linkLabel: "作品を見る" },
  { c: "var(--c-yellow)", k: "ハッカソン", t: "ハッカソン 受賞", d: "シスハックで割り勘アプリ『Settlo』を開発し、企業賞を受賞した。", link: "/works#settlo", linkLabel: "作品を見る" },
  { c: "var(--c-orange)", k: "研究", t: "学会発表に挑戦", d: "水野慎士研究室での研究を、外の場へ。いま挑戦の途中。" },
  { c: "var(--c-red)", k: "進学", t: "大学院 進学を準備", d: "CG・画像処理・インタラクションを、もっと深くへ。" },
];
---

<Base>
  <!-- ===== HERO ===== -->
  <section class="hero" data-accent="var(--c-violet)">
    <div class="hero-bg" aria-hidden="true">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-aurora" aria-hidden="true"></div>
    <div class="hero-kinetic" aria-hidden="true">
      <div class="hk-row hk-row--1">
        {[...kineticA, ...kineticA, ...kineticA].map((w, i) => (<span class:list={{ on: i % 3 === 1 }}>{w}</span>))}
      </div>
      <div class="hk-row hk-row--2">
        {[...kineticB, ...kineticB, ...kineticB].map((w, i) => (<span class:list={{ on: i % 3 === 2 }}>{w}</span>))}
      </div>
      <div class="hk-row hk-row--3">
        {[...kineticA, ...kineticB, ...kineticA, ...kineticB].map((w, i) => (<span class:list={{ on: i % 4 === 0 }}>{w}</span>))}
      </div>
    </div>
    </div>
    <div class="container hero-inner">
      <p class="eyebrow reveal">Portfolio — Osaki Ryoma</p>
      <h1 class="hero-title display reveal">
        <span class="line-mask"><span>つくって、</span></span>
        <span class="line-mask"><span class="spectrum-text">光を放つ。</span></span>
      </h1>
      <div class="hero-foot reveal" data-delay="2">
        <p class="hero-thesis">いろいろなことに手を出すほど、<span class="spectrum-text">出せる色が増えていく。</span></p>
        <p class="hero-lead">
          愛知工業大学 情報科学部 メディア情報専攻。水野慎士研究室で CG・画像処理を学びながら、
          グラフィック・映像・Web・企画、そして球場の売り場まで — 領域を分けずに横断しています。
        </p>
        <div class="hero-actions">
          <a href="/works" class="btn btn--primary">作品を見る →</a>
          <a href="/about" class="btn btn--ghost">About</a>
        </div>
      </div>
    </div>
    <div class="hero-scroll" aria-hidden="true">SCROLL<span></span></div>
  </section>

  <!-- ===== FEATURED (Bento) ===== -->
  <section class="section" data-accent="var(--c-blue)">
    <div class="container">
      <div class="section-head sh-row reveal">
        <div>
          <span class="eyebrow">Selected Works</span>
          <h2 class="display">代表的な作品</h2>
        </div>
        <a href="/works" class="link-arrow display">すべて見る →</a>
      </div>

      <div class="bento">
        {featuredWorks.map((w, i) => (
          <a href={`/works#${w.slug}`} class="bento-card reveal" data-delay={(i % 3) + 1}>
            <div class="bento-media" style={w.thumb ? `--mbg:url(${w.thumb})` : undefined}>
              {w.video
                ? <video src={w.video} poster={w.thumb} muted loop playsinline preload="none" data-hover></video>
                : <img src={w.thumb} alt={w.title} loading="lazy" onerror="this.closest('.bento-card').classList.add('noimg')" />}
            </div>
            <div class="bento-overlay">
              <span class="tag" style={`--c:${categoryLabels[w.category].color}`}>{categoryLabels[w.category].ja}</span>
              <div class="bento-text">
                <h3>{w.title}</h3>
                <p>{w.summary}</p>
              </div>
              <span class="bento-view">View →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FIELDS ===== -->
  <section class="section section--alt" data-accent="var(--c-cyan)">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">Focus</span>
        <h2 class="sec-title">6つの領域を、横断する。</h2>
        <p class="fields-lead">ひとつの分野に絞らない。横断するほど、できることが増えていく。</p>
      </div>
      <ul class="fields">
        {Object.entries(categoryLabels).map(([key, c], i) => (
          <li class="field reveal" style={`--c:${c.color}`}>
            <a href={`/works#cat-${key}`}>
              <span class="field-no">{String(i + 1).padStart(2, "0")}</span>
              <span class="field-main">
                <span class="field-en display">{c.en}</span>
                <span class="field-ja">{c.ja}</span>
              </span>
              <span class="field-count display">{counts[key as keyof typeof counts]}<small>works</small></span>
              <span class="field-arrow" aria-hidden="true">↗</span>
              {fieldThumb[key] && <span class="field-preview" style={`background-image:url(${fieldThumb[key]})`} aria-hidden="true"></span>}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ===== ACTIVITY & CHALLENGE（つくる以外の幅：色々なことに手を出している） ===== -->
  <section class="section" data-accent="var(--c-orange)">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">Activity &amp; Challenge</span>
        <h2 class="sec-title">色々なことに、手を出してきた。</h2>
        <p class="acts-lead">つくることの外側でも動いてきた。売り場、運営、出展、ハッカソン、そして研究へ。</p>
      </div>
      <div class="acts">
        {activities.map((a, i) => {
          const Tag = a.link ? "a" : "div";
          return (
            <Tag class:list={["act", "reveal", { "act--link": !!a.link }]} data-delay={(i % 3) + 1} style={`--c:${a.c}`} href={a.link ?? undefined} target={a.link?.startsWith("http") ? "_blank" : undefined} rel={a.link?.startsWith("http") ? "noopener noreferrer" : undefined}>
              <span class="act-no">{String(i + 1).padStart(2, "0")}</span>
              <span class="act-k">{a.k}</span>
              <h3 class="act-t">{a.t}</h3>
              <p class="act-d">{a.d}</p>
              {a.link && <span class="act-arrow" aria-hidden="true">{a.linkLabel ?? "詳しく"} ↗</span>}
            </Tag>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ===== ABOUT teaser ===== -->
  <section class="section about-teaser" data-accent="var(--c-red)">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">About</span>
        <h2 class="sec-title about-copy">手を動かして、学ぶ。</h2>
      </div>
      <p class="about-sub reveal">
        水野慎士研究室での CG・画像処理を軸に、グラフィック・映像・Web・企画まで——
        興味の向くままに手を出しながら、表現の幅を広げています。次は、学会発表と大学院へ。
      </p>
      <ul class="about-stats reveal" data-delay="1" aria-label="数字で見る">
        <li><b>06</b><span>領域 / Fields</span></li>
        <li><b>{works.length}</b><span>作品 / Works</span></li>
        <li><b>03</b><span>出展 / Exhibitions</span></li>
      </ul>
      <div class="about-foot reveal" data-delay="2">
        <ul class="about-facts">
          <li>情報科学部 メディア情報専攻</li>
          <li>水野慎士研究室（CG・画像処理）</li>
          <li>学生団体 CEED 副部長</li>
        </ul>
        <a href="/about" class="btn btn--primary">プロフィールを見る →</a>
      </div>
    </div>
  </section>

  <style>
    /* HERO（本文がほぼ満たす高さ＝下に暗い空きを作らない） */
    .hero { position: relative; min-height: 88svh; display: flex; align-items: center; overflow: hidden; }
    /* 背景の発光（グロー/オーロラ/斜め文字）を“下へフェードアウト”＝下端で色がハードに切れる継ぎ目を解消し、
       ヒーロー下端を作品セクションと同じ暗さに揃える（暗い帯も切れ目も出ない） */
    .hero-bg { position: absolute; inset: 0; z-index: 0; overflow: hidden;
      -webkit-mask-image: linear-gradient(to bottom, #000 45%, transparent 90%);
      mask-image: linear-gradient(to bottom, #000 45%, transparent 90%); }
    /* ヒーロー直後の作品セクションは上を詰めて境目を自然に */
    .hero + .section { padding-top: var(--space-3); }
    .hero-glow { position: absolute; inset: 0; z-index: -1;
      background:
        radial-gradient(40% 38% at 78% 18%, color-mix(in srgb, var(--c-violet) 40%, transparent), transparent 70%),
        radial-gradient(38% 40% at 10% 88%, color-mix(in srgb, var(--c-cyan) 28%, transparent), transparent 70%),
        radial-gradient(30% 30% at 92% 92%, color-mix(in srgb, var(--c-red) 24%, transparent), transparent 70%);
      filter: blur(10px); animation: float 16s var(--ease) infinite alternate;
    }
    @keyframes float { to { transform: translate3d(-2%, 2%, 0) scale(1.08); } }
    /* スペクトラムのオーロラ（ゆっくり回転して呼吸する） */
    .hero-aurora { position: absolute; inset: -18% -8%; z-index: -1; pointer-events: none;
      background: conic-gradient(from 0deg at 60% 40%,
        color-mix(in srgb, var(--c-violet) 22%, transparent),
        color-mix(in srgb, var(--c-cyan) 20%, transparent),
        color-mix(in srgb, var(--c-green) 16%, transparent),
        color-mix(in srgb, var(--c-orange) 18%, transparent),
        color-mix(in srgb, var(--c-red) 20%, transparent),
        color-mix(in srgb, var(--c-violet) 22%, transparent));
      filter: blur(52px); opacity: 0.4; mix-blend-mode: screen;
      animation: aurora 44s linear infinite; }
    @keyframes aurora { to { transform: rotate(360deg); } }
    :root[data-theme="light"] .hero-aurora { mix-blend-mode: multiply; opacity: 0.32; }
    @media (prefers-reduced-motion: reduce) { .hero-aurora { animation: none; } }
    .hero-inner { position: relative; z-index: 2; padding-top: clamp(64px, 8vh, 100px); }
    .hero-title { font-size: var(--fs-mega); font-weight: 700; line-height: 0.92; letter-spacing: -0.04em; margin-bottom: var(--space-4); }
    .hero-foot { display: grid; gap: var(--space-3); grid-template-columns: 1fr; max-width: 760px; }
    .hero-thesis { font-family: var(--font-display); font-weight: 700; font-size: clamp(1.15rem, 2.2vw, 1.7rem); line-height: 1.45; letter-spacing: -0.01em; }
    .hero-lead { color: var(--fg-soft); font-size: clamp(1rem, 1.4vw, 1.2rem); max-width: 52ch; }
    .hero-actions { display: flex; gap: 0.8rem; flex-wrap: wrap; }
    .hero-scroll { position: absolute; z-index: 3; bottom: 1.6rem; left: 50%; transform: translateX(-50%); font-family: var(--font-display); font-size: 0.7rem; letter-spacing: 0.25em; color: var(--muted); display: flex; flex-direction: column; align-items: center; gap: 0.6rem; }
    .hero-scroll span { width: 1px; height: 40px; background: linear-gradient(var(--muted), transparent); }

    /* MARQUEE */
    .marquee-wrap { padding-block: var(--space-3); border-block: 1px solid var(--line); }

    /* section head row */
    .sh-row { display: flex; justify-content: space-between; align-items: flex-end; gap: 1rem; }
    .link-arrow { color: var(--fg-soft); font-weight: 600; white-space: nowrap; transition: color 0.25s var(--ease); }
    .link-arrow:hover { color: var(--fg); }

    /* BENTO */
    /* モバイル：2列＋先頭を大きく（サムネが大きすぎ・縦に長すぎを解消） */
    .bento { display: grid; gap: 0.8rem; grid-template-columns: repeat(2, 1fr); grid-auto-rows: clamp(148px, 42vw, 184px); perspective: 1400px; }
    .bento-card { position: relative; overflow: hidden; border-radius: var(--radius); border: 1px solid var(--line); background: var(--bg-3); grid-column: span 1; transition: transform 0.4s var(--ease); transform-style: preserve-3d; }
    .bento-card:nth-child(1) { grid-column: span 2; grid-row: span 2; }
    @media (min-width: 760px) {
      .bento { grid-template-columns: repeat(6, 1fr); grid-auto-rows: 220px; gap: 1rem; }
      .bento-card { grid-column: span 2; }
      .bento-card:nth-child(1) { grid-column: span 4; grid-row: span 2; }
      .bento-card:nth-child(2) { grid-column: span 2; grid-row: span 2; }
    }
    .bento-media { position: absolute; inset: 0; display: grid; place-items: center; }
    .bento-media::before { content: ""; position: absolute; inset: 0; background-image: var(--mbg); background-size: cover; background-position: center; filter: blur(30px) brightness(0.55) saturate(1.3); z-index: 0; }
    .bento-media img, .bento-media video { position: relative; z-index: 1; width: 100%; height: 100%; object-fit: contain; transition: transform 0.7s var(--ease), filter 0.5s var(--ease); }
    .bento-card.noimg .bento-media::after { content: "画像準備中"; color: var(--muted); font-size: var(--fs-small); }
    .bento-card.noimg img { display: none; }
    .bento-card:hover .bento-media img { transform: scale(1.05); }

    .bento-overlay { position: absolute; inset: 0; z-index: 2; display: flex; flex-direction: column; justify-content: space-between; padding: 1.2rem; background: linear-gradient(to top, rgba(5,5,8,0.92) 0%, rgba(5,5,8,0.35) 45%, transparent 75%); }
    .tag { align-self: flex-start; font-size: 0.68rem; font-weight: 700; letter-spacing: 0.04em; padding: 0.3rem 0.7rem; border-radius: 999px; color: #06060a; background: var(--c, #fff); }
    .bento-text h3 { font-size: var(--fs-h3); color: #fff; margin-bottom: 0.3rem; }
    .bento-text p { font-size: var(--fs-small); color: rgba(255,255,255,0.7); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .bento-view { position: absolute; top: 1.2rem; right: 1.2rem; font-family: var(--font-display); font-size: 0.78rem; color: #fff; opacity: 0; transform: translateY(-6px); transition: all 0.3s var(--ease); }
    .bento-card:hover .bento-view { opacity: 1; transform: none; }
    /* モバイルの小カードは文字を詰めて窮屈さを回避（先頭の大カードは大きめ） */
    @media (max-width: 759px) {
      .bento-overlay { padding: 0.8rem; }
      .bento-text h3 { font-size: 0.95rem; line-height: 1.3; }
      .bento-text p { font-size: 0.72rem; }
      .bento-card:not(:nth-child(1)) .bento-text p { display: none; }
      .bento-card:nth-child(1) .bento-text h3 { font-size: 1.35rem; }
      .bento-view { display: none; }
    }

    /* FIELDS（番号付き索引＝エディトリアル。色は“ホバーの差し色”だけ＝脱・虹色テンプレ。
       ホバーで代表作サムネが出る＝分野を実作品に紐づける。見出しは明朝＝和の味） */
    .sec-title { font-family: var(--font-mincho); font-weight: 800; font-size: var(--fs-h2); line-height: 1.22; letter-spacing: 0.03em; }
    .fields-lead { color: var(--fg-soft); margin-top: 1rem; max-width: 46ch; font-size: clamp(0.95rem, 1.2vw, 1.05rem); }
    .fields { margin-top: var(--space-4); border-top: 1px solid var(--line); }
    .field { border-bottom: 1px solid var(--line); }
    .field a { position: relative; display: grid; grid-template-columns: auto 1fr auto auto; align-items: center; gap: 1.5rem; padding: 1.55rem 0.6rem; transition: padding 0.4s var(--ease); }
    .field a::before { content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 2px; background: var(--c); transform: scaleY(0); transform-origin: center; transition: transform 0.4s var(--ease); }
    .field a:hover { padding-left: 1.5rem; }
    .field a:hover::before { transform: scaleY(1); }
    .field-no { font-family: var(--font-display); font-weight: 700; font-size: 0.85rem; color: var(--muted); font-variant-numeric: tabular-nums; }
    .field-main { display: flex; flex-direction: column; gap: 0.15rem; min-width: 0; }
    .field-en { font-size: clamp(1.5rem, 3.6vw, 2.5rem); font-weight: 700; line-height: 1.05; color: var(--fg); transition: color 0.3s var(--ease); }
    .field a:hover .field-en { color: var(--c); }
    .field-ja { color: var(--fg-soft); font-size: var(--fs-small); }
    .field-count { font-weight: 700; color: var(--fg-soft); font-size: 1.05rem; font-variant-numeric: tabular-nums; }
    .field-count small { color: var(--muted); font-weight: 400; font-size: 0.64rem; letter-spacing: 0.06em; margin-left: 0.25rem; }
    .field-arrow { color: var(--muted); font-size: 1.1rem; transition: transform 0.3s var(--ease), color 0.3s var(--ease); }
    .field a:hover .field-arrow { transform: translate(3px, -3px); color: var(--c); }
    /* ホバーで代表作プレビュー（デスクトップのみ・実作品に紐づける） */
    .field-preview { position: absolute; right: 7.5rem; top: 50%; width: 210px; height: 124px; border-radius: 12px; background-size: cover; background-position: center; opacity: 0; transform: translateY(-50%) scale(0.95) rotate(-1.5deg); pointer-events: none; border: 1px solid var(--line); box-shadow: 0 24px 60px -24px rgba(0,0,0,0.7); transition: opacity 0.35s var(--ease), transform 0.35s var(--ease); z-index: 2; }
    @media (hover: hover) and (min-width: 920px) { .field a:hover .field-preview { opacity: 1; transform: translateY(-50%) scale(1) rotate(0); } }
    @media (max-width: 919px) { .field-preview { display: none; } }
    @media (max-width: 560px) {
      .field a { grid-template-columns: auto 1fr auto; gap: 0.9rem; padding: 1.25rem 0.5rem; }
      .field-en { font-size: 1.42rem; }
      .field-arrow { display: none; }
    }

    /* ACTIVITY & CHALLENGE（活動と挑戦：色＝多分野） */
    .acts-lead { color: var(--fg-soft); margin-top: 0.9rem; max-width: 46ch; font-size: clamp(0.95rem, 1.2vw, 1.05rem); }
    .acts { display: grid; gap: 1rem; grid-template-columns: 1fr; margin-top: var(--space-4); }
    @media (min-width: 680px) { .acts { grid-template-columns: repeat(2, 1fr); } }
    @media (min-width: 1000px) { .acts { grid-template-columns: repeat(3, 1fr); } }
    .act { position: relative; border: 1px solid var(--line); border-radius: var(--radius); background: var(--card); padding: 1.7rem 1.5rem 1.8rem; overflow: hidden; transition: transform 0.35s var(--ease), border-color 0.35s var(--ease); }
    /* 明朝の番号＝和・東映の章アンカー（常時は淡く、ホバーで分野色が灯る） */
    .act-no { display: block; font-family: var(--font-mincho); font-weight: 700; font-size: 2rem; line-height: 1; font-variant-numeric: tabular-nums; color: color-mix(in srgb, var(--fg) 20%, transparent); margin-bottom: 0.7rem; transition: color 0.35s var(--ease); }
    .act-k { display: block; font-family: var(--font-display); font-weight: 700; font-size: 0.66rem; letter-spacing: 0.16em; color: var(--muted); margin-bottom: 0.55rem; transition: color 0.35s var(--ease); }
    .act-t { font-family: var(--font-mincho); font-weight: 700; font-size: 1.28rem; line-height: 1.5; margin-bottom: 0.55rem; color: var(--fg); }
    .act-d { color: var(--fg-soft); font-size: var(--fs-small); line-height: 1.85; }
    .act:hover { transform: translateY(-4px); border-color: color-mix(in srgb, var(--c) 50%, var(--line)); }
    .act:hover .act-no, .act:hover .act-k { color: var(--c); }
    /* 売り子カード等＝外部リンク化したカードの誘導表示 */
    .act-arrow { display: inline-block; margin-top: 0.8rem; font-family: var(--font-display); font-size: 0.72rem; font-weight: 700; letter-spacing: 0.04em; color: var(--c); opacity: 0.9; transition: transform 0.3s var(--ease); }
    .act--link:hover .act-arrow { transform: translateX(3px); }
    :root[data-theme="light"] .act-arrow { color: color-mix(in srgb, var(--c) 76%, #15151c); }

    /* ライトテーマ：明るい分野色を文字に使う箇所は沈めて可読性を確保（色相は維持） */
    :root[data-theme="light"] .field a:hover .field-en { color: color-mix(in srgb, var(--c) 72%, #15151c); }
    :root[data-theme="light"] .act:hover .act-no,
    :root[data-theme="light"] .act:hover .act-k { color: color-mix(in srgb, var(--c) 76%, #15151c); }

    /* HERO KINETIC（ヒーロー背景：斜めに流れるゴースト文字を複数本） */
    .hero-kinetic { position: absolute; inset: -10% -8%; z-index: 0; display: flex; flex-direction: column; justify-content: center; gap: clamp(0.3rem, 2.2vh, 1.6rem); transform: rotate(-8deg); pointer-events: none; }
    .hk-row { display: flex; gap: 1.6rem; width: max-content; white-space: nowrap; font-family: var(--font-display); font-weight: 800; font-size: clamp(2.6rem, 11vw, 9rem); line-height: 1; color: transparent; -webkit-text-stroke: 1.5px color-mix(in srgb, var(--fg) 8%, transparent); will-change: transform; }
    .hk-row span { display: inline-block; }
    .hk-row .on { -webkit-text-stroke: 0; color: color-mix(in srgb, var(--accent-ink) 13%, transparent); }
    .hk-row--1 { animation: hk1 55s linear infinite; }
    .hk-row--2 { animation: hk2 70s linear infinite; }
    .hk-row--3 { animation: hk1 88s linear infinite; }
    @keyframes hk1 { to { transform: translateX(-33.33%); } }
    @keyframes hk2 { from { transform: translateX(-33.33%); } to { transform: translateX(0); } }
    @media (prefers-reduced-motion: reduce) { .hk-row { animation: none; } }

    /* ABOUT teaser（締め＝叙情コピー → 大数字の帯 → 事実＋CTA の自然な縦の流れ） */
    .center { text-align: center; }
    .about-copy { font-size: clamp(2.2rem, 5.5vw, 4rem); line-height: 1.2; margin-top: 0.4rem; }
    .about-sub { color: var(--fg-soft); max-width: 60ch; margin: var(--space-4) 0 0; font-size: clamp(1rem, 1.35vw, 1.15rem); line-height: 1.95; }
    /* 大数字の帯（明朝・極細罫で挟む＝MIKIMOTO/IMAYO型の格） */
    .about-stats { display: flex; flex-wrap: wrap; gap: clamp(1.8rem, 6vw, 4.5rem); margin: var(--space-4) 0; padding: var(--space-3) 0; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
    .about-stats li { display: flex; flex-direction: column; gap: 0.3rem; }
    .about-stats b { font-family: var(--font-mincho); font-weight: 700; font-size: clamp(3rem, 7vw, 5rem); line-height: 1; color: var(--fg); font-variant-numeric: tabular-nums; }
    .about-stats span { font-family: var(--font-display); font-size: 0.68rem; letter-spacing: 0.14em; color: var(--muted); text-transform: uppercase; }
    .about-foot { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 1.5rem; }
    .about-facts { display: flex; flex-wrap: wrap; gap: 0.6rem; }
    .about-facts li { font-size: var(--fs-small); color: var(--fg-soft); padding: 0.5rem 1.05rem; border: 1px solid var(--line); border-radius: 999px; }
  </style>

  <script>
    // Bento カードの立体ホバー（fine pointer かつ motion 許可時のみ）
    const fine = matchMedia("(pointer: fine)").matches;
    const okMotion = !matchMedia("(prefers-reduced-motion: reduce)").matches;

    // ヒーローのスクロール演出は背景グローのみ控えめに（本文はクリアに保つ）
    if (okMotion) {
      const heroScroll = document.querySelector<HTMLElement>(".hero-scroll");
      const heroGlow = document.querySelector<HTMLElement>(".hero-glow");
      let ticking = false;
      const onHeroScroll = () => {
        const y = window.scrollY;
        if (y <= window.innerHeight) {
          if (heroScroll) heroScroll.style.opacity = String(Math.max(0, 1 - (y / window.innerHeight) * 4));
          if (heroGlow) heroGlow.style.transform = `translateY(${y * 0.35}px)`;
        }
        ticking = false;
      };
      addEventListener("scroll", () => { if (!ticking) { requestAnimationFrame(onHeroScroll); ticking = true; } }, { passive: true });
    }

    // Bento動画はホバー時だけ再生（複数同時autoplayをやめて軽量化）。touch端末はポスター静止。
    if (fine) {
      document.querySelectorAll<HTMLElement>(".bento-card").forEach((card) => {
        const vid = card.querySelector<HTMLVideoElement>("video[data-hover]");
        if (vid) {
          card.addEventListener("pointerenter", () => { vid.preload = "auto"; vid.play().catch(() => {}); });
          card.addEventListener("pointerleave", () => { vid.pause(); });
        }
      });
    }

    if (fine && okMotion) {
      document.querySelectorAll<HTMLElement>(".bento-card").forEach((card) => {
        let raf = 0;
        card.addEventListener("pointermove", (e) => {
          const r = card.getBoundingClientRect();
          const px = (e.clientX - r.left) / r.width - 0.5;
          const py = (e.clientY - r.top) / r.height - 0.5;
          cancelAnimationFrame(raf);
          raf = requestAnimationFrame(() => {
            card.style.transform = `perspective(1400px) rotateX(${(-py * 5).toFixed(2)}deg) rotateY(${(px * 5).toFixed(2)}deg) translateZ(8px)`;
          });
        });
        card.addEventListener("pointerleave", () => {
          cancelAnimationFrame(raf);
          card.style.transform = "";
        });
      });
    }
  </script>
</Base>
