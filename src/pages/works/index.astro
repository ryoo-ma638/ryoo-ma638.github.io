---
import Base from "../../layouts/Base.astro";
import Lightbox from "../../components/Lightbox.astro";
import WorkModal from "../../components/WorkModal.astro";
import { works, categoryLabels, type Category } from "../../data/works.ts";

const order: Category[] = ["web", "imaging", "cg", "video", "planning", "graphic", "sound"];

// 各分野の中での表示順（売り出したい・評価が高いと思われる作品を上に）。
// ここに無いslugは元の順で末尾へ回る。data側は触らず、表示順だけを制御する。
const rankOrder: string[] = [
  // Web・アプリ：受託 → 公開中アプリ → 公開中サイト → 受賞 → 実案件 → …
  "drone-note", "meegri", "yumiki-world", "settlo", "chuo-seisakusho", "uriko-site", "ceed-site", "toka-club", "nogi-photo",
  // 画像処理・インタラクション：完成作品 → 研究中 → 構想中
  "death-comer", "shuwa-game", "wis-umbrella", "fukuoka-award",
  // CG・3D：代表作・高評価を上に
  "shibuya-crossing", "strikeout", /* "aitland"＝一時非表示中（works.tsでコメントアウト）。再表示時に位置を保つため残置 */ "robot-argus", "jojo-scene", "live-stage",
  // 映像（実写・編集）
  "mm2-cinematography", "manga-jitsuei",
  // 企画・発表（虫歯アニマルズ＝TGS出展もここへ移動）
  "presentation-slides", "mushiba-animals", "todofuken-battle",
  // グラフィック・ロゴ
  "color-poster", "business-card", "character-design",
  // サウンド・音楽
  "sound-arrange",
];
const rankOf = (slug: string) => { const i = rankOrder.indexOf(slug); return i < 0 ? 999 : i; };

const grouped = order.map((cat) => ({
  cat,
  label: categoryLabels[cat],
  items: works.filter((w) => w.category === cat).sort((a, b) => rankOf(a.slug) - rankOf(b.slug)),
}));
const total = works.length;
---

<Base title="Works — Osaki Ryoma" description="CG・映像・グラフィック・画像処理・Web の制作実績一覧。各作品に狙いと工夫を添えています。">
  <!-- HERO -->
  <section class="works-hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="container">
      <p class="eyebrow reveal">Works — 制作実績</p>
      <h1 class="mega display reveal"><span class="line-mask"><span>これまでの<span class="spectrum-text">制作</span></span></span></h1>
      <p class="lead reveal" data-delay="1">授業課題から受託・研究まで、取り組んだ制作を分野別に。各作品はクリックで「狙い・工夫・資料」まで詳しく見られます。<br />色は分野を表します ― 色の数だけ、手を出してきた分野がある。</p>
      <div class="wk-filter reveal" data-delay="2" role="group" aria-label="分野で絞り込み">
        <button type="button" class="chip chip--all is-active" data-cat="all" aria-pressed="true">すべて<small>{total}</small></button>
        {grouped.map((g) => (
          <button type="button" class="chip" data-cat={g.cat} style={`--c:${g.label.color}`} aria-pressed="false"><span class="d"></span>{g.label.ja}<small>{g.items.length}</small></button>
        ))}
      </div>
      <p class="wk-count reveal" data-delay="2" aria-live="polite"><b id="wkShown">{total}</b><span>/ {total} 作品を表示中</span></p>
    </div>
  </section>

  {grouped.map((g, gi) => (
    <section class="section cat-section" id={`cat-${g.cat}`} data-cat={g.cat} data-count={g.items.length} data-accent={g.label.color} style={`--c:${g.label.color}`}>
      <div class="container">
        <div class="cat-head reveal">
          <span class="cat-no display">0{gi + 1}</span>
          <div>
            <span class="eyebrow cat-eyebrow">{g.label.en}</span>
            <h2 class="display">{g.label.ja}</h2>
          </div>
        </div>

        <div class="work-list">
          {g.items.map((w, i) => {
            const galCount = w.gallery?.length;
            return (
            <article class="work-row reveal" id={w.slug} style={`--c:${g.label.color}`}>
              <div
                class={`work-media is-zoom${w.category === "graphic" ? " is-poster" : ""}${!w.thumb && !w.video ? " is-empty" : ""}`}
                style={w.thumb ? `--mbg:url(${w.thumb})` : undefined}
                data-work={w.slug}
                role="button"
                tabindex="0"
                aria-label={`${w.title} の詳細を見る`}
              >
                {w.video
                  ? <video src={w.video} poster={w.thumb} muted loop playsinline preload="none"></video>
                  : w.thumb
                    ? <img src={w.thumb} alt={w.title} loading="lazy" onerror="this.closest('.work-media').classList.add('noimg')" />
                    : <span class="media-ph">画像準備中</span>}
                <span class="zoom-hint">詳しく見る{galCount ? `（＋${galCount}枚）` : ""}<span aria-hidden="true"> ↗</span></span>
              </div>
              <div class="work-info">
                <span class="tags-row">
                  <span class="work-no">{String(i + 1).padStart(2, "0")}</span>
                  {w.status && <span class="status-pill">{w.status}</span>}
                </span>
                <h3>{w.title}</h3>
                <p class="work-summary">{w.summary}</p>
                <dl class="work-meta">
                  {w.tools && <div><dt>使用ツール</dt><dd>{w.tools.join(" / ")}</dd></div>}
                  {w.duration && <div><dt>制作時間</dt><dd>{w.duration}</dd></div>}
                </dl>
                {w.link && <a class="btn btn--ghost" href={w.link} target={w.link.startsWith("http") ? "_blank" : undefined} rel={w.link.startsWith("http") ? "noopener noreferrer" : undefined}>サイトを見る →</a>}
              </div>
            </article>
          );})}
        </div>
      </div>
    </section>
  ))}

  <WorkModal />
  <Lightbox />

  <script>
    // 分野フィルタ：チップで作品セクションを絞り込み、表示数カウンタと URL(?d=) を同期する。
    (() => {
      const filter = document.querySelector(".wk-filter");
      if (!filter) return;
      const chips = Array.from(filter.querySelectorAll<HTMLButtonElement>(".chip"));
      const sections = Array.from(document.querySelectorAll<HTMLElement>(".cat-section[data-cat]"));
      const shown = document.getElementById("wkShown");
      const cats = sections.map((s) => s.dataset.cat as string);
      const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
      const active = new Set<string>(); // 空＝すべて表示

      function apply() {
        const all = active.size === 0;
        let count = 0;
        sections.forEach((s) => {
          const on = all || active.has(s.dataset.cat as string);
          s.hidden = !on;
          if (on) count += Number(s.dataset.count || 0);
        });
        chips.forEach((c) => {
          const on = c.dataset.cat === "all" ? all : active.has(c.dataset.cat as string);
          c.classList.toggle("is-active", on);
          c.setAttribute("aria-pressed", String(on));
        });
        if (shown) shown.textContent = String(count);
        const params = new URLSearchParams(location.search);
        if (all) params.delete("d");
        else params.set("d", [...active].join(","));
        const qs = params.toString();
        history.replaceState(null, "", location.pathname + (qs ? "?" + qs : "") + location.hash);
      }

      chips.forEach((c) =>
        c.addEventListener("click", () => {
          const cat = c.dataset.cat as string;
          if (cat === "all") active.clear();
          else if (active.has(cat)) active.delete(cat);
          else active.add(cat);
          apply();
        })
      );

      // 初期状態：?d=cg,web か #cat-web で事前フィルタ（トップの「6領域」リンクから来たとき等）
      const d = new URLSearchParams(location.search).get("d");
      if (d) d.split(",").filter((x) => cats.includes(x)).forEach((x) => active.add(x));
      else if (location.hash.startsWith("#cat-") && cats.includes(location.hash.slice(5))) active.add(location.hash.slice(5));
      apply();

      // #cat-xxx（分野）でも #slug（個別作品）でも、対象へスムーズにスクロール
      if (location.hash) {
        const el = document.getElementById(location.hash.slice(1));
        if (el) requestAnimationFrame(() => el.scrollIntoView({ behavior: reduce ? "auto" : "smooth", block: "start" }));
      }
    })();
  </script>

  <style>
    .works-hero { position: relative; padding-top: calc(78px + var(--space-5)); padding-bottom: var(--space-4); overflow: hidden; }
    .hero-glow { position: absolute; inset: 0; z-index: -1; background: radial-gradient(45% 50% at 80% 0%, color-mix(in srgb, var(--c-violet) 28%, transparent), transparent 70%); filter: blur(8px); }
    .mega { font-size: var(--fs-hero); font-weight: 700; line-height: 0.95; margin: 0.4rem 0 1.2rem; }
    .lead { max-width: 56ch; color: var(--fg-soft); }
    /* 分野フィルタ（チップ）＋表示数カウンタ */
    .wk-filter { display: flex; flex-wrap: wrap; gap: 0.55rem; margin-top: var(--space-3); }
    .chip { display: inline-flex; align-items: center; gap: 0.5rem; font-size: var(--fs-small); font-weight: 700; padding: 0.55rem 1.05rem; border-radius: 999px; border: 1px solid var(--line); color: var(--fg-soft); background: transparent; cursor: pointer; transition: color 0.25s var(--ease), border-color 0.25s var(--ease), background 0.25s var(--ease), transform 0.25s var(--ease); }
    .chip .d { width: 9px; height: 9px; border-radius: 50%; background: var(--c, var(--fg)); transition: transform 0.25s var(--ease); }
    .chip small { color: var(--muted); font-weight: 700; }
    .chip:hover { border-color: var(--c, var(--accent-ink)); color: var(--fg); transform: translateY(-2px); }
    .chip:hover .d { transform: scale(1.35); }
    .chip:focus-visible { outline: 3px solid var(--accent-ink); outline-offset: 2px; }
    /* 選択中：その分野色で塗りつぶし（文字は暗色で可読） */
    .chip.is-active { color: #06060a; background: var(--c, var(--fg)); border-color: transparent; }
    .chip.is-active small { color: rgba(6, 6, 10, 0.55); }
    .chip.is-active .d { background: #06060a; }
    /* 「すべて」選択中はスペクトラム＝全分野 */
    .chip--all.is-active { background: var(--spectrum); background-size: 160% auto; color: #06060a; animation: hue 8s linear infinite; text-shadow: 0 1px 2px rgba(255,255,255,0.35); }
    .chip--all.is-active small { color: rgba(6, 6, 10, 0.6); }
    @media (prefers-reduced-motion: reduce) { .chip--all.is-active { animation: none; } }

    .wk-count { margin-top: 1rem; font-family: var(--font-display); font-size: 0.84rem; color: var(--muted); letter-spacing: 0.03em; display: flex; align-items: baseline; gap: 0.45rem; }
    .wk-count b { color: var(--fg); font-size: 1.1rem; font-variant-numeric: tabular-nums; }

    .cat-section { padding-block: var(--space-5); border-top: 1px solid var(--line); }
    .cat-section[hidden] { display: none; }
    .cat-head { display: flex; align-items: center; gap: 1.2rem; margin-bottom: var(--space-4); }
    .cat-no { font-size: clamp(2.5rem, 7vw, 5rem); font-weight: 700; line-height: 1; opacity: 0.9; color: var(--c); }
    .cat-eyebrow { color: var(--c); }
    .cat-head h2 { font-size: var(--fs-h2); word-break: keep-all; }
    /* ライトテーマ：淡い分野色（黄・シアン等）が淡い背景に埋もれないよう、色相は保ちつつ暗めに寄せて可読性を確保 */
    :root[data-theme="light"] .cat-no,
    :root[data-theme="light"] .cat-eyebrow,
    :root[data-theme="light"] .work-no { color: color-mix(in srgb, var(--c) 70%, #14131b); }

    .work-list { display: grid; gap: var(--space-5); }
    .work-row { display: grid; gap: 1rem 2rem; grid-template-columns: 1fr; align-items: start; scroll-margin-top: 96px; position: relative; }
    @media (min-width: 880px) {
      .work-row { grid-template-columns: 1.12fr 0.88fr; align-items: center; gap: 3rem; }
      /* 交互配置：偶数行はメディアを右へ（映画的な編集リズム） */
      .work-row:nth-child(even) .work-media { order: 2; }
      .work-row:nth-child(even) .work-info { order: 1; }
    }
    /* 分野内の通し番号（小さく・分野色）＝ランク順の目印。大きなセクション番号と役割を分ける */
    .work-no { font-family: var(--font-display); font-weight: 700; font-size: 0.84rem; letter-spacing: 0.05em; color: var(--c, var(--accent-ink)); font-variant-numeric: tabular-nums; }

    .work-media { position: relative; border-radius: var(--radius); overflow: hidden; background: var(--bg-3); aspect-ratio: 4/3; border: 1px solid var(--line); display: grid; place-items: center; }
    /* グラフィック作品（縦長ポスター）はメディア枠を縦長にして全体を大きく見せる */
    .work-media.is-poster { aspect-ratio: 4/5; max-width: 460px; justify-self: center; width: 100%; }
    /* 縦長画像も見切れないよう、ぼかした同画像を背景に敷き本体は全体表示 */
    .work-media::before { content: ""; position: absolute; inset: -8%; background-image: var(--mbg); background-size: cover; background-position: center; filter: blur(26px) brightness(0.5) saturate(1.3); z-index: 0; }
    .work-media img, .work-media video { position: relative; z-index: 1; width: 100%; height: 100%; object-fit: contain; transition: transform 0.7s var(--ease); }
    .work-row:hover .work-media img { transform: scale(1.04); }
    /* 準備中（サムネ未配置）は、分野色の点線カードで“意図された枠”に見せる */
    .work-media.is-empty { border-style: dashed; border-color: color-mix(in srgb, var(--c) 38%, var(--line)); background: linear-gradient(150deg, color-mix(in srgb, var(--c) 9%, var(--bg-3)), var(--bg-3) 72%); }
    .media-ph { position: relative; z-index: 1; display: inline-flex; flex-direction: column; align-items: center; gap: 0.6rem; color: var(--fg-soft); font-size: var(--fs-small); font-weight: 700; letter-spacing: 0.04em; }
    .media-ph::before { content: ""; width: 30px; height: 30px; border-radius: 50%; border: 2px dashed var(--c); opacity: 0.75; }
    .work-media.is-zoom { cursor: zoom-in; }
    .work-media.is-zoom:focus-visible { outline: 3px solid var(--accent-ink); outline-offset: 3px; }
    .zoom-hint { position: absolute; z-index: 2; bottom: 0.7rem; right: 0.7rem; font-family: var(--font-display); font-size: 0.72rem; font-weight: 600; letter-spacing: 0.02em; color: #fff; background: rgba(0,0,0,0.55); border: 1px solid rgba(255,255,255,0.2); padding: 0.32rem 0.7rem; border-radius: 999px; opacity: 0; transform: translateY(6px); transition: opacity 0.3s var(--ease), transform 0.3s var(--ease); backdrop-filter: blur(4px); pointer-events: none; }
    .work-media.is-zoom:hover .zoom-hint, .work-media.is-zoom:focus-visible .zoom-hint { opacity: 1; transform: none; }
    /* タッチ端末はホバーが無いので、操作のヒントを常時うっすら表示（発見性UP） */
    @media (hover: none) { .zoom-hint { opacity: 0.92; transform: none; } }
    .work-media.noimg::after { content: "画像準備中"; color: var(--muted); font-size: var(--fs-small); }
    .work-media.noimg img { display: none; }

    .tags-row { display: inline-flex; gap: 0.7rem; align-items: center; margin-bottom: 0.8rem; flex-wrap: wrap; }
    .status-pill { display: inline-block; font-size: 0.68rem; font-weight: 700; padding: 0.28rem 0.7rem; border-radius: 999px; color: var(--fg); border: 1.5px solid var(--line); background: var(--bg-3); }
    .work-info h3 { font-size: clamp(1.5rem, 3vw, 2.3rem); margin-bottom: 0.7rem; word-break: keep-all; overflow-wrap: anywhere; }
    .work-summary { color: var(--fg); margin-bottom: 1rem; }

    .work-meta { display: flex; gap: 2rem; margin: 1rem 0 0.5rem; flex-wrap: wrap; }
    .work-meta dt { font-family: var(--font-display); font-size: 0.68rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); }
    .work-meta dd { font-weight: 700; font-size: var(--fs-small); }
  </style>
</Base>
