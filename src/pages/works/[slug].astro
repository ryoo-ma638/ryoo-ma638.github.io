---
// 作品の個別詳細ページ（/works/<slug>）。
// 一覧の没入モーダルと同じ内容を、共有・検索・ブラウザ戻るが効く独立URLとして提供する。
// ※モーダル（WorkModal.astro）は一覧側に残置。ここはその静的ページ版。
import Base from "../../layouts/Base.astro";
import Lightbox from "../../components/Lightbox.astro";
import { works, categoryLabels, type Category } from "../../data/works.ts";

export function getStaticPaths() {
  return works.map((w) => ({ params: { slug: w.slug } }));
}

const { slug } = Astro.params;
const work = works.find((w) => w.slug === slug)!;
const cat = categoryLabels[work.category];

// 前後の作品は「一覧（works/index.astro）と同じ表示順」で決める。
// ※並び順を変えるときは works/index.astro の rankOrder と両方そろえること。
const order: Category[] = ["web", "imaging", "cg", "video", "planning", "graphic", "sound"];
const rankOrder: string[] = [
  "drone-note", "meegri", "yumiki-world", "settlo", "nogi-photo", "chuo-seisakusho", "uriko-site", "portfolio-vol2", "ceed-site", "toka-club",
  "deathcamer", "kamakama-quest", "shuwa-game", "wis-umbrella", "fukuoka-award",
  "shibuya-crossing", "strikeout", "robot-argus", "jojo-scene", "live-stage",
  "mm2-cinematography", "manga-jitsuei",
  "presentation-slides", "mushiba-animals", "todofuken-battle",
  "color-poster", "business-card", "character-design",
  "sound-arrange",
];
const rankOf = (s: string) => { const i = rankOrder.indexOf(s); return i < 0 ? 999 : i; };
const flat = order.flatMap((c) => works.filter((w) => w.category === c).sort((a, b) => rankOf(a.slug) - rankOf(b.slug)));
const idx = flat.findIndex((w) => w.slug === slug);
const prev = flat[(idx - 1 + flat.length) % flat.length];
const next = flat[(idx + 1) % flat.length];

const externalLink = work.link?.startsWith("http");
const lbList = work.gallery && work.gallery.length ? work.gallery : (work.thumb ? [work.thumb] : []);
---

<Base title={`${work.title} — Osaki Ryoma`} description={work.summary}>
  <article class="wd container" data-accent={cat.color} style={`--c:${cat.color}`}>
    <!-- パンくず -->
    <p class="wd-crumb reveal">
      <a href={`/works#cat-${work.category}`}>← Works 一覧</a>
      <span class="wd-tag">{cat.ja}</span>
      {work.status && <span class="wd-status">{work.status}</span>}
    </p>

    <!-- ヒーロー（メディア｜情報） -->
    <div class="wd-head">
      <div
        class="wd-media reveal"
        data-gallery={JSON.stringify(lbList)}
        data-caption={work.title}
        style={work.thumb ? `--mbg:url(${work.thumb})` : undefined}
      >
        {work.video
          ? <video src={work.video} poster={work.thumb} autoplay muted loop playsinline preload="none"></video>
          : work.thumb
            ? <img src={work.thumb} alt={work.title} />
            : <span class="wd-noimg">画像準備中</span>}
        <span class="wd-bar" aria-hidden="true"></span>
        {(work.video || work.thumb) && <span class="wd-zoom" aria-hidden="true">クリックで拡大 ↗</span>}
      </div>

      <div class="wd-info reveal" data-delay="1">
        <h1 class="display">{work.title}</h1>
        <p class="wd-sum">{work.summary}</p>

        {work.goal && <div class="wd-kv"><span>狙い</span><p>{work.goal}</p></div>}
        {work.approach && <div class="wd-kv"><span>工夫</span><p>{work.approach}</p></div>}

        <dl class="wd-meta">
          {work.tools && <div><dt>使用ツール</dt><dd>{work.tools.join(" / ")}</dd></div>}
          {work.duration && <div><dt>制作時間</dt><dd>{work.duration}</dd></div>}
        </dl>

        {work.links && work.links.length > 0 && (
          <div class="wd-press">
            <span class="wd-press-label">📰 掲載メディア</span>
            {work.links.map((l) => (
              <a class="wd-press-link" href={l.href} target="_blank" rel="noopener noreferrer">{l.label} <span aria-hidden="true">↗</span></a>
            ))}
          </div>
        )}

        {work.link && (
          externalLink
            ? <a class="btn btn--primary" href={work.link} target="_blank" rel="noopener noreferrer">サイトを見る →</a>
            : <a class="btn btn--primary" href={work.link}>サイトを見る →</a>
        )}
      </div>
    </div>

    <!-- 2本目の動画（現在のPC版プレイ） -->
    {work.video2 && (
      <section class="wd-sec reveal">
        <p class="eyebrow wd-eyebrow">Gameplay</p>
        <h2 class="wd-h2">通しプレイ・ハイライト <span class="mut">（早送り）</span></h2>
        <div class="wd-v2">
          <video src={work.video2} autoplay muted loop playsinline preload="none"></video>
        </div>
      </section>
    )}

    <!-- ステージ別プレイ（3カラム） -->
    {work.stageVideos && work.stageVideos.length > 0 && (
      <section class="wd-sec reveal">
        <p class="eyebrow wd-eyebrow">Stages</p>
        <h2 class="wd-h2">ステージ別プレイ <span class="mut">（WAVE1・WAVE2・ボス）</span></h2>
        <div class="wd-stages">
          {work.stageVideos.map((sv) => (
            <figure class="wd-stage">
              <video src={sv.src} autoplay muted loop playsinline preload="none"></video>
              <figcaption>{sv.label}</figcaption>
            </figure>
          ))}
        </div>
      </section>
    )}

    <!-- ギャラリー -->
    {work.gallery && work.gallery.length > 0 && (
      <section class="wd-sec reveal">
        <p class="eyebrow wd-eyebrow">Gallery</p>
        <h2 class="wd-h2">関連画像 <span class="mut">（クリックで拡大）</span></h2>
        <div class="wd-gal">
          {work.gallery.map((g, gi) => (
            <img src={g} alt={`${work.title} スクリーンショット ${gi + 1}`} loading="lazy"
              data-gallery={JSON.stringify(work.gallery)} data-index={gi} data-caption={work.title} />
          ))}
        </div>
      </section>
    )}

    <!-- スライド（種類ごと・横スクロール） -->
    {work.slideGroups?.map((sg) => (
      <section class="wd-sec reveal">
        <p class="eyebrow wd-eyebrow">Slides</p>
        <h2 class="wd-h2">{sg.title} {sg.images.length > 1 && <span class="mut">（{sg.images.length}枚・横スクロール →）</span>}</h2>
        <div class="wd-strip">
          {sg.images.map((s, si) => (
            <img class="wd-slide" src={s} alt={`${sg.title} ${si + 1}`} loading="lazy"
              data-gallery={JSON.stringify(sg.images)} data-index={si} data-caption={sg.title} />
          ))}
        </div>
      </section>
    ))}

    <!-- 音源 -->
    {work.audio && work.audio.length > 0 && (
      <section class="wd-sec reveal">
        <p class="eyebrow wd-eyebrow">Sound</p>
        <h2 class="wd-h2">試聴</h2>
        <div class="wd-tracks">
          {work.audio.map((a) => (
            <div class="wd-track">
              <div class="wd-track-head">
                <span class="wd-track-ic" aria-hidden="true">♪</span>
                <span class="wd-track-title">{a.title}</span>
                {a.note && <span class="wd-track-note">{a.note}</span>}
              </div>
              <audio controls preload="none" src={a.src}></audio>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- 前後の作品 -->
    <nav class="wd-pn reveal" aria-label="前後の作品">
      <a class="wd-pn-card" href={`/works/${prev.slug}`}>
        <span class="wd-pn-dir">← 前の作品</span>
        {prev.thumb && <img src={prev.thumb} alt="" loading="lazy" />}
        <span class="wd-pn-title">{prev.title}</span>
      </a>
      <a class="wd-pn-all" href="/works">一覧<br />へ</a>
      <a class="wd-pn-card next" href={`/works/${next.slug}`}>
        <span class="wd-pn-dir">次の作品 →</span>
        {next.thumb && <img src={next.thumb} alt="" loading="lazy" />}
        <span class="wd-pn-title">{next.title}</span>
      </a>
    </nav>

    <!-- CTA -->
    <div class="wd-cta reveal">
      <p class="wd-cta-lead">この作品について、もっと話せます。</p>
      <a class="btn btn--primary" href="/contact">お問い合わせ →</a>
    </div>
  </article>

  <Lightbox />
</Base>

<style>
  .wd { padding-block: clamp(1.4rem, 4vw, 3rem) var(--space-6); }

  /* パンくず */
  .wd-crumb { display: flex; align-items: center; gap: 0.7rem; flex-wrap: wrap; margin-bottom: clamp(1.2rem, 3vw, 2rem); }
  .wd-crumb a { font-weight: 700; color: var(--fg-soft); border-bottom: 2px solid transparent; padding-bottom: 1px; transition: color 0.25s var(--ease), border-color 0.25s var(--ease); }
  .wd-crumb a:hover { color: var(--fg); border-color: var(--c); }
  .wd-tag { font-size: 0.7rem; font-weight: 700; padding: 0.32rem 0.8rem; border-radius: 999px; color: #06060a; background: var(--c, #fff); }
  .wd-status { font-size: 0.7rem; font-weight: 700; padding: 0.3rem 0.8rem; border-radius: 999px; color: var(--fg); border: 1.5px solid var(--line); }

  /* ヒーロー */
  .wd-head { display: grid; grid-template-columns: 1.15fr 0.85fr; gap: clamp(1.3rem, 3.5vw, 2.6rem); align-items: start; }

  .wd-media { position: relative; border-radius: var(--radius); overflow: hidden; border: 1px solid var(--line);
    background: var(--bg-3); display: grid; place-items: center; min-height: clamp(240px, 40vh, 420px); cursor: zoom-in; }
  /* 縦長・横長どちらでも見切れないよう、ぼかした本体を背面に敷いて中央に全体表示 */
  .wd-media::before { content: ""; position: absolute; inset: 0; background: var(--mbg) center / cover no-repeat;
    filter: blur(38px) saturate(1.35) brightness(0.5); transform: scale(1.25); opacity: 0.5; }
  .wd-media img, .wd-media video { position: relative; z-index: 1; max-width: 100%; max-height: min(72vh, 580px);
    width: auto; height: auto; object-fit: contain; display: block; }
  .wd-media .wd-noimg { position: relative; z-index: 1; color: var(--muted); font-size: var(--fs-small); font-weight: 700; }
  .wd-bar { position: absolute; top: 0; left: 0; right: 0; height: 4px; z-index: 2; background: var(--c); }
  .wd-zoom { position: absolute; right: 0.7rem; bottom: 0.7rem; z-index: 2; font-family: var(--font-display); font-size: 0.66rem; font-weight: 700;
    letter-spacing: 0.04em; color: var(--fg); background: color-mix(in srgb, #05050a 62%, transparent); border: 1px solid var(--line);
    padding: 0.3rem 0.6rem; border-radius: 999px; opacity: 0; transition: opacity 0.25s var(--ease); }
  .wd-media:hover .wd-zoom { opacity: 1; }

  /* 2本目の動画（Gameplay） */
  .wd-v2 { border-radius: var(--radius); overflow: hidden; border: 1px solid var(--line); background: var(--bg-3); display: grid; place-items: center; }
  .wd-v2 video { width: 100%; height: auto; max-height: min(72vh, 580px); object-fit: contain; display: block; }

  /* ステージ別プレイ（3カラム） */
  .wd-stages { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(0.6rem, 1.5vw, 1rem); }
  .wd-stage { border-radius: var(--radius); overflow: hidden; border: 1px solid var(--line); background: var(--bg-3); }
  .wd-stage video { width: 100%; aspect-ratio: 16 / 10; object-fit: cover; display: block; }
  .wd-stage figcaption { padding: 0.5rem 0.6rem; font-size: 0.78rem; font-weight: 700; color: var(--fg-soft); }
  @media (max-width: 640px) { .wd-stages { grid-template-columns: 1fr; } }

  .wd-info h1 { font-size: clamp(1.7rem, 4vw, 2.9rem); line-height: 1.12; margin-bottom: 0.9rem; }
  .wd-sum { color: var(--fg); font-size: 1.02rem; line-height: 1.85; margin-bottom: 1.4rem; }

  .wd-kv { display: grid; grid-template-columns: 3.6rem 1fr; gap: 0.75rem; margin-bottom: 0.85rem; color: var(--fg-soft); line-height: 1.8; }
  .wd-kv span { font-weight: 700; color: var(--fg); font-size: var(--fs-small); }
  .wd-kv p { font-size: 0.94rem; }

  .wd-meta { display: flex; gap: 2rem; margin: 1.3rem 0; flex-wrap: wrap; }
  .wd-meta div { display: grid; gap: 0.25rem; }
  .wd-meta dt { font-family: var(--font-display); font-size: 0.64rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); }
  .wd-meta dd { font-weight: 700; font-size: var(--fs-small); }

  .wd-press { display: flex; flex-wrap: wrap; align-items: center; gap: 0.5rem; margin: 0.4rem 0 1.4rem; }
  .wd-press-label { font-size: 0.78rem; font-weight: 700; color: var(--fg-soft); }
  .wd-press-link { font-size: 0.8rem; font-weight: 700; color: var(--accent-ink); border: 1px solid var(--line); border-radius: 999px;
    padding: 0.34rem 0.85rem; transition: border-color 0.25s var(--ease), transform 0.25s var(--ease); }
  .wd-press-link:hover { border-color: var(--accent-ink); transform: translateY(-2px); }

  /* セクション（ギャラリー・スライド・音源） */
  .wd-sec { margin-top: clamp(2.2rem, 5vw, 3.4rem); }
  .wd-eyebrow { color: var(--c); margin-bottom: 0.4rem; }
  .wd-h2 { font-size: var(--fs-h2); margin-bottom: 1.1rem; }
  .wd-h2 .mut { font-size: 0.7em; color: var(--muted); font-weight: 500; }

  .wd-gal { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 0.9rem; }
  .wd-gal img { width: 100%; aspect-ratio: 16 / 10; object-fit: contain; background: var(--bg-3); border: 1px solid var(--line);
    border-radius: 12px; cursor: zoom-in; transition: transform 0.25s var(--ease), border-color 0.25s var(--ease); }
  .wd-gal img:hover { transform: translateY(-4px); border-color: var(--c); }

  .wd-strip { display: flex; gap: 0.8rem; overflow-x: auto; scroll-snap-type: x mandatory; padding-bottom: 0.7rem; scrollbar-width: thin; -webkit-overflow-scrolling: touch; }
  .wd-strip::-webkit-scrollbar { height: 7px; }
  .wd-strip::-webkit-scrollbar-thumb { background: var(--line); border-radius: 999px; }
  .wd-slide { flex: 0 0 auto; width: clamp(260px, 74vw, 440px); aspect-ratio: 16 / 10; object-fit: contain; background: #eef0f4;
    border: 1px solid var(--line); border-radius: 12px; cursor: zoom-in; scroll-snap-align: start; transition: border-color 0.25s var(--ease); }
  .wd-slide:hover { border-color: var(--c); }

  .wd-tracks { display: grid; gap: 0.8rem; }
  .wd-track { background: var(--bg-3); border: 1px solid var(--line); border-radius: 12px; padding: 0.8rem 0.95rem; }
  .wd-track-head { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem; flex-wrap: wrap; }
  .wd-track-ic { color: var(--c-violet); font-size: 1.1rem; line-height: 1; }
  .wd-track-title { font-weight: 700; font-size: 0.98rem; }
  .wd-track-note { font-size: 0.74rem; color: var(--muted); }
  .wd-track audio { width: 100%; height: 38px; display: block; }

  /* 前後の作品 */
  .wd-pn { display: grid; grid-template-columns: 1fr auto 1fr; gap: 1rem; align-items: stretch; margin-top: clamp(2.6rem, 5.5vw, 4rem); }
  .wd-pn-card { display: grid; grid-template-columns: 88px 1fr; grid-template-rows: auto auto; gap: 0.15rem 0.85rem; align-items: center;
    background: var(--bg-2); border: 1px solid var(--line); border-radius: var(--radius); padding: 0.75rem 0.95rem;
    transition: transform 0.25s var(--ease), border-color 0.25s var(--ease); }
  .wd-pn-card:hover { transform: translateY(-4px); border-color: var(--c); }
  .wd-pn-card img { grid-row: 1 / span 2; width: 88px; aspect-ratio: 16 / 10; object-fit: cover; border-radius: 8px; }
  .wd-pn-dir { font-family: var(--font-display); font-size: 0.62rem; font-weight: 700; letter-spacing: 0.05em; color: var(--muted); }
  .wd-pn-title { font-weight: 700; font-size: 0.85rem; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .wd-pn-card.next { text-align: right; grid-template-columns: 1fr 88px; }
  .wd-pn-card.next img { grid-column: 2; }
  .wd-pn-card.next .wd-pn-dir, .wd-pn-card.next .wd-pn-title { grid-column: 1; }
  .wd-pn-all { align-self: center; text-align: center; font-family: var(--font-display); font-weight: 700; font-size: 0.78rem; line-height: 1.25;
    width: 76px; height: 76px; display: grid; place-items: center; border-radius: 50%; color: #06060a; background: var(--fg);
    transition: transform 0.25s var(--ease); }
  .wd-pn-all:hover { transform: translateY(-3px) rotate(-4deg); }

  /* CTA */
  .wd-cta { display: flex; flex-direction: column; align-items: center; gap: 0.9rem; text-align: center; margin-top: clamp(2.6rem, 5.5vw, 4rem); }
  .wd-cta-lead { font-family: var(--font-display); font-size: clamp(1.1rem, 2.4vw, 1.5rem); font-weight: 700; }

  @media (max-width: 820px) {
    .wd-head { grid-template-columns: 1fr; }
    .wd-pn { grid-template-columns: 1fr; }
    .wd-pn-all { justify-self: center; order: -1; }
    .wd-pn-card.next { text-align: left; grid-template-columns: 88px 1fr; }
    .wd-pn-card.next img { grid-column: 1; grid-row: 1 / span 2; }
    .wd-pn-card.next .wd-pn-dir, .wd-pn-card.next .wd-pn-title { grid-column: 2; }
  }
</style>
