---
import Yumiki from "../../layouts/Yumiki.astro";
import { charms, charmVideos, img } from "../../data/yumiki.ts";
// 著作権配慮：魅力ページで残せる写真（京都市CM＝bg-world／まとめ＝bg-summary）だけ表示。番組切り抜き（会話力/努力家）は非掲載。
const safeBg = new Set(["bg-world.jpg", "bg-summary.jpg"]);
// 最後の1つ（まとめ）は特別な締めカードとして別扱い
const features = charms.slice(0, -1);
const summary = charms[charms.length - 1];
const accents = ["var(--y-peach)", "var(--y-sky)", "var(--y-mint)"];
const tapes = ["var(--y-butter)", "var(--y-pink)", "var(--y-lav)"];
// 各魅力ページ（ノート1ページ）の手書きツッコミ（本文の事実に沿った一言のみ）
const notes = [
  "“はんなりすっとこどっこい”が原点。",
  "生放送でも自分のペース。",
  "頼れる姉さん、でも陰で努力家。",
];
// 動画1本目=フィーチャー、残り=チェキ風
const featureVideo = charmVideos[0];
const restVideos = charmVideos.slice(1);
// 締めの寄せ書き付箋（色だけ割り当て・文章はdataのまま）
const sumColors = ["var(--y-peach)", "var(--y-sky)", "var(--y-mint)", "var(--y-lav)"];
const sumTilts = ["-2.2deg", "1.6deg", "-1.4deg", "2deg"];

// 名場面クリップ（本人提供動画・public/assets/yumiki/video/）。概要は実映像とテロップで確認した事実ベース。
const funClips = [
  { f: "donene", title: "伝説の即興曲「ドンエネ」", desc: "ラジオ『沈黙の金曜日』から生まれた即興英語ソング「ドンストップエナジー（ドンエネ）」。アドリブ力が爆発した、ファンの間で語り継がれる名場面。" },
  { f: "lavit-dance", title: "『ラヴィット！』料理中にダンス", desc: "得意料理「弓木家の高野豆腐入り煮込みハンバーグ」を作る料理コーナーで、調理の途中に思わず『おひとりさま天国』を踊り出してしまった天真爛漫な一幕。" },
  { f: "kaidan", title: "『乃木坂工事中』怪談話", desc: "「悩んでひねり出した“B級特技”発表会」で披露した、ひとり語りの怪談話（「ラグビー部が夏休みに合宿を始めました…」）。人を惹きつける話術が光る一席。" },
  { f: "mste-cheatday", title: "Mステで『チートデイ』", desc: "ミュージックステーション出演時の一場面。36thシングル『チートデイ』を披露し、タモリさんとのトークでは“香港の空港でファンが出待ち”という海外人気のエピソードも飛び出した。" },
  { f: "sumo-kanagawa", title: "『乃木坂工事中』相撲対決（金川紗耶）", desc: "「些細な因縁を相撲で解決！」企画で、親友の金川紗耶さんと相撲で対決。“おバカキャラ同士”の二人のガチンコ勝負。" },
  { f: "lavit-cookie", title: "『ラヴィット！』ヘッドホン伝言ゲーム", desc: "大音量で何も聞こえない状態でお題を伝える「ヘッドホンガンガン伝言ゲーム」。お題『くっきーゆみっきー超ハッピー』に、失敗するとビリビリ電流が走る中で奮闘。" },
  { f: "lavit-tsumasaki", title: "『ラヴィット！』ワードスナイパー", desc: "瞬時にお題に合う言葉を出す「ワードスナイパー対決」。お題に対する弓木さんの自由すぎる回答（“つま先”）が、スタジオを和ませた。" },
  { f: "lavit-sugawara", title: "『ラヴィット！』相方褒め合い（菅原咲月）", desc: "「照れたらアウト！相方褒め合い選手権」に、乃木坂46の後輩・菅原咲月さんとペアで挑戦。お互いを褒め合い、照れをこらえる二人が微笑ましい。" },
  { f: "lavit-ota-hammer", title: "『ラヴィット！』ピコピコハンマー対決", desc: "“叩いて被ってジャンケンポン”が進化したダブルピコピコハンマーのゲームで、ジャングルポケット太田さんらと白熱のバトルを繰り広げた。" },
  { f: "lavit-ota-yabai", title: "『ラヴィット！』「マジでやばいから」", desc: "ジャングルポケット太田さん考案のオリジナルゲーム（ロマンチックにお題の言葉を言う）で、立ち上がって大絶叫。「マジでやばいから」と大ウケした場面。" },
];
const clipTapes = ["var(--y-pink)", "var(--y-mint)", "var(--y-sky)", "var(--y-butter)", "var(--y-lav)", "var(--y-peach)"];

// 番組切り抜き写真を載せない魅力ポイント（会話力／努力家）は、写真の代わりに“ノートの挿絵パネル”で埋める。
const charmDeco: Record<string, { icon: string; sub: string; doodles: string[] }> = {
  "会話力": { icon: "🗣️", sub: "TALK MAGIC", doodles: ["♪", "❝", "✦"] },
  "努力家": { icon: "🌱", sub: "QUIET EFFORT", doodles: ["✎", "♡", "✦"] },
};
// 名場面カードに添える大きな絵文字シール（テロップ・企画名から内容に合うものを割当）。
const clipIcon: Record<string, string> = {
  donene: "🎤", "lavit-dance": "🍳", kaidan: "👻", "mste-cheatday": "🎸",
  "sumo-kanagawa": "🤼", "lavit-cookie": "🎧", "lavit-tsumasaki": "🎯",
  "lavit-sugawara": "💕", "lavit-ota-hammer": "🔨", "lavit-ota-yabai": "📣",
};
// 検証済みの公式/本人提供リンクがある名場面だけリンクを付ける（未検証リンクは付けない＝誤情報防止）。
const clipLink: Record<string, { href: string; label: string }> = {
  donene: { href: "https://www.instagram.com/reel/DJRKfD9TgSm/", label: "▶ ドンエネを見る" },
  // 公式「乃木坂配信中」乃木坂工事中#455「B級特技発表会 前編」。怪談は16:17(=977秒)から。
  kaidan: { href: "https://youtu.be/A2fK3kZ6GQo?t=977", label: "▶ 怪談を見る（16:17〜・公式）" },
};
---
<Yumiki title="魅力 — YUMIKI WORLD">
  <section class="y-section cm-sec sb-grid">
    <div class="y-container">
      <!-- 表紙＝推しノートの見開き（中央テンプレを崩した手貼りタイトル） -->
      <div class="cm-cover y-reveal">
        <span class="sb-doodle cm-cover-doodle" style="--cc:var(--y-pink)" aria-hidden="true">♡</span>
        <span class="sb-stamp cm-cover-stamp" style="--cc:var(--y-peach)" aria-hidden="true">★ Her Charm</span>
        <h1 class="cm-cover-tt">弓木奈於の<span class="sb-mark" style="--cc:var(--y-butter)">魅力</span>、語らせて。</h1>
        <p class="cm-intro sb-note">知れば知るほど好きになる。彼女の“ずるい”魅力を、ファン目線でめいっぱい。</p>
      </div>

      <div class="cm-list">
        {features.map((c, i) => {
          const lead = c.body[0];
          const rest = c.body.slice(1);
          return (
            <article class={`cm-page y-reveal sb-ruled ${i % 2 ? "cm-page--rev" : ""}`} style={`--cc:${accents[i % 3]};--tape:${tapes[i % 3]}`}>
              <span class="sb-doodle cm-page-doodle" style={`--cc:${accents[i % 3]}`} aria-hidden="true">{["♡", "✦", "✿"][i % 3]}</span>

              {/* 章見出し：左寄せ＋大きな通し番号でテンプレの単調反復を崩す */}
              <header class="sb-head cm-page-head">
                <span class="sb-num sb-head-num" aria-hidden="true">0{i + 1}</span>
                <span class="sb-head-tt">
                  <span class="sb-head-eyebrow">Point 0{i + 1}</span>
                  <h2>{c.title}</h2>
                </span>
              </header>

              <div class="cm-page-body">
                {safeBg.has(c.img) ? (
                  <figure class="sb-cheki sb-taped cm-page-cheki">
                    <span class="sb-tape l" aria-hidden="true"></span>
                    <span class="sb-tape r" aria-hidden="true"></span>
                    <div class="cm-cheki-img">
                      <img src={img(c.img)} alt={c.title} loading="lazy" />
                    </div>
                    <figcaption><span aria-hidden="true">♡</span> {c.tag}</figcaption>
                  </figure>
                ) : (
                  <figure class="cm-deco sb-taped" style={`--cc:${accents[i % 3]}`} aria-hidden="true">
                    <span class="sb-tape l" aria-hidden="true"></span>
                    <span class="sb-tape r" aria-hidden="true"></span>
                    <span class="cm-deco-emoji sb-decal sb-jiggle">{charmDeco[c.tag]?.icon ?? "♡"}</span>
                    <span class="sb-stamp cm-deco-stamp" style={`--cc:${accents[i % 3]}`}>♡ {c.tag}</span>
                    <span class="cm-deco-sub">{charmDeco[c.tag]?.sub ?? "YUMIKI"}</span>
                    {(charmDeco[c.tag]?.doodles ?? []).map((d, di) => (
                      <span class={`sb-doodle cm-deco-d cm-deco-d--${di + 1}`} style={`--cc:${tapes[i % 3]}`}>{d}</span>
                    ))}
                  </figure>
                )}
                {/* 本文（番組由来の写真は非掲載・公式/CM/ブログのみ掲載） */}
                <div class="cm-page-text">
                  <p class="cm-lead"><span class="cm-q" aria-hidden="true">❝</span>{lead}</p>
                  {rest.map((p) => <p class="cm-p">{p}</p>)}
                  <span class="sb-note cm-page-note">{notes[i]}</span>
                </div>
              </div>
            </article>
          );
        })}
      </div>

      <!-- 動画で知る弓木さん（すべて公式チャンネルのembed可能な動画） -->
      <section class="cm-movies y-reveal">
        <header class="sb-head cm-mv-head">
          <span class="sb-num sb-head-num" style="--cc:var(--y-sky)" aria-hidden="true">▶</span>
          <span class="sb-head-tt">
            <span class="sb-head-eyebrow">Movie ✦</span>
            <h2>動画で見る<span class="sb-mark" style="--cc:var(--y-sky)">弓木さん</span></h2>
          </span>
        </header>
        <p class="cm-mv-intro sb-note">公式チャンネルの動画で、天真爛漫な“弓木ワールド”を。サムネイルをタップすると再生します ▶</p>

        <!-- 1本目＝大きなフィーチャー（まずはこれ▶ ステッカー付き） -->
        <article class="cm-mv-feature sb-taped" data-yt={featureVideo.id} style="--cc:var(--y-peach);--tape:var(--y-pink)">
          <span class="sb-tape l" aria-hidden="true"></span>
          <span class="sb-stamp cm-mv-first" style="--cc:var(--y-peach)" aria-hidden="true">まずはこれ ▶</span>
          <button class="cm-mv-thumb cm-mv-thumb--big" type="button" aria-label={`再生：${featureVideo.title}`}>
            <img src={`https://i.ytimg.com/vi/${featureVideo.id}/hqdefault.jpg`} alt={featureVideo.title} loading="lazy" width="480" height="360" />
            <span class="cm-mv-play" aria-hidden="true">▶</span>
          </button>
          <div class="cm-mv-meta">
            <span class="cm-mv-ch">{featureVideo.channel}</span>
            <h4 class="cm-mv-title">{featureVideo.title}</h4>
            <p class="cm-mv-note">{featureVideo.note}</p>
          </div>
        </article>

        <!-- 残り＝チェキ風の非対称配置 -->
        <div class="cm-mv-grid">
          {restVideos.map((v) => (
            <article class="cm-mv-card sb-cheki" data-yt={v.id}>
              <button class="cm-mv-thumb" type="button" aria-label={`再生：${v.title}`}>
                <img src={`https://i.ytimg.com/vi/${v.id}/hqdefault.jpg`} alt={v.title} loading="lazy" width="480" height="360" />
                <span class="cm-mv-play" aria-hidden="true">▶</span>
              </button>
              <div class="cm-mv-meta">
                <span class="cm-mv-ch">{v.channel}</span>
                <h4 class="cm-mv-title">{v.title}</h4>
                <p class="cm-mv-note">{v.note}</p>
              </div>
            </article>
          ))}
        </div>
        <p class="cm-mv-foot">※ 公式チャンネルの動画を埋め込み表示しています。著作権は各権利者に帰属します。</p>
      </section>

      <!-- 名場面クリップ：ドンエネ＆怪談話（押すと再生・音あり） -->
      <section class="y-section cm-clips-sec">
        <header class="sb-head cm-clips-head y-reveal">
          <span class="sb-num sb-head-num" style="--cc:var(--y-pink)" aria-hidden="true">♪</span>
          <span class="sb-head-tt">
            <span class="sb-head-eyebrow">Best Scenes</span>
            <h2>弓木さんの<span class="sb-mark" style="--cc:var(--y-pink)">名場面</span>クリップ</h2>
          </span>
        </header>
        <p class="cm-clips-intro sb-note">バラエティ・ラジオ・ライブでの“弓木ワールド全開”な名場面を、エピソードでご紹介します。</p>
        <div class="cm-clips-grid">
          {funClips.map((c, i) => (
            <figure id={`clip-${c.f}`} class="cm-clip cm-clip--text y-reveal" data-delay={(i % 3) + 1} style={`--cc:${clipTapes[i % clipTapes.length]}; transform: rotate(${i % 2 === 0 ? -0.6 : 0.6}deg); scroll-margin-top: 90px`}>
              <span class="cm-clip-emoji sb-decal sb-jiggle" aria-hidden="true">{clipIcon[c.f] ?? "▶"}</span>
              <span class="cm-clip-badge" aria-hidden="true">▶ EPISODE</span>
              <figcaption class="cm-clip-cap">{c.title}</figcaption>
              <p class="cm-clip-desc">{c.desc}</p>
              {clipLink[c.f] && (
                <a class="cm-clip-link" href={clipLink[c.f].href} target="_blank" rel="noopener noreferrer">{clipLink[c.f].label}</a>
              )}
            </figure>
          ))}
        </div>
        <p class="cm-clips-foot sb-note">※ 番組・配信の名場面を、エピソードとして文章でご紹介しています。著作権は各権利者に帰属します。</p>
      </section>

      <!-- 締め：ファンからの“寄せ書き／色紙”（色違いの付箋を貼った風） -->
      <article class="cm-sum y-reveal sb-ruled">
        <span class="sb-doodle cm-sum-doodle cm-sum-doodle--1" style="--cc:var(--y-pink)" aria-hidden="true">♡</span>
        <span class="sb-doodle cm-sum-doodle cm-sum-doodle--2" style="--cc:var(--y-mint)" aria-hidden="true">✦</span>

        {safeBg.has(summary.img) && (
          <figure class="sb-cheki sb-taped cm-sum-cheki">
            <span class="sb-tape" aria-hidden="true"></span>
            <img src={img(summary.img)} alt={summary.title} loading="lazy" />
            <figcaption><span aria-hidden="true">♡</span> {summary.tag}</figcaption>
          </figure>
        )}

        <div class="cm-sum-board">
          <span class="sb-stamp cm-sum-stamp" style="--cc:var(--y-peach)" aria-hidden="true">My Conclusion</span>
          <h2 class="cm-sum-title"><span class="sb-mark" style="--cc:var(--y-butter)">{summary.title}</span></h2>
          <div class="cm-sum-notes">
            {summary.body.map((p, i) => (
              <p class="sb-sticky cm-sum-note" style={`--cc:${sumColors[i % sumColors.length]};transform:rotate(${sumTilts[i % sumTilts.length]})`}>{p}</p>
            ))}
          </div>

          <div class="cm-sum-cta">
            <span class="cm-sum-arrow" aria-hidden="true">↪</span>
            <a href="/yumiki/memory" class="y-btn y-btn--peach cm-sum-btn">推しとの思い出を見る ♡</a>
          </div>
        </div>
      </article>
    </div>
  </section>

  <style>
    .cm-sec { position: relative; }

    /* ===== 表紙（手貼りタイトル・中央テンプレを崩す） ===== */
    .cm-cover { position: relative; padding: 1rem 0 1.6rem; }
    .cm-cover-stamp { margin-bottom: 0.9rem; }
    .cm-cover-tt { font-size: clamp(1.7rem, 4.6vw, 2.7rem); line-height: 1.4; transform: rotate(-1deg); }
    .cm-cover-doodle { top: -0.4rem; left: -0.2rem; font-size: 1.6rem; }
    /* .sb-note 既定の rotate(-2deg) は読みやすさのため少しだけ右回転に上書き */
    .cm-intro { display: inline-block; margin-top: 1rem; font-size: 0.95rem; max-width: 42ch; transform: rotate(1deg); }

    .cm-list { display: flex; flex-direction: column; gap: clamp(2.4rem, 7vw, 4.2rem); margin-top: clamp(1.6rem, 5vw, 2.8rem); }

    /* ===== 1つの魅力 = ノートの1ページ ===== */
    .cm-page { position: relative; border-radius: var(--y-radius-sm); padding: clamp(1.4rem, 4vw, 2.4rem);
      box-shadow: var(--y-shadow-sm); border: 2px solid #fff;
      transform: rotate(-0.5deg); transition: transform 0.4s var(--y-ease), box-shadow 0.4s var(--y-ease); }
    .cm-page--rev { transform: rotate(0.6deg); }
    .cm-page:hover { transform: rotate(0); box-shadow: var(--y-shadow); }
    .cm-page-doodle { top: -0.6rem; right: 6%; font-size: 1.7rem; }
    .cm-page--rev .cm-page-doodle { right: auto; left: 6%; }

    .cm-page-head { margin-bottom: 1.4rem; }
    .cm-page-head .sb-head-num { color: transparent; opacity: 0.85; }
    .cm-page-head h2 { font-size: clamp(1.35rem, 3.4vw, 1.95rem); line-height: 1.4; }

    .cm-page-body { display: grid; gap: 1.4rem; grid-template-columns: 1fr; align-items: start; }
    @media (min-width: 880px) {
      .cm-page-body { grid-template-columns: 0.86fr 1.14fr; gap: clamp(1.8rem, 3.5vw, 3rem); align-items: center; }
      .cm-page--rev .cm-page-cheki { order: 2; }
    }

    /* チェキ（共通 .sb-cheki を使い、サイズ・傾きだけ調整） */
    .cm-page-cheki { justify-self: center; width: min(82vw, 340px); transform: rotate(-2.4deg);
      transition: transform 0.4s var(--y-ease); }
    .cm-page--rev .cm-page-cheki { transform: rotate(2.4deg); }
    .cm-page:hover .cm-page-cheki { transform: rotate(0) scale(1.015); }
    .cm-cheki-img { aspect-ratio: 3/2; border-radius: 2px; overflow: hidden; background: var(--y-cream-2); }
    .cm-cheki-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .cm-cheki-img.noimg img { display: none; }
    .cm-cheki-img.noimg::after { content: "📷"; display: grid; place-items: center; height: 100%; font-size: 2.4rem; opacity: 0.4; }
    .cm-page-cheki figcaption::first-letter { color: var(--cc); }

    /* 本文 */
    .cm-page-text { position: relative; }
    .cm-lead { position: relative; font-size: 1.06rem; font-weight: 700; line-height: 1.95; color: var(--y-ink); margin: 0 0 0.9rem; padding-left: 1.4rem; }
    .cm-q { position: absolute; left: -0.1rem; top: -0.5rem; font-size: 2.2rem; color: var(--cc); opacity: 0.6; line-height: 1; }
    .cm-p { color: var(--y-ink-soft); margin-bottom: 0.8rem; line-height: 1.9; font-size: 0.95rem; }
    .cm-page-note { margin-top: 0.4rem; }

    /* ===== 動画で知る弓木さん ===== */
    .cm-movies { margin-top: clamp(3.2rem, 8vw, 5rem); }
    .cm-mv-head { margin-bottom: 0.8rem; }
    .cm-mv-head .sb-head-num { color: transparent; }
    .cm-mv-head h2 { font-size: clamp(1.5rem, 4vw, 2.1rem); }
    .cm-mv-intro { display: inline-block; margin-bottom: clamp(1.6rem, 4vw, 2.2rem); font-size: 0.92rem; max-width: 46ch; }

    /* フィーチャー（1本目を大きく） */
    .cm-mv-feature { position: relative; display: grid; gap: 1.2rem; grid-template-columns: 1fr; align-items: center;
      background: #fff; border: 2px solid var(--y-line); border-radius: var(--y-radius-sm); padding: clamp(0.9rem, 2.5vw, 1.4rem);
      box-shadow: var(--y-shadow-sm); transform: rotate(-0.6deg); margin-bottom: clamp(1.8rem, 5vw, 2.6rem);
      transition: transform 0.4s var(--y-ease), box-shadow 0.4s var(--y-ease); }
    @media (min-width: 760px) { .cm-mv-feature { grid-template-columns: 1.25fr 0.75fr; gap: clamp(1.4rem, 3vw, 2.2rem); } }
    .cm-mv-feature:hover { transform: rotate(0); box-shadow: var(--y-shadow); }
    .cm-mv-first { position: absolute; top: -0.9rem; right: 1rem; z-index: 4; font-size: 0.82rem;
      transform: rotate(4deg); box-shadow: var(--y-shadow-sm); }
    .cm-mv-thumb--big { border-radius: var(--y-radius-sm); }

    /* 残り（チェキ風の非対称配置） */
    .cm-mv-grid { display: grid; gap: 1.8rem 1.4rem; grid-template-columns: repeat(auto-fit, minmax(238px, 1fr)); align-items: start; }
    .cm-mv-card { padding: 0.55rem 0.55rem 0; overflow: visible; transition: transform .35s var(--y-ease), box-shadow .35s var(--y-ease); }
    .cm-mv-card:nth-child(odd) { transform: rotate(-1.4deg); }
    .cm-mv-card:nth-child(even) { transform: rotate(1.6deg); }
    .cm-mv-card:nth-child(3n) { transform: rotate(-0.6deg) translateY(0.9rem); }
    .cm-mv-card:hover { transform: rotate(0) translateY(-5px); box-shadow: var(--y-shadow); }

    /* サムネ（共通の再生ボタン演出） */
    .cm-mv-thumb { display: block; position: relative; width: 100%; padding: 0; border: 0; cursor: pointer; background: #000; aspect-ratio: 16/9; overflow: hidden; border-radius: 2px; }
    .cm-mv-card .cm-mv-thumb { border-radius: 2px; }
    .cm-mv-thumb img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s var(--y-ease), opacity .3s; }
    .cm-mv-thumb:hover img { transform: scale(1.05); opacity: .85; }
    .cm-mv-play { position: absolute; inset: 0; margin: auto; width: 58px; height: 58px; display: grid; place-items: center; border-radius: 50%;
      background: color-mix(in srgb, var(--y-peach) 88%, #fff); color: #fff; font-size: 1.25rem; padding-left: 4px;
      box-shadow: 0 6px 18px rgba(0,0,0,.3); transition: transform .3s var(--y-ease); }
    .cm-mv-thumb:hover .cm-mv-play { transform: scale(1.12); }
    .cm-mv-frame { position: relative; width: 100%; aspect-ratio: 16/9; background: #000; border-radius: 2px; overflow: hidden; }
    .cm-mv-frame iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }
    .cm-mv-meta { padding: 0.85rem 0.6rem 0.9rem; }
    .cm-mv-feature .cm-mv-meta { padding: 0.2rem 0.4rem; }
    .cm-mv-ch { display: inline-block; font-family: var(--y-font-en); font-weight: 700; font-size: .68rem; letter-spacing: .04em; color: var(--y-ink-soft);
      background: var(--y-cream-2); border-radius: 999px; padding: .25rem .7rem; margin-bottom: .55rem; }
    .cm-mv-title { font-size: 1.02rem; line-height: 1.5; margin-bottom: .4rem; }
    .cm-mv-feature .cm-mv-title { font-size: clamp(1.05rem, 2.4vw, 1.3rem); }
    .cm-mv-note { color: var(--y-ink-soft); font-size: .85rem; line-height: 1.7; }
    .cm-mv-foot { text-align: center; color: var(--y-muted); font-size: .76rem; margin-top: 1.6rem; }

    /* ── 名場面クリップ（本人提供動画） ── */
    .cm-clips-sec { padding-top: 0; }
    .cm-clips-head { margin-bottom: 0.6rem; }
    .cm-clips-intro { display: block; text-align: center; max-width: 48ch; margin: 0 auto 1.6rem; }
    /* 名場面クリップ＝3列の均一16:9ギャラリーに圧縮（縦長を解消・本数は維持） */
    .cm-clips-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem 1.2rem; align-items: start; }
    @media (min-width: 600px) { .cm-clips-grid { grid-template-columns: 1fr 1fr; } }
    @media (min-width: 940px) { .cm-clips-grid { grid-template-columns: repeat(3, 1fr); } }
    .cm-clip { margin: 0; padding: 0.45rem 0.45rem 0.95rem; display: flex; flex-direction: column;
      transition: transform .35s var(--y-ease), box-shadow .35s var(--y-ease); }
    .cm-clip:hover { transform: rotate(0deg) translateY(-4px); box-shadow: var(--y-shadow); z-index: 2; }
    .cm-clip-v { display: block; width: 100%; aspect-ratio: 16 / 9; height: auto; object-fit: contain; border-radius: 4px; background: #000; }
    .cm-clip-cap { font-family: var(--y-font-jp); font-weight: 700; margin: 0.65rem 0 0.3rem; color: var(--y-ink); font-size: 0.96rem; line-height: 1.5; }
    .cm-clip-desc { margin: 0; color: var(--y-ink-soft); font-size: 0.84rem; line-height: 1.75; }
    .cm-clips-foot { display: block; text-align: center; color: var(--y-muted); font-size: 0.74rem; margin-top: 1.6rem; }
    /* 名場面＝テキスト・エピソードカード（番組クリップの自配信をやめ、文章で紹介） */
    .cm-clip--text { background: #fff; border: 2px solid var(--y-line); border-left: 5px solid var(--cc, var(--y-pink)); border-radius: var(--y-radius-sm); padding: 1rem 1.15rem 1.2rem; box-shadow: var(--y-shadow-sm); }
    .cm-clip--text:hover { transform: rotate(0) translateY(-4px) !important; box-shadow: var(--y-shadow); }
    .cm-clip-badge { display: inline-block; font-family: var(--y-font-en); font-weight: 700; font-size: 0.64rem; letter-spacing: .08em; color: var(--y-ink-soft); background: var(--y-cream-2); border-radius: 999px; padding: .25rem .7rem; margin-bottom: .55rem; }
    .cm-clip--text .cm-clip-cap { margin: 0 0 0.4rem; font-size: 1.02rem; }
    /* 名場面カードの絵文字シール＆検証済みリンク */
    .cm-clip { position: relative; }
    .cm-clip-emoji { position: absolute; top: -16px; right: 12px; z-index: 4; font-size: clamp(1.8rem, 5vw, 2.3rem); line-height: 1; }
    .cm-clip-link { align-self: flex-start; margin-top: .85rem; font-family: var(--y-font-en); font-weight: 700; font-size: .78rem;
      color: color-mix(in srgb, var(--y-ink) 52%, var(--y-peach)); background: color-mix(in srgb, var(--y-peach) 22%, #fff);
      padding: .34rem .85rem; border-radius: 999px; transition: transform .25s var(--y-ease), background .25s var(--y-ease); }
    .cm-clip-link:hover { transform: translateY(-2px); background: color-mix(in srgb, var(--y-peach) 38%, #fff); }

    /* 会話力／努力家：写真の代わりの“挿絵パネル”（番組切り抜き非掲載の跡地を埋める） */
    .cm-deco { position: relative; justify-self: center; width: min(82vw, 340px); aspect-ratio: 3 / 2; margin: 0;
      display: grid; place-content: center; justify-items: center; gap: .55rem; text-align: center; padding: 1rem;
      background: linear-gradient(150deg, color-mix(in srgb, var(--cc) 26%, #fff), color-mix(in srgb, var(--cc) 8%, #fffdf8));
      border: 2px dashed color-mix(in srgb, var(--cc) 45%, #fff); border-radius: var(--y-radius-sm);
      box-shadow: var(--y-shadow-sm); transform: rotate(-2.2deg); transition: transform .4s var(--y-ease), box-shadow .4s var(--y-ease); }
    .cm-page--rev .cm-deco { transform: rotate(2.2deg); }
    .cm-page:hover .cm-deco { transform: rotate(0) scale(1.015); box-shadow: var(--y-shadow); }
    .cm-deco-emoji { font-size: clamp(3rem, 9vw, 4.4rem); line-height: 1; }
    .cm-deco-sub { font-family: var(--y-font-en); font-weight: 700; font-size: .72rem; letter-spacing: .14em; color: var(--y-ink-soft); }
    .cm-deco-d { font-size: 1.5rem; }
    .cm-deco-d--1 { top: 12%; left: 9%; }
    .cm-deco-d--2 { bottom: 14%; right: 10%; }
    .cm-deco-d--3 { top: 18%; right: 15%; }
    @media (prefers-reduced-motion: reduce) { .cm-deco { transform: rotate(-2.2deg); } .cm-page--rev .cm-deco { transform: rotate(2.2deg); } }
    /* 魅力ページ：写真は1カラムで本文の上に（番組由来は非掲載・公式/CM/ブログのみ掲載） */
    @media (min-width: 880px) { .cm-page-body { grid-template-columns: 1fr; } }

    /* ===== 締め：寄せ書き／色紙 ===== */
    .cm-sum { position: relative; overflow: hidden; margin-top: clamp(3.2rem, 8vw, 5rem);
      border: 2px dashed var(--y-line); border-radius: var(--y-radius);
      padding: clamp(1.8rem, 5vw, 3rem) clamp(1.2rem, 4vw, 2.6rem); box-shadow: var(--y-shadow-sm); }
    .cm-sum-doodle { font-size: 2.2rem; }
    .cm-sum-doodle--1 { top: 1rem; right: 1.2rem; }
    .cm-sum-doodle--2 { bottom: 1rem; left: 1.4rem; font-size: 1.6rem; }
    .cm-sum-cheki { display: block; width: min(72vw, 320px); margin: 0 auto 1.6rem; transform: rotate(-2deg); }
    .cm-sum-cheki img { aspect-ratio: 3/2; }
    .cm-sum-cheki figcaption::first-letter { color: var(--y-peach); }
    .cm-sum-board { max-width: 60ch; margin: 0 auto; text-align: center; }
    .cm-sum-stamp { margin-bottom: 0.9rem; }
    .cm-sum-title { font-size: clamp(1.45rem, 4vw, 2.1rem); line-height: 1.4; margin-bottom: 1.4rem; display: inline-block; }
    .cm-sum-notes { display: flex; flex-direction: column; gap: 1rem; text-align: left; margin-bottom: 1.8rem; }
    .cm-sum-note { color: var(--y-ink); line-height: 1.9; font-size: 0.95rem; font-weight: 500; }
    .cm-sum-cta { display: inline-flex; align-items: center; gap: 0.4rem; }
    .cm-sum-arrow { font-size: 1.8rem; color: var(--y-peach); transform: rotate(8deg); line-height: 1; }
    .cm-sum-btn { margin: 0; }

    @media (max-width: 879px) {
      .cm-sum-notes { gap: 0.85rem; }
    }
  </style>

  <script>
    // 動画サムネをクリックしたら、その場で YouTube（プライバシー強化モード）を再生。
    // 初期表示はサムネ画像だけ＝iframeは押すまで読み込まないので軽い（lite-youtube方式）。
    document.querySelectorAll(".cm-mv-card, .cm-mv-feature").forEach((card) => {
      const btn = card.querySelector(".cm-mv-thumb");
      const id = card.getAttribute("data-yt");
      if (!btn || !id) return;
      btn.addEventListener("click", () => {
        const frame = document.createElement("div");
        frame.className = "cm-mv-frame";
        const iframe = document.createElement("iframe");
        iframe.src = "https://www.youtube-nocookie.com/embed/" + id + "?autoplay=1&rel=0";
        iframe.title = "YouTube 動画プレイヤー";
        iframe.allow = "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share";
        iframe.allowFullscreen = true;
        iframe.loading = "lazy";
        frame.appendChild(iframe);
        btn.replaceWith(frame);
      }, { once: true });
    });
  </script>
