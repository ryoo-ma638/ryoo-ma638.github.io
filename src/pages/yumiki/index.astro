---
import Yumiki from "../../layouts/Yumiki.astro";
import { profile, nav, sns, img } from "../../data/yumiki.ts";
const cards = nav.filter((n) => n.href !== "/yumiki/");
const cardDesc: Record<string, string> = {
  "/yumiki/profile": "生年月日・経歴・出演番組・家族のこと",
  "/yumiki/charm": "弓木ワールド・会話力・努力家・まとめ",
  "/yumiki/memory": "ライブ・ミーグリ・イベントの思い出",
  "/yumiki/gallery": "写真集・生写真・お気に入りショット",
};
const cardColor: Record<string, string> = {
  "/yumiki/profile": "var(--y-sky)",
  "/yumiki/charm": "var(--y-pink)",
  "/yumiki/memory": "var(--y-mint)",
  "/yumiki/gallery": "var(--y-lav)",
};
// 今の弓木さん（最新トピックス・すべて事実）
const now = [
  { emoji: "📕", t: "初の写真集", d: "1st『天使だったのか』2024.7発売・オリコン書籍部門1位", c: "var(--y-peach)" },
  { emoji: "⭐️", t: "初の福神", d: "35th『チャンスは平等』(2024.4)で初の福神入り", c: "var(--y-butter)" },
  { emoji: "🎬", t: "初主演ドラマ", d: "『未恋』(2025.1)で初主演。繊細な演技が話題に", c: "var(--y-lav)" },
  { emoji: "🎤", t: "選抜の常連へ", d: "最新シングルも選抜入り（10作連続）。グループに欠かせない存在に", c: "var(--y-mint)" },
];
---
<Yumiki>
  <!-- HERO -->
  <section class="y-hero">
    <div class="y-container y-hero-inner">
      <div class="y-hero-text y-reveal">
        <span class="y-tag" style="background:var(--y-butter)">✦ 乃木坂46 4期生</span>
        <h1 class="y-hero-title">
          ようこそ、<br /><span class="y-hero-name">弓木ワールド</span>へ。
        </h1>
        <p class="y-hero-lead">{profile.intro}</p>
        <div class="y-hero-btns">
          <a href="/yumiki/charm" class="y-btn y-btn--peach">魅力を見る ♡</a>
          <a href="/yumiki/profile" class="y-btn y-btn--soft">プロフィール</a>
        </div>
        <div class="y-hero-sns">
          {sns.map((s) => (<a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.label}><img src={img(s.icon)} alt={s.label} /></a>))}
        </div>
      </div>
      <div class="y-hero-photo y-reveal" data-delay="1">
        <div class="y-photo-frame">
          <img src={img("yumiki-main.png")} alt="弓木奈於さん" onerror="this.src='/assets/yumiki/nao_main.jpg'" />
        </div>
        <span class="y-blob y-blob--1">♡</span>
        <span class="y-blob y-blob--2">✦</span>
        <span class="y-blob y-blob--3">✿</span>
      </div>
    </div>
  </section>

  <!-- NOW / 最新トピックス -->
  <section class="y-section y-now-sec">
    <div class="y-container">
      <div class="y-head y-reveal">
        <span class="y-eyebrow">Now</span>
        <h2>✨ 今の<span class="wave">弓木さん</span></h2>
      </div>
      <div class="y-now-grid">
        {now.map((n, i) => (
          <div class="y-now-card y-card y-reveal" data-delay={(i % 4) + 1} style={`--cc:${n.c}`}>
            <span class="y-now-emoji">{n.emoji}</span>
            <h3>{n.t}</h3>
            <p>{n.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- NAV CARDS -->
  <section class="y-section">
    <div class="y-container">
      <div class="y-head y-reveal">
        <span class="y-eyebrow">Explore</span>
        <h2><span class="wave">弓木ワールド</span>を探検しよう</h2>
      </div>
      <div class="y-cards">
        {cards.map((c, i) => (
          <a href={c.href} class="y-nav-card y-card y-reveal" data-delay={(i % 3) + 1} style={`--cc:${cardColor[c.href]}`}>
            <span class="y-nav-emoji">{c.emoji}</span>
            <h3>{c.label}</h3>
            <p>{cardDesc[c.href]}</p>
            <span class="y-nav-go">のぞいてみる →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <style>
    .y-hero { padding: 3rem 0 4rem; }
    .y-hero-inner { display: grid; gap: 2.5rem; grid-template-columns: 1fr; align-items: center; }
    @media (min-width: 880px) { .y-hero-inner { grid-template-columns: 1.1fr 0.9fr; } }
    .y-hero-title { font-size: clamp(2.4rem, 7vw, 4.5rem); font-weight: 900; line-height: 1.2; margin: 1rem 0 1.2rem; }
    .y-hero-name { background: linear-gradient(90deg, var(--y-peach), var(--y-lav), var(--y-sky)); -webkit-background-clip: text; background-clip: text; color: transparent; }
    .y-hero-lead { color: var(--y-ink-soft); max-width: 46ch; margin-bottom: 1.6rem; }
    .y-hero-btns { display: flex; gap: 0.8rem; flex-wrap: wrap; margin-bottom: 1.4rem; }
    .y-hero-sns { display: flex; gap: 0.7rem; }
    .y-hero-sns a { width: 44px; height: 44px; border-radius: 50%; background: #fff; display: grid; place-items: center; box-shadow: var(--y-shadow-sm); transition: transform .3s var(--y-ease); }
    .y-hero-sns a:hover { transform: translateY(-3px) scale(1.08); }
    .y-hero-sns img { width: 22px; height: 22px; }

    .y-hero-photo { position: relative; justify-self: center; }
    .y-photo-frame { width: min(78vw, 380px); aspect-ratio: 4/5; border-radius: 48% 52% 50% 50% / 52% 48% 52% 48%; overflow: hidden; border: 6px solid #fff; box-shadow: var(--y-shadow); animation: floaty 6s ease-in-out infinite; }
    .y-photo-frame img { width: 100%; height: 100%; object-fit: cover; object-position: center top; }
    .y-blob { position: absolute; font-size: 2rem; animation: twinkle 2.6s ease-in-out infinite; }
    .y-blob--1 { top: -6px; right: 6%; color: var(--y-peach); }
    .y-blob--2 { bottom: 12%; left: -10px; color: var(--y-butter); animation-delay: .6s; font-size: 2.6rem; }
    .y-blob--3 { bottom: -8px; right: 18%; color: var(--y-lav); animation-delay: 1.1s; }

    .y-now-sec { padding-top: 0; }
    .y-now-grid { display: grid; gap: 1.1rem; grid-template-columns: repeat(2, 1fr); }
    @media (min-width: 880px) { .y-now-grid { grid-template-columns: repeat(4, 1fr); } }
    .y-now-card { padding: 1.5rem 1.3rem; border-top: 5px solid var(--cc); }
    .y-now-emoji { font-size: 1.8rem; display: block; margin-bottom: 0.5rem; }
    .y-now-card h3 { font-size: 1.15rem; margin-bottom: 0.4rem; }
    .y-now-card p { color: var(--y-ink-soft); font-size: 0.85rem; line-height: 1.6; }

    .y-cards { display: grid; gap: 1.4rem; grid-template-columns: repeat(2, 1fr); }
    @media (max-width: 620px) { .y-cards { grid-template-columns: 1fr; } }
    .y-nav-card { padding: 2rem 1.6rem; border-top: 6px solid var(--cc); transition: transform .35s var(--y-ease), box-shadow .35s var(--y-ease); }
    .y-nav-card:hover { transform: translateY(-6px) rotate(-1deg); box-shadow: var(--y-shadow); }
    .y-nav-emoji { font-size: 2.4rem; display: block; margin-bottom: 0.6rem; }
    .y-nav-card h3 { font-size: 1.4rem; margin-bottom: 0.4rem; }
    .y-nav-card p { color: var(--y-ink-soft); font-size: 0.9rem; margin-bottom: 1rem; }
    .y-nav-go { font-family: var(--y-font-en); font-weight: 700; color: var(--y-peach); }
  </style>
</Yumiki>
