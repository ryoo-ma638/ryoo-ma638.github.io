---
import Yumiki from "../../layouts/Yumiki.astro";
import { profile, nav, sns, img } from "../../data/yumiki.ts";
const cards = nav.filter((n) => n.href !== "/yumiki/");
const cardDesc: Record<string, string> = {
  "/yumiki/profile": "生年月日・経歴・出演番組・家族のこと",
  "/yumiki/charm": "弓木ワールド・会話力・努力家・まとめ",
  "/yumiki/memory": "ライブ・ミーグリ・イベントの思い出",
  "/yumiki/gallery": "写真集・生写真・お気に入りショット",
};
const cardColor: Record<string, string> = {
  "/yumiki/profile": "var(--y-sky)",
  "/yumiki/charm": "var(--y-pink)",
  "/yumiki/memory": "var(--y-mint)",
  "/yumiki/gallery": "var(--y-lav)",
};
const heroLead =
  "天真爛漫なトークでバラエティを沸かせ、影では努力を惜しまない——乃木坂46 4期生・弓木奈於さんの魅力を、ファン目線でめいっぱい詰め込んだ非公式ファンサイトです。";
// 今の弓木さん（2026年6月時点の最新トピックス・事実）
const now = [
  { emoji: "💿", t: "最新シングル", d: "41st『最後に階段を駆け上がったのはいつだ？』(2026.4)に参加", c: "var(--y-sky)" },
  { emoji: "📸", t: "最新グラビア", d: "『B.L.T. 2026年5月号』に登場（“ふつうで幸せな日曜日”）", c: "var(--y-pink)" },
  { emoji: "⭐️", t: "選抜の常連", d: "選抜入りを続ける、グループに欠かせない存在に", c: "var(--y-butter)" },
  { emoji: "📺", t: "バラエティで活躍", d: "『ラヴィット！』『乃木坂工事中』などで天然トークが炸裂", c: "var(--y-mint)" },
];
---
<Yumiki>
  <!-- HERO -->
  <section class="y-hero">
    <div class="y-hero-glow" aria-hidden="true"></div>
    <div class="y-container y-hero-inner">
      <div class="y-hero-text y-reveal">
        <span class="y-hero-eyebrow">NOGIZAKA46 <i>✦</i> 4<small>TH</small> GENERATION</span>
        <h1 class="y-hero-title">
          <span class="y-hero-kicker">ようこそ、</span>
          <span class="y-hero-big"><span class="y-hero-name">弓木ワールド</span><span class="y-hero-he">へ。</span></span>
        </h1>
        <p class="y-hero-romaji">YUMIKI&nbsp;NAO &nbsp;/&nbsp; 弓木 奈於</p>
        <p class="y-hero-lead">{heroLead}</p>
        <ul class="y-hero-facts">
          <li><span>🎂</span> 1999.2.3</li>
          <li><span>📍</span> 京都府</li>
          <li><span>📏</span> 165cm</li>
          <li><span>🩷</span> 赤 × 黄緑</li>
        </ul>
        <div class="y-hero-btns">
          <a href="/yumiki/charm" class="y-btn y-btn--peach">魅力を見る ♡</a>
          <a href="/yumiki/profile" class="y-btn y-btn--soft">プロフィール</a>
        </div>
        <div class="y-hero-sns">
          {sns.map((s) => (<a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.label}><img src={img(s.icon)} alt={s.label} loading="lazy" /></a>))}
        </div>
      </div>
      <div class="y-hero-photo y-reveal" data-delay="1">
        <span class="y-photo-card" aria-hidden="true"></span>
        <span class="y-photo-ring" aria-hidden="true"></span>
        <div class="y-photo-frame">
          <img src={img("yumiki-main.jpg")} alt="弓木奈於さん" fetchpriority="high" width="757" height="991" onerror="this.src='/assets/yumiki/yumiki-main.png'" />
        </div>
        <span class="y-photo-badge" aria-hidden="true"><b>♡</b><i>MY OSHI</i></span>
        <span class="y-blob y-blob--1">♡</span>
        <span class="y-blob y-blob--2">✦</span>
        <span class="y-blob y-blob--3">✿</span>
        <span class="y-blob y-blob--4">⭐️</span>
      </div>
    </div>
  </section>

  <!-- 流れるリボン -->
  <div class="y-ribbon" aria-hidden="true">
    <div class="y-ribbon-track">
      {Array.from({ length: 4 }).map(() => (
        <span class="y-ribbon-unit">弓木奈於 <i>✦</i> NAO YUMIKI <i>✦</i> 乃木坂46 4期生 <i>✦</i> ゆみっきー <i>✦</i> </span>
      ))}
    </div>
  </div>

  <!-- NOW / 最新トピックス -->
  <section class="y-section y-now-sec">
    <div class="y-container">
      <div class="y-head y-reveal">
        <span class="y-eyebrow">Now</span>
        <h2>✨ 今の<span class="wave">弓木さん</span></h2>
      </div>
      <div class="y-now-grid">
        {now.map((n, i) => (
          <div class="y-memo y-reveal" data-delay={(i % 4) + 1} style={`--cc:${n.c}`}>
            <span class="y-memo-tape" aria-hidden="true"></span>
            <span class="y-memo-emoji">{n.emoji}</span>
            <h3 class="y-memo-t">{n.t}</h3>
            <p class="y-memo-d">{n.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- NAV CARDS -->
  <section class="y-section">
    <div class="y-container">
      <div class="y-head y-reveal">
        <span class="y-eyebrow">Explore</span>
        <h2><span class="wave">弓木ワールド</span>を探検しよう</h2>
      </div>
      <div class="y-cards">
        {cards.map((c, i) => (
          <a href={c.href} class="y-nav-card y-card y-reveal" data-delay={(i % 3) + 1} style={`--cc:${cardColor[c.href]}`}>
            <span class="y-nav-emoji">{c.emoji}</span>
            <h3>{c.label}</h3>
            <p>{cardDesc[c.href]}</p>
            <span class="y-nav-go">のぞいてみる →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <style>
    /* ===== HERO（雑誌風・大型） ===== */
    .y-hero { position: relative; padding: clamp(1.5rem, 5vw, 3.5rem) 0 clamp(2rem, 5vw, 3.5rem); overflow: hidden; }
    .y-hero-glow { position: absolute; inset: -25% -10% auto -10%; height: 130%; z-index: -1; pointer-events: none;
      background:
        radial-gradient(38% 48% at 78% 22%, color-mix(in srgb, var(--y-peach) 55%, transparent), transparent 70%),
        radial-gradient(44% 52% at 18% 62%, color-mix(in srgb, var(--y-sky) 48%, transparent), transparent 70%),
        radial-gradient(40% 40% at 62% 92%, color-mix(in srgb, var(--y-lav) 42%, transparent), transparent 70%);
      filter: blur(10px); opacity: .85; animation: y-hero-glow 15s ease-in-out infinite alternate; }
    @keyframes y-hero-glow { 0% { transform: translate3d(0,0,0) scale(1); } 100% { transform: translate3d(0,-2%,0) scale(1.07); } }

    .y-hero-inner { display: grid; gap: clamp(2rem, 4vw, 3rem); grid-template-columns: 1fr; align-items: center; }
    @media (min-width: 880px) { .y-hero-inner { grid-template-columns: 1.05fr 0.95fr; } }

    .y-hero-eyebrow { display: inline-flex; align-items: center; gap: .5rem; font-family: var(--y-font-en); font-weight: 700; font-size: .78rem; letter-spacing: .14em; color: var(--y-ink-soft); background: #fff; border: 2px solid var(--y-line); padding: .42rem .95rem; border-radius: 999px; box-shadow: var(--y-shadow-sm); }
    .y-hero-eyebrow i { color: var(--y-peach); font-style: normal; }
    .y-hero-eyebrow small { font-size: .65em; }

    .y-hero-title { margin: 1.1rem 0 .5rem; line-height: 1.06; }
    .y-hero-kicker { display: block; font-size: clamp(1.1rem, 3vw, 1.7rem); font-weight: 700; color: var(--y-ink); }
    .y-hero-big { display: block; font-size: clamp(2.9rem, 9.2vw, 5.6rem); font-weight: 900; letter-spacing: -.01em; }
    .y-hero-name { background: linear-gradient(100deg, var(--y-peach), var(--y-lav) 45%, var(--y-sky) 82%); background-size: 220% 100%; -webkit-background-clip: text; background-clip: text; color: transparent; animation: y-shine 7s ease-in-out infinite; }
    @keyframes y-shine { 0%,100% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } }
    .y-hero-he { color: var(--y-ink); }

    .y-hero-romaji { font-family: var(--y-font-en); font-weight: 700; letter-spacing: .1em; color: var(--y-muted); font-size: .82rem; margin-bottom: 1.1rem; }
    .y-hero-lead { color: var(--y-ink-soft); max-width: 44ch; margin-bottom: 1.3rem; font-size: .96rem; }

    .y-hero-facts { list-style: none; padding: 0; margin: 0 0 1.5rem; display: flex; flex-wrap: wrap; gap: .55rem; }
    .y-hero-facts li { display: inline-flex; align-items: center; gap: .35rem; background: #fff; border: 2px solid var(--y-line); border-radius: 999px; padding: .4rem .85rem; font-size: .82rem; font-weight: 700; color: var(--y-ink); box-shadow: var(--y-shadow-sm); }

    .y-hero-btns { display: flex; gap: 0.8rem; flex-wrap: wrap; margin-bottom: 1.3rem; }
    .y-hero-sns { display: flex; gap: 0.7rem; }
    .y-hero-sns a { width: 44px; height: 44px; border-radius: 50%; background: #fff; display: grid; place-items: center; box-shadow: var(--y-shadow-sm); transition: transform .3s var(--y-ease); }
    .y-hero-sns a:hover { transform: translateY(-3px) scale(1.08); }
    .y-hero-sns img { width: 22px; height: 22px; }

    /* 写真：背景カード＋回転リング＋多層フレーム＋ステッカー */
    .y-hero-photo { position: relative; justify-self: center; width: min(80vw, 390px); aspect-ratio: 4/5; }
    .y-photo-card { position: absolute; inset: 7% -6% -8% 7%; border-radius: 44px; background: linear-gradient(135deg, var(--y-pink), var(--y-lav)); transform: rotate(6deg); box-shadow: var(--y-shadow); }
    .y-photo-ring { position: absolute; inset: -7%; border-radius: 50%; border: 2px dashed color-mix(in srgb, var(--y-peach) 65%, #fff); animation: y-spin 28s linear infinite; }
    .y-photo-ring::before { content: "✦"; position: absolute; top: -2px; left: 50%; transform: translate(-50%,-50%); color: var(--y-butter); font-size: 1.3rem; }
    @keyframes y-spin { to { transform: rotate(360deg); } }
    .y-photo-frame { position: absolute; inset: 0; border-radius: 44px; overflow: hidden; border: 6px solid #fff; box-shadow: var(--y-shadow); animation: floaty 6s ease-in-out infinite; }
    .y-photo-frame img { width: 100%; height: 100%; object-fit: cover; object-position: center top; }
    .y-photo-badge { position: absolute; bottom: -5%; left: -7%; width: clamp(68px, 19%, 90px); aspect-ratio: 1; border-radius: 50%; background: #fff; box-shadow: var(--y-shadow); display: grid; place-content: center; text-align: center; line-height: 1; transform: rotate(-8deg); animation: wobble 5s ease-in-out infinite; }
    .y-photo-badge b { color: var(--y-peach); font-size: 1.5rem; }
    .y-photo-badge i { display: block; font-family: var(--y-font-en); font-style: normal; font-weight: 700; font-size: .55rem; letter-spacing: .08em; color: var(--y-ink-soft); margin-top: 2px; }

    .y-blob { position: absolute; font-size: 2rem; animation: twinkle 2.6s ease-in-out infinite, floaty 7s ease-in-out infinite; pointer-events: none; }
    .y-blob--1 { top: -4%; right: 3%; color: var(--y-peach); }
    .y-blob--2 { top: 15%; left: -8%; color: var(--y-butter); animation-delay: .6s, .3s; font-size: 2.3rem; }
    .y-blob--3 { bottom: 7%; right: -5%; color: var(--y-lav); animation-delay: 1.1s, .8s; }
    .y-blob--4 { top: 46%; right: -7%; color: var(--y-sky); animation-delay: .4s, 1.2s; font-size: 1.4rem; }

    /* 流れるリボン */
    .y-ribbon { margin-top: clamp(1.6rem, 4vw, 2.6rem); padding: .7rem 0; background: linear-gradient(90deg, var(--y-peach), var(--y-butter), var(--y-mint), var(--y-sky), var(--y-lav), var(--y-peach)); overflow: hidden; transform: rotate(-1.2deg) scale(1.04); }
    .y-ribbon-track { display: flex; width: max-content; animation: y-marquee 28s linear infinite; }
    .y-ribbon-unit { font-family: var(--y-font-en); font-weight: 700; font-size: 1rem; letter-spacing: .04em; color: #fff; white-space: nowrap; padding-right: 1rem; text-shadow: 0 1px 2px rgba(120,90,80,.2); }
    .y-ribbon-unit i { font-style: normal; }
    @keyframes y-marquee { to { transform: translateX(-50%); } }
    @media (prefers-reduced-motion: reduce) { .y-ribbon-track, .y-photo-ring, .y-hero-glow, .y-hero-name { animation: none; } }

    .y-now-sec { padding-top: 0; }
    /* スクラップブックのメモ風（付箋＋マスキングテープ＋互い違いの傾き） */
    .y-now-grid { display: grid; gap: 1.4rem 1.2rem; grid-template-columns: repeat(2, 1fr); max-width: 760px; margin-inline: auto; }
    .y-memo { position: relative; background: color-mix(in srgb, var(--cc) 15%, #fff); border: 1.5px solid color-mix(in srgb, var(--cc) 32%, #fff);
      border-radius: 14px; padding: 1.6rem 1.3rem 1.4rem; box-shadow: var(--y-shadow-sm); transition: transform .35s var(--y-ease), box-shadow .35s var(--y-ease); }
    .y-memo:nth-child(odd) { transform: rotate(-1.5deg); }
    .y-memo:nth-child(even) { transform: rotate(1.5deg); margin-top: 1.5rem; }
    .y-memo:hover { transform: rotate(0) translateY(-5px); box-shadow: var(--y-shadow); z-index: 1; }
    .y-memo-tape { position: absolute; top: -9px; left: 20px; width: 66px; height: 22px; transform: rotate(-8deg); opacity: 0.85;
      background: color-mix(in srgb, var(--cc) 62%, transparent); box-shadow: 0 2px 5px rgba(120,90,80,0.12);
      -webkit-mask-image: repeating-linear-gradient(90deg,#000 0 5px,transparent 5px 7px); mask-image: repeating-linear-gradient(90deg,#000 0 5px,transparent 5px 7px); }
    .y-memo-emoji { font-size: 1.6rem; line-height: 1; }
    .y-memo-t { font-size: 1.08rem; margin: 0.4rem 0 0.4rem; }
    .y-memo-d { color: var(--y-ink-soft); font-size: 0.85rem; line-height: 1.75; }

    .y-cards { display: grid; gap: 1.4rem; grid-template-columns: repeat(2, 1fr); }
    @media (max-width: 620px) { .y-cards { grid-template-columns: 1fr; } }
    .y-nav-card { position: relative; overflow: hidden; padding: 2.1rem 1.7rem; transition: transform .35s var(--y-ease), box-shadow .35s var(--y-ease); }
    .y-nav-card::after { content: ""; position: absolute; right: -26px; bottom: -26px; width: 88px; height: 88px; border-radius: 50%; background: color-mix(in srgb, var(--cc) 22%, transparent); transition: transform .45s var(--y-ease); }
    .y-nav-card:hover { transform: translateY(-7px) rotate(-1.2deg); box-shadow: var(--y-shadow); }
    .y-nav-card:hover::after { transform: scale(1.6); }
    .y-nav-emoji { position: relative; z-index: 1; display: grid; place-items: center; width: 62px; height: 62px; border-radius: 50%; font-size: 2rem; margin-bottom: 0.8rem;
      background: color-mix(in srgb, var(--cc) 34%, #fff); box-shadow: 0 6px 16px color-mix(in srgb, var(--cc) 45%, transparent); }
    .y-nav-card h3 { position: relative; z-index: 1; font-size: 1.4rem; margin-bottom: 0.4rem; }
    .y-nav-card p { position: relative; z-index: 1; color: var(--y-ink-soft); font-size: 0.9rem; margin-bottom: 1rem; }
    .y-nav-go { position: relative; z-index: 1; display: inline-flex; align-items: center; gap: 0.3rem; font-family: var(--y-font-en); font-weight: 700; color: var(--y-ink);
      background: color-mix(in srgb, var(--cc) 30%, #fff); padding: 0.4rem 0.95rem; border-radius: 999px; transition: gap .3s var(--y-ease); }
    .y-nav-card:hover .y-nav-go { gap: 0.6rem; }
  </style>
</Yumiki>
