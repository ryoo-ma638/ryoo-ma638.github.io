  /* ノードをタップしたとき♡が弾けるプチ演出（JSが body に生成） */
  .rel-burst { position: fixed; z-index: 1200; pointer-events: none; font-size: 1.15rem; transform: translate(-50%, -50%); will-change: transform, opacity; animation: rel-burst .75s ease-out forwards; }
  @keyframes rel-burst { 0% { opacity: 1; transform: translate(-50%, -50%) scale(.5); } 100% { opacity: 0; transform: translate(calc(-50% + var(--tx, 0px)), calc(-50% + var(--ty, 0px))) scale(1.1) rotate(var(--rot, 0deg)); } }

</style>

<script>
  // ── メンバー詳細モーダル ──
  const modal = document.getElementById("ymem");
  if (modal) {
    const av = document.getElementById("ymemAv")!;
    const nm = document.getElementById("ymemName")!;
    const rel = document.getElementById("ymemRel")!;
    const sub = document.getElementById("ymemSub")!;
    const note = document.getElementById("ymemNote")!;
    let lastFocused: HTMLElement | null = null;
    const xBtn = modal.querySelector(".ymem-x") as HTMLElement | null;
    const lockScroll = () => { const b = document.body; const n = (parseInt(b.dataset.scrollLock || "0", 10)) + 1; b.dataset.scrollLock = String(n); b.style.overflow = "hidden"; };
    const unlockScroll = () => { const b = document.body; const n = Math.max(0, (parseInt(b.dataset.scrollLock || "0", 10)) - 1); b.dataset.scrollLock = String(n); if (n === 0) b.style.overflow = ""; };
    const focusables = () => Array.from(modal.querySelectorAll('button, a[href], [tabindex]:not([tabindex="-1"])')).filter((el) => (el as HTMLElement).offsetParent !== null) as HTMLElement[];
    const onTrap = (e: KeyboardEvent) => { if (e.key !== "Tab") return; const f = focusables(); if (!f.length) return; const first = f[0], last = f[f.length - 1]; if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); } else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); } };
    // ♡が弾けるプチ演出（ノードを開いた瞬間・reduced-motion時は無効）
    const burstOK = !window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const burstGlyphs = ["♡", "✦", "♥", "✿"];
    const burstColors = ["#ff9fb2", "#ffc2d1", "#ffd98a", "#9fe3c5", "#cdbcff", "#a9d8ff"];
    const heartBurst = (x: number, y: number) => {
      if (!burstOK) return;
      for (let k = 0; k < 8; k++) {
        const s = document.createElement("span");
        s.className = "rel-burst";
        s.textContent = burstGlyphs[k % burstGlyphs.length];
        const ang = (Math.PI * 2 * k) / 8 + Math.random() * 0.5;
        const dist = 38 + Math.random() * 30;
        s.style.left = x + "px";
        s.style.top = y + "px";
        s.style.color = burstColors[k % burstColors.length];
        s.style.setProperty("--tx", Math.cos(ang) * dist + "px");
        s.style.setProperty("--ty", Math.sin(ang) * dist - 22 + "px");
        s.style.setProperty("--rot", Math.random() * 60 - 30 + "deg");
        s.style.fontSize = 0.9 + Math.random() * 0.7 + "rem";
        document.body.appendChild(s);
        window.setTimeout(() => s.remove(), 800);
      }
    };
    const open = (btn: HTMLElement) => {
      const name = btn.dataset.name || "";
      const gc = btn.style.getPropertyValue("--gc") || "var(--y-peach)";
      av.textContent = name.replace(/[\s　]/g, "").charAt(0);
      (av as HTMLElement).style.background = gc;
      nm.textContent = name;
      rel.textContent = btn.dataset.rel || "";
      (rel as HTMLElement).style.background = gc;
      sub.textContent = btn.dataset.sub || "";
      note.textContent = btn.dataset.note || "";
      lastFocused = document.activeElement as HTMLElement;
      modal.classList.add("open");
      modal.setAttribute("aria-hidden", "false");
      lockScroll();
      modal.addEventListener("keydown", onTrap as EventListener);
      xBtn?.focus();
    };
    const close = () => {
      modal.classList.remove("open");
      modal.setAttribute("aria-hidden", "true");
      modal.removeEventListener("keydown", onTrap as EventListener);
      unlockScroll();
      lastFocused?.focus?.();
    };
    document.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest(".node--link") as HTMLElement | null;
      if (btn) { heartBurst(e.clientX, e.clientY); open(btn); return; }
      if (e.target === modal || (e.target as HTMLElement).classList.contains("ymem-x")) close();
    });
    document.addEventListener("keydown", (e) => { if (e.key === "Escape" && modal.classList.contains("open")) close(); });
  }

  // ── 中心相関図：ハブから各ノードへ“線”をSVGで描く（レスポンシブ再計算） ──
  const SVGNS = "http://www.w3.org/2000/svg";
  // 矩形の中心(cx,cy・幅w/高h)から目標(tx,ty)方向に伸ばした時の、矩形の枠との交点
  function edgePoint(cx: number, cy: number, w: number, h: number, tx: number, ty: number) {
    const dx = tx - cx, dy = ty - cy;
    if (!dx && !dy) return { x: cx, y: cy };
    const sx = dx !== 0 ? (w / 2) / Math.abs(dx) : Infinity;
    const sy = dy !== 0 ? (h / 2) / Math.abs(dy) : Infinity;
    const s = Math.min(sx, sy);
    return { x: cx + dx * s, y: cy + dy * s };
  }
  const corReduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  let corVisible = false, corAnimated = false;
  function drawCor() {
    const cor = document.getElementById("cor");
    const svg = document.getElementById("corSvg");
    const hub = document.getElementById("corHub");
    if (!cor || !svg || !hub) return;
    while (svg.firstChild) svg.removeChild(svg.firstChild);
    // モバイル（SVG非表示）は描かない
    if (getComputedStyle(svg).display === "none") return;
    const cr = cor.getBoundingClientRect();
    svg.setAttribute("viewBox", `0 0 ${cr.width} ${cr.height}`);
    const hb = hub.getBoundingClientRect();
    const hx = hb.left - cr.left + hb.width / 2;
    const hy = hb.top - cr.top + hb.height / 2;
    // 初回かつ表示領域に入った時だけ“描き込み”アニメ（resize等の再描画は静的）
    const animate = corVisible && !corAnimated && !corReduce;
    cor.querySelectorAll<HTMLElement>(".cor-node").forEach((node, i) => {
      const nb = node.getBoundingClientRect();
      const nx = nb.left - cr.left + nb.width / 2;
      const ny = nb.top - cr.top + nb.height / 2;
      const gc = node.style.getPropertyValue("--gc") || "var(--y-peach)";
      node.dataset.corIdx = String(i);
      // ハブの枠 → ノードの枠 を結ぶ（カードの間の隙間にだけ線が出るのではっきり見える）
      const p1 = edgePoint(hx, hy, hb.width, hb.height, nx, ny);
      const p2 = edgePoint(nx, ny, nb.width, nb.height, hx, hy);
      // ゆるく弧を描く“毛糸”のような線（直線より可愛い・隣り合う線は逆向きに反らす）
      const mx = (p1.x + p2.x) / 2, my = (p1.y + p2.y) / 2;
      const dx = p2.x - p1.x, dy = p2.y - p1.y;
      const nlen = Math.hypot(dx, dy) || 1;
      const amp = Math.min(24, nlen * 0.13) * (i % 2 === 0 ? 1 : -1);
      const cxp = mx + (-dy / nlen) * amp, cyp = my + (dx / nlen) * amp;
      const line = document.createElementNS(SVGNS, "path");
      line.setAttribute("d", `M ${p1.x} ${p1.y} Q ${cxp} ${cyp} ${p2.x} ${p2.y}`);
      line.setAttribute("fill", "none");
      line.setAttribute("class", "cor-line");
      line.setAttribute("stroke-width", "2.6");
      line.setAttribute("stroke-linecap", "round");
      line.setAttribute("opacity", "0.6");
      line.dataset.corIdx = String(i);
      line.style.stroke = gc;
      line.style.setProperty("--gc", gc);
      svg.appendChild(line);
      const len = line.getTotalLength();
      // 線の上に♡を3つ散らす（中央を大きく）＝“つながり”を可愛く
      const hearts: SVGTextElement[] = [];
      [0.3, 0.5, 0.7].forEach((tt, hi) => {
        const pt = line.getPointAtLength(len * tt);
        const heart = document.createElementNS(SVGNS, "text");
        heart.setAttribute("x", String(pt.x));
        heart.setAttribute("y", String(pt.y));
        heart.setAttribute("text-anchor", "middle");
        heart.setAttribute("dominant-baseline", "central");
        heart.setAttribute("font-size", hi === 1 ? "15" : "10");
        heart.setAttribute("class", "cor-heart");
        heart.dataset.corIdx = String(i);
        heart.style.fill = gc;
        heart.style.setProperty("--gc", gc);
        heart.textContent = "♡";
        svg.appendChild(heart);
        hearts.push(heart);
      });
      if (animate) {
        line.style.strokeDasharray = String(len);
        line.style.strokeDashoffset = String(len);
        line.style.transition = `stroke-dashoffset .85s cubic-bezier(.4,0,.2,1) ${(0.1 + i * 0.07).toFixed(2)}s`;
        hearts.forEach((h, hi) => { h.style.opacity = "0"; h.style.transition = `opacity .4s ease ${(0.45 + i * 0.07 + hi * 0.06).toFixed(2)}s`; });
        requestAnimationFrame(() => requestAnimationFrame(() => {
          line.style.strokeDashoffset = "0";
          hearts.forEach((h) => { h.style.opacity = "0.9"; });
        }));
      }
    });
    if (animate) corAnimated = true;
  }
  // ホバー/フォーカスで“その人との絆だけ”を光らせ、他を沈める
  const corEl = document.getElementById("cor");
  if (corEl) {
    const svgEl = document.getElementById("corSvg");
    const light = (idx: string, on: boolean) => {
      if (!svgEl) return;
      corEl.classList.toggle("focus-on", on);
      svgEl.querySelectorAll(`[data-cor-idx="${idx}"]`).forEach((el) => el.classList.toggle("lit", on));
    };
    const onEnter = (e: Event) => { const n = (e.target as HTMLElement).closest(".cor-node") as HTMLElement | null; if (n && n.dataset.corIdx != null) light(n.dataset.corIdx, true); };
    const onLeave = (e: Event) => { const n = (e.target as HTMLElement).closest(".cor-node") as HTMLElement | null; if (n && n.dataset.corIdx != null) light(n.dataset.corIdx, false); };
    corEl.addEventListener("mouseover", onEnter);
    corEl.addEventListener("mouseout", onLeave);
    corEl.addEventListener("focusin", onEnter);
    corEl.addEventListener("focusout", onLeave);
    // 相関図が画面に入ったら線アニメを発火（一度だけ）
    if ("IntersectionObserver" in window) {
      const io = new IntersectionObserver((es) => es.forEach((en) => { if (en.isIntersecting) { corVisible = true; drawCor(); io.disconnect(); } }), { threshold: 0.15 });
      io.observe(corEl);
    } else { corVisible = true; }
  }
  let t: number | undefined;
  const schedule = () => { window.clearTimeout(t); t = window.setTimeout(drawCor, 120); };
  window.addEventListener("load", () => { drawCor(); window.setTimeout(drawCor, 350); });
  window.addEventListener("resize", schedule);
  if (document.fonts && document.fonts.ready) document.fonts.ready.then(drawCor);
  drawCor();
</script>
