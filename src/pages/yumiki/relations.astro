  .unit-chip--leader:hover::after { transform: translateX(130%); }
  @media (prefers-reduced-motion: reduce) { .unit-chip:hover { transform: none; } .unit-chip--leader::after { display: none; } }

  /* 表紙＝相関図のヒーローに格上げ（外グロー＋内オーラ＋大見出し＋縁の輪） */
