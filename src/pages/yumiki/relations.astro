---
import Yumiki from "../../layouts/Yumiki.astro";
import { unit, relations } from "../../data/yumiki.ts";
const { generations, groups } = relations;
const initial = (name: string) => name.replace(/[\s　]/g, "").charAt(0);
---
<Yumiki title="つながり — YUMIKI WORLD">
  <section class="y-section">
    <div class="y-container">
      <div class="y-head y-reveal">
        <span class="y-eyebrow">Connections</span>
        <h2>🤝 弓木さんの<span class="wave">つながり</span></h2>
        <p class="rel-intro">同じグループの仲間から、番組でお世話になっている方々まで。弓木さんを中心にした“つながりの地図”です。</p>
        <p class="rel-hint"><span class="rel-hint-dot" aria-hidden="true">♡</span> マークのついた人は、<b>タップでエピソード</b>が見られます</p>
      </div>

      <!-- 軍団 首ンセス -->
      <article class="unit y-reveal">
        <span class="unit-deco" aria-hidden="true">♛</span>
        <div class="unit-head">
          <span class="unit-badge">弓木 奈於 率いる軍団</span>
          <h3 class="unit-name">{unit.name}<small>（{unit.reading}）</small></h3>
          <p class="unit-meta">{unit.formed} 結成 ／ {unit.song}</p>
          <p class="unit-origin">{unit.origin}</p>
        </div>
      </article>

      <!-- 相関図 -->
      <div class="rel-map">
        <div class="rel-hub y-reveal">
          <div class="rel-hub-photo"><img src="/assets/yumiki/yumiki-main.jpg" alt="弓木奈於さん" loading="lazy" onerror="this.src='/assets/yumiki/nao_main.jpg'" /></div>
          <span class="rel-hub-name">弓木 奈於</span>
          <span class="rel-hub-sub">を中心としたつながり</span>
        </div>

        <h3 class="rel-sec-title y-reveal">同じ時代を生きる乃木坂46の仲間</h3>
        <div class="gen-grid">
          {generations.map((g, gi) => (
            <div class="cluster y-reveal" style={`--gc:${g.color}`} data-delay={(gi % 2) + 1}>
              <h4 class="cluster-title">{g.gen}<small>現役 {g.members.length}名</small></h4>
              <div class="nodes">
                {g.members.map((m) => (
                  m.bond ? (
                    <button class="node node--link" data-name={m.name} data-sub={g.gen} data-note={m.bond} style={`--gc:${g.color}`}>
                      <span class="node-av">{initial(m.name)}<span class="node-badge" aria-hidden="true">♡</span></span>
                      <span class="node-name">{m.name}</span>
                    </button>
                  ) : (
                    <span class="node">
                      <span class="node-av node-av--plain" style={`--gc:${g.color}`}>{initial(m.name)}</span>
                      <span class="node-name">{m.name}</span>
                    </span>
                  )
                ))}
              </div>
            </div>
          ))}
        </div>

        <h3 class="rel-sec-title y-reveal">弓木さんを支える、まわりの人々</h3>
        <div class="grp-grid">
          {groups.map((g, gi) => (
            <div class="cluster y-reveal" style={`--gc:${g.color}`} data-delay={(gi % 3) + 1}>
              <h4 class="cluster-title cluster-title--sm">{g.group}</h4>
              <div class="nodes">
                {g.people.map((p) => (
                  p.note ? (
                    <button class="node node--link" data-name={p.name} data-sub={p.role} data-note={p.note} style={`--gc:${g.color}`}>
                      <span class="node-av">{initial(p.name)}<span class="node-badge" aria-hidden="true">♡</span></span>
                      <span class="node-name">{p.name}</span>
                    </button>
                  ) : (
                    <span class="node">
                      <span class="node-av node-av--plain" style={`--gc:${g.color}`}>{initial(p.name)}</span>
                      <span class="node-name">{p.name}</span>
                    </span>
                  )
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <p class="rel-foot y-reveal">※ メンバー在籍は2026年6月時点。番組での共演など、公開されている情報をもとにファンが作成したものです。</p>
    </div>
  </section>

  <!-- メンバー詳細ポップアップ -->
  <div id="ymem" class="ymem" aria-hidden="true" role="dialog" aria-modal="true">
    <button class="ymem-x" aria-label="閉じる">✕</button>
    <div class="ymem-card" role="document">
      <span class="ymem-av" id="ymemAv"></span>
      <h3 class="ymem-name" id="ymemName"></h3>
      <span class="ymem-sub" id="ymemSub"></span>
      <p class="ymem-note" id="ymemNote"></p>
    </div>
  </div>
</Yumiki>

<style>
  .rel-intro { margin-top: 0.9rem; color: var(--y-ink-soft); font-size: 0.95rem; max-width: 48ch; margin-inline: auto; line-height: 1.8; }
  .rel-hint { margin-top: 0.7rem; font-size: 0.82rem; color: var(--y-ink-soft); background: #fff; border: 1.5px dashed var(--y-line); border-radius: 999px; padding: 0.4rem 1rem; display: inline-block; }
  .rel-hint-dot { color: var(--y-peach); }

  /* 軍団 首ンセス */
  .unit { position: relative; overflow: hidden; margin-bottom: clamp(2.4rem, 7vw, 4rem); border: 2px dashed var(--y-line); border-radius: var(--y-radius);
    padding: clamp(1.6rem, 5vw, 2.6rem); box-shadow: var(--y-shadow-sm); text-align: center;
    background: linear-gradient(150deg, color-mix(in srgb, var(--y-lav) 20%, #fff), color-mix(in srgb, var(--y-sky) 18%, #fff)); }
  .unit-deco { position: absolute; top: -1rem; right: 0.4rem; font-size: 6rem; color: var(--y-butter); opacity: 0.35; pointer-events: none; }
  .unit-head { position: relative; z-index: 1; }
  .unit-badge { display: inline-block; font-weight: 700; font-size: 0.74rem; color: #fff; background: var(--y-peach); padding: 0.32rem 0.95rem; border-radius: 999px; }
  .unit-name { font-size: clamp(1.8rem, 6vw, 2.6rem); margin: 0.6rem 0 0.3rem; }
  .unit-name small { font-size: 0.42em; color: var(--y-muted); font-weight: 500; }
  .unit-meta { font-family: var(--y-font-en); font-weight: 700; font-size: 0.82rem; color: var(--y-peach); }
  .unit-origin { color: var(--y-ink-soft); font-size: 0.9rem; max-width: 52ch; margin: 0.8rem auto 0; line-height: 1.85; }

  /* 中心ハブ */
  .rel-map { position: relative; }
  .rel-hub { position: relative; z-index: 2; width: fit-content; margin: 0 auto; display: flex; flex-direction: column; align-items: center; text-align: center;
    background: #fff; border: 3px solid var(--y-peach); border-radius: var(--y-radius); padding: 1.2rem 2.2rem 1.3rem; box-shadow: var(--y-shadow); }
  .rel-hub::after { content: ""; position: absolute; left: 50%; bottom: -2.4rem; transform: translateX(-50%); width: 3px; height: 2.4rem;
    background: repeating-linear-gradient(var(--y-peach) 0 6px, transparent 6px 11px); }
  .rel-hub-photo { width: 90px; height: 90px; border-radius: 50%; overflow: hidden; border: 3px solid var(--y-pink); margin-bottom: 0.6rem; box-shadow: var(--y-shadow-sm); }
  .rel-hub-photo img { width: 100%; height: 100%; object-fit: cover; object-position: center top; }
  .rel-hub-name { font-size: 1.4rem; font-weight: 700; }
  .rel-hub-sub { font-size: 0.82rem; color: var(--y-ink-soft); }

  .rel-sec-title { text-align: center; font-size: 1.1rem; margin: clamp(2.4rem, 6vw, 3.2rem) 0 1.4rem; }
  .rel-sec-title::before { content: "♡"; color: var(--y-peach); margin-right: 0.4rem; }

  /* クラスター共通 */
  .gen-grid, .grp-grid { display: grid; gap: clamp(1.1rem, 3vw, 1.6rem); grid-template-columns: 1fr; }
  @media (min-width: 720px) { .gen-grid { grid-template-columns: repeat(2, 1fr); } .grp-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1040px) { .grp-grid { grid-template-columns: repeat(4, 1fr); } }
  .cluster { position: relative; border-radius: var(--y-radius); padding: 1.5rem 1.1rem 1.3rem;
    background: color-mix(in srgb, var(--gc) 11%, #fff); border: 1.5px solid color-mix(in srgb, var(--gc) 28%, #fff); }
  .cluster::before { content: "♡"; position: absolute; top: -13px; left: 50%; transform: translateX(-50%); width: 26px; height: 26px; display: grid; place-items: center;
    border-radius: 50%; background: var(--gc); color: #fff; font-size: 0.78rem; box-shadow: var(--y-shadow-sm); }
  .cluster-title { font-size: 1.12rem; margin-bottom: 1rem; text-align: center; display: flex; align-items: baseline; justify-content: center; gap: 0.5rem; }
  .cluster-title--sm { font-size: 0.98rem; line-height: 1.4; }
  .cluster-title small { font-size: 0.7rem; font-weight: 500; color: var(--y-ink-soft); }

  /* メンバーノード（アバター＋名前） */
  .nodes { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.7rem 0.55rem; }
  .node { display: flex; flex-direction: column; align-items: center; gap: 0.3rem; width: 4.7rem; padding: 0; border: none; background: none; }
  .node-av { position: relative; width: 50px; height: 50px; border-radius: 50%; display: grid; place-items: center; font-weight: 700; font-size: 1.15rem; color: #fff;
    background: var(--gc); box-shadow: var(--y-shadow-sm); }
  .node-av--plain { background: color-mix(in srgb, var(--gc) 40%, #fff); color: color-mix(in srgb, var(--y-ink) 70%, var(--gc)); }
  .node-name { font-size: 0.74rem; font-weight: 700; color: var(--y-ink); line-height: 1.3; text-align: center; }
  .node-badge { position: absolute; right: -3px; bottom: -3px; width: 19px; height: 19px; border-radius: 50%; background: #fff; color: var(--y-peach); font-size: 0.62rem; display: grid; place-items: center; box-shadow: var(--y-shadow-sm); }
  /* クリックできる人＝立体的に・押せる合図 */
  .node--link { cursor: pointer; transition: transform .25s var(--y-ease); }
  .node--link .node-av { box-shadow: 0 6px 16px color-mix(in srgb, var(--gc) 50%, transparent); outline: 2px solid #fff; outline-offset: 2px; }
  .node--link:hover { transform: translateY(-4px); }
  .node--link:hover .node-name { color: var(--y-peach); }
  .node--link:focus-visible { outline: 3px solid var(--y-peach); outline-offset: 3px; border-radius: 12px; }

  .rel-foot { text-align: center; color: var(--y-muted); font-size: 0.74rem; margin-top: clamp(2rem, 6vw, 3rem); }

  /* メンバー詳細ポップアップ */
  .ymem { position: fixed; inset: 0; z-index: 1000; display: none; place-items: center; padding: 1.2rem;
    background: color-mix(in srgb, var(--y-ink) 45%, transparent); backdrop-filter: blur(4px); }
  .ymem.open { display: grid; }
  .ymem-card { position: relative; background: #fff; border-radius: var(--y-radius); padding: 2rem 1.6rem 1.8rem; max-width: 380px; width: 100%; text-align: center;
    box-shadow: var(--y-shadow); border: 3px solid var(--y-pink); animation: ymem-pop .3s var(--y-ease); }
  @keyframes ymem-pop { from { transform: scale(.9); opacity: 0; } to { transform: scale(1); opacity: 1; } }
  .ymem-av { width: 72px; height: 72px; border-radius: 50%; display: grid; place-items: center; font-weight: 700; font-size: 1.8rem; color: #fff; margin: 0 auto 0.8rem; box-shadow: var(--y-shadow-sm); }
  .ymem-name { font-size: 1.4rem; margin-bottom: 0.3rem; }
  .ymem-sub { display: inline-block; font-size: 0.7rem; font-weight: 700; color: var(--y-ink); background: var(--y-cream-2); padding: 0.2rem 0.7rem; border-radius: 999px; }
  .ymem-note { margin-top: 1rem; color: var(--y-ink-soft); font-size: 0.92rem; line-height: 1.9; }
  .ymem-x { position: fixed; top: clamp(1rem, 4vw, 2rem); right: clamp(1rem, 4vw, 2rem); width: 46px; height: 46px; border-radius: 50%; background: #fff; color: var(--y-ink); font-size: 1.2rem; box-shadow: var(--y-shadow); display: grid; place-items: center; }

  @media (prefers-reduced-motion: reduce) { .ymem-card { animation: none; } }
</style>

<script>
  const modal = document.getElementById("ymem");
  if (modal) {
    const av = document.getElementById("ymemAv")!;
    const nm = document.getElementById("ymemName")!;
    const sub = document.getElementById("ymemSub")!;
    const note = document.getElementById("ymemNote")!;
    const open = (btn: HTMLElement) => {
      const name = btn.dataset.name || "";
      const gc = btn.style.getPropertyValue("--gc") || "var(--y-peach)";
      av.textContent = name.replace(/[\s　]/g, "").charAt(0);
      (av as HTMLElement).style.background = gc;
      nm.textContent = name;
      sub.textContent = btn.dataset.sub || "";
      note.textContent = btn.dataset.note || "";
      modal.classList.add("open");
      modal.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
    };
    const close = () => {
      modal.classList.remove("open");
      modal.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
    };
    document.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest(".node--link") as HTMLElement | null;
      if (btn) { open(btn); return; }
      if (e.target === modal || (e.target as HTMLElement).classList.contains("ymem-x")) close();
    });
    document.addEventListener("keydown", (e) => { if (e.key === "Escape") close(); });
  }
</script>
