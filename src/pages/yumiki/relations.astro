  @media (prefers-reduced-motion: reduce) { .cor-legend { transform: none; } }

  /* 世代/グループのクラスター＝シール帳の台紙（ドット）に */
  .cluster--sb { background-image: radial-gradient(circle, color-mix(in srgb, var(--gc) 28%, transparent) 1.5px, transparent 1.6px);
    background-size: 15px 15px; background-position: 7px 7px; }

  /* 軍団チップ＝ミニ・トレカ（ぷるん／軍団長はホロのきらめき） */
  .unit-chip { transition: transform .3s var(--y-ease), box-shadow .3s var(--y-ease); }
