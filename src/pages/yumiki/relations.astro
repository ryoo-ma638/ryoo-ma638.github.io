---
import Yumiki from "../../layouts/Yumiki.astro";
import { unit, relations } from "../../data/yumiki.ts";
const { keyBonds, generations, groups } = relations;
const initial = (name: string) => name.replace(/[\s　]/g, "").charAt(0);
---
<Yumiki title="つながり — YUMIKI WORLD">
  <section class="y-section">
    <div class="y-container">
      <div class="y-head y-reveal">
        <span class="y-eyebrow">Connections</span>
        <h2>🤝 弓木さんの<span class="wave">つながり</span></h2>
        <p class="rel-intro">同期との2人旅、軍団、慕う後輩、お世話になった先輩、高校の同級生、番組での共演まで。弓木さんを中心に、人とのつながりを“相関図”にしてみました。</p>
        <p class="rel-hint"><span class="rel-hint-dot" aria-hidden="true">♡</span> マークのついた人は <b>タップでエピソード</b> が読めます</p>
      </div>

      <!-- 軍団 首ンセス -->
      <article class="unit y-reveal">
        <span class="unit-deco" aria-hidden="true">♛</span>
        <div class="unit-head">
          <span class="unit-badge">弓木 奈於 率いる軍団</span>
          <h3 class="unit-name">{unit.name}<small>（{unit.reading}）</small></h3>
          <p class="unit-meta">{unit.formed} 結成 ／ {unit.song}</p>
          <p class="unit-origin">{unit.origin}</p>
          <div class="unit-members">
            <span class="unit-chip unit-chip--leader">👑 {unit.leader.name}<small>軍団長・{unit.leader.gen}</small></span>
            {unit.members.map((m) => (
              <span class="unit-chip">{m.name}<small>{m.gen}</small></span>
            ))}
          </div>
        </div>
      </article>

      <!-- ★ 中心相関図（縁の深い人を線でつなぐ） -->
      <h3 class="rel-sec-title y-reveal">弓木さんと、特に縁の深い人たち</h3>
      <div class="cor-legend y-reveal">
        <span class="cor-leg" style="--gc:var(--y-pink)"><i></i>同期</span>
        <span class="cor-leg" style="--gc:var(--y-mint)"><i></i>後輩</span>
        <span class="cor-leg" style="--gc:var(--y-butter)"><i></i>先輩</span>
        <span class="cor-leg" style="--gc:var(--y-lav)"><i></i>高校</span>
      </div>
      <div class="cor y-reveal" id="cor">
        <svg class="cor-svg" id="corSvg" aria-hidden="true" preserveAspectRatio="none"></svg>
        <div class="cor-grid">
          {keyBonds.slice(0, 3).map((p) => (
            <button class="cor-node node--link" data-name={p.name} data-sub={p.cat} data-rel={p.rel} data-note={p.note} style={`--gc:${p.color}`}>
              <span class="cor-rel">{p.rel}</span>
              <span class="cor-av">{initial(p.name)}</span>
              <span class="cor-nm">{p.name}</span>
            </button>
          ))}
          {keyBonds.slice(3, 4).map((p) => (
            <button class="cor-node node--link" data-name={p.name} data-sub={p.cat} data-rel={p.rel} data-note={p.note} style={`--gc:${p.color}`}>
              <span class="cor-rel">{p.rel}</span>
              <span class="cor-av">{initial(p.name)}</span>
              <span class="cor-nm">{p.name}</span>
            </button>
          ))}

          <div class="cor-hub" id="corHub">
            <img src="/assets/yumiki/yumiki-main.jpg" alt="弓木奈於さん" loading="lazy" onerror="this.src='/assets/yumiki/yumiki-main.png'" />
            <b>弓木 奈於</b>
            <small>ゆみっきー</small>
          </div>

          {keyBonds.slice(4, 8).map((p) => (
            <button class="cor-node node--link" data-name={p.name} data-sub={p.cat} data-rel={p.rel} data-note={p.note} style={`--gc:${p.color}`}>
              <span class="cor-rel">{p.rel}</span>
              <span class="cor-av">{initial(p.name)}</span>
              <span class="cor-nm">{p.name}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- 全員ロスター（世代別） -->
      <h3 class="rel-sec-title y-reveal">同じ時代を生きる乃木坂46の仲間（現役メンバー）</h3>
      <div class="gen-grid">
        {generations.map((g, gi) => (
          <div class="cluster y-reveal" style={`--gc:${g.color}`} data-delay={(gi % 2) + 1}>
            <h4 class="cluster-title">{g.gen}<small>現役 {g.members.length}名</small></h4>
            <div class="nodes">
              {g.members.map((m) => (
                m.bond ? (
                  <button class="node node--link" data-name={m.name} data-sub={g.gen} data-rel={m.rel} data-note={m.bond} style={`--gc:${g.color}`}>
                    <span class="node-av">{initial(m.name)}<span class="node-badge" aria-hidden="true">♡</span></span>
                    <span class="node-name">{m.name}</span>
                    {m.rel && <span class="node-rel">{m.rel}</span>}
                  </button>
                ) : (
                  <span class="node">
                    <span class="node-av node-av--plain" style={`--gc:${g.color}`}>{initial(m.name)}</span>
                    <span class="node-name">{m.name}</span>
                  </span>
                )
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- 世代外のつながり -->
      <h3 class="rel-sec-title y-reveal">弓木さんを支える、まわりの人々</h3>
      <div class="grp-grid">
        {groups.map((g, gi) => (
          <div class="cluster y-reveal" style={`--gc:${g.color}`} data-delay={(gi % 2) + 1}>
            <h4 class="cluster-title cluster-title--sm">{g.group}</h4>
            <div class="nodes">
              {g.people.map((p) => (
                p.note ? (
                  <button class="node node--link" data-name={p.name} data-sub={p.role} data-rel={p.rel} data-note={p.note} style={`--gc:${g.color}`}>
                    <span class="node-av">{initial(p.name)}<span class="node-badge" aria-hidden="true">♡</span></span>
                    <span class="node-name">{p.name}</span>
                    {p.rel && <span class="node-rel">{p.rel}</span>}
                  </button>
                ) : (
                  <span class="node">
                    <span class="node-av node-av--plain" style={`--gc:${g.color}`}>{initial(p.name)}</span>
                    <span class="node-name">{p.name}</span>
                  </span>
                )
              ))}
            </div>
          </div>
        ))}
      </div>

      <p class="rel-foot y-reveal">※ メンバー在籍は2026年6月時点。番組での共演・本人やメンバーの発信など、公開されている情報をもとにファンが作成したものです。</p>
    </div>
  </section>

  <!-- メンバー詳細ポップアップ -->
  <div id="ymem" class="ymem" aria-hidden="true" role="dialog" aria-modal="true">
    <button class="ymem-x" aria-label="閉じる">✕</button>
    <div class="ymem-card" role="document">
      <span class="ymem-av" id="ymemAv"></span>
      <h3 class="ymem-name" id="ymemName"></h3>
      <span class="ymem-rel" id="ymemRel"></span>
      <span class="ymem-sub" id="ymemSub"></span>
      <p class="ymem-note" id="ymemNote"></p>
    </div>
  </div>
</Yumiki>

<style>
  .rel-intro { margin-top: 0.9rem; color: var(--y-ink-soft); font-size: 0.95rem; max-width: 52ch; margin-inline: auto; line-height: 1.85; }
  .rel-hint { margin-top: 0.7rem; font-size: 0.82rem; color: var(--y-ink-soft); background: #fff; border: 1.5px dashed var(--y-line); border-radius: 999px; padding: 0.4rem 1rem; display: inline-block; }
  .rel-hint-dot { color: var(--y-peach); }

  /* 軍団 首ンセス */
  .unit { position: relative; overflow: hidden; margin-bottom: clamp(2.4rem, 7vw, 4rem); border: 2px dashed var(--y-line); border-radius: var(--y-radius);
    padding: clamp(1.6rem, 5vw, 2.6rem); box-shadow: var(--y-shadow-sm); text-align: center;
    background: linear-gradient(150deg, color-mix(in srgb, var(--y-lav) 20%, #fff), color-mix(in srgb, var(--y-sky) 18%, #fff)); }
  .unit-deco { position: absolute; top: -1rem; right: 0.4rem; font-size: 6rem; color: var(--y-butter); opacity: 0.35; pointer-events: none; }
  .unit-head { position: relative; z-index: 1; }
  .unit-badge { display: inline-block; font-weight: 700; font-size: 0.74rem; color: #fff; background: var(--y-peach); padding: 0.32rem 0.95rem; border-radius: 999px; }
  .unit-name { font-size: clamp(1.8rem, 6vw, 2.6rem); margin: 0.6rem 0 0.3rem; }
  .unit-name small { font-size: 0.42em; color: var(--y-muted); font-weight: 500; }
  .unit-meta { font-family: var(--y-font-en); font-weight: 700; font-size: 0.82rem; color: var(--y-peach); }
  .unit-origin { color: var(--y-ink-soft); font-size: 0.9rem; max-width: 56ch; margin: 0.8rem auto 0; line-height: 1.85; }
  .unit-members { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.5rem; margin-top: 1.2rem; }
  .unit-chip { display: inline-flex; flex-direction: column; align-items: center; line-height: 1.25; font-weight: 700; font-size: 0.9rem; color: var(--y-ink);
    background: #fff; border: 1.5px solid var(--y-line); border-radius: 14px; padding: 0.45rem 0.9rem; box-shadow: var(--y-shadow-sm); }
  .unit-chip small { font-size: 0.62rem; font-weight: 500; color: var(--y-muted); margin-top: 2px; }
  .unit-chip--leader { background: color-mix(in srgb, var(--y-butter) 30%, #fff); border-color: color-mix(in srgb, var(--y-peach) 40%, #fff); }

  .rel-sec-title { text-align: center; font-size: 1.12rem; margin: clamp(2.4rem, 6vw, 3.4rem) 0 1.4rem; }
  .rel-sec-title::before { content: "♡"; color: var(--y-peach); margin-right: 0.4rem; }

  /* 色の凡例 */
  .cor-legend { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.45rem 0.9rem; margin: -0.4rem auto 1.2rem; }
  .cor-leg { display: inline-flex; align-items: center; gap: 0.35rem; font-size: 0.76rem; font-weight: 700; color: var(--y-ink-soft); }
  .cor-leg i { width: 13px; height: 13px; border-radius: 50%; background: var(--gc); box-shadow: var(--y-shadow-sm); }

  /* ===== 中心相関図 ===== */
  .cor { position: relative; max-width: 780px; margin: 0 auto clamp(1rem, 4vw, 2rem); }
  .cor-svg { position: absolute; inset: 0; width: 100%; height: 100%; z-index: 0; pointer-events: none; overflow: visible; }
  .cor-grid { position: relative; z-index: 1; display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(0.8rem, 3vw, 1.7rem); align-items: stretch; }

  .cor-hub { display: grid; place-content: center; justify-items: center; gap: 0.2rem; text-align: center;
    background: #fff; border: 3px solid var(--y-peach); border-radius: var(--y-radius); padding: 0.7rem 0.5rem; box-shadow: var(--y-shadow); }
  .cor-hub img { width: clamp(56px, 13vw, 84px); height: clamp(56px, 13vw, 84px); border-radius: 50%; object-fit: cover; object-position: center top; border: 2px solid var(--y-pink); }
  .cor-hub b { font-size: clamp(0.82rem, 2.3vw, 1.05rem); margin-top: 0.3rem; }
  .cor-hub small { font-size: 0.64rem; color: var(--y-muted); font-family: var(--y-font-en); font-weight: 700; }

  .cor-node { display: flex; flex-direction: column; align-items: center; gap: 0.32rem; padding: 0.7rem 0.4rem 0.8rem; cursor: pointer;
    background: color-mix(in srgb, var(--gc) 13%, #fff); border: 1.5px solid color-mix(in srgb, var(--gc) 34%, #fff); border-radius: 16px;
    box-shadow: var(--y-shadow-sm); transition: transform 0.25s var(--y-ease), box-shadow 0.25s var(--y-ease); }
  .cor-node:hover { transform: translateY(-4px); box-shadow: var(--y-shadow); }
  .cor-node:focus-visible { outline: 3px solid var(--y-peach); outline-offset: 3px; }
  .cor-rel { font-size: 0.6rem; font-weight: 700; color: #fff; background: var(--gc); padding: 0.14rem 0.5rem; border-radius: 999px; line-height: 1.4; }
  .cor-av { width: clamp(38px, 10vw, 50px); height: clamp(38px, 10vw, 50px); border-radius: 50%; display: grid; place-items: center; font-weight: 700; color: #fff;
    background: var(--gc); font-size: 1.05rem; box-shadow: 0 5px 14px color-mix(in srgb, var(--gc) 50%, transparent); outline: 2px solid #fff; outline-offset: 2px; }
  .cor-nm { font-size: 0.74rem; font-weight: 700; text-align: center; line-height: 1.3; }

  @media (max-width: 700px) {
    .cor-svg { display: none; }
    .cor-grid { grid-template-columns: repeat(2, 1fr); gap: 0.7rem; }
    .cor-hub { grid-column: 1 / -1; order: -1; flex-direction: row; }
    .cor-hub { display: flex; align-items: center; gap: 0.7rem; justify-content: center; }
    .cor-hub img { width: 56px; height: 56px; }
    .cor-hub b { margin-top: 0; }
  }

  /* クラスター共通 */
  .gen-grid, .grp-grid { display: grid; gap: clamp(1.1rem, 3vw, 1.6rem); grid-template-columns: 1fr; }
  @media (min-width: 720px) { .gen-grid { grid-template-columns: repeat(2, 1fr); } .grp-grid { grid-template-columns: repeat(2, 1fr); } }
  .cluster { position: relative; border-radius: var(--y-radius); padding: 1.5rem 1.1rem 1.3rem;
    background: color-mix(in srgb, var(--gc) 11%, #fff); border: 1.5px solid color-mix(in srgb, var(--gc) 28%, #fff); }
  .cluster::before { content: "♡"; position: absolute; top: -13px; left: 50%; transform: translateX(-50%); width: 26px; height: 26px; display: grid; place-items: center;
    border-radius: 50%; background: var(--gc); color: #fff; font-size: 0.78rem; box-shadow: var(--y-shadow-sm); }
  .cluster-title { font-size: 1.12rem; margin-bottom: 1.1rem; text-align: center; display: flex; align-items: baseline; justify-content: center; gap: 0.5rem; }
  .cluster-title--sm { font-size: 0.98rem; line-height: 1.4; }
  .cluster-title small { font-size: 0.7rem; font-weight: 500; color: var(--y-ink-soft); }

  /* メンバーノード（アバター＋名前＋関係ラベル） */
  .nodes { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.9rem 0.55rem; }
  .node { display: flex; flex-direction: column; align-items: center; gap: 0.3rem; width: 5.1rem; padding: 0; border: none; background: none; }
  .node-av { position: relative; width: 50px; height: 50px; border-radius: 50%; display: grid; place-items: center; font-weight: 700; font-size: 1.15rem; color: #fff;
    background: var(--gc); box-shadow: var(--y-shadow-sm); }
  .node-av--plain { background: color-mix(in srgb, var(--gc) 40%, #fff); color: color-mix(in srgb, var(--y-ink) 70%, var(--gc)); }
  .node-name { font-size: 0.74rem; font-weight: 700; color: var(--y-ink); line-height: 1.3; text-align: center; }
  .node-rel { font-size: 0.58rem; font-weight: 700; color: color-mix(in srgb, var(--y-ink) 55%, var(--gc)); background: color-mix(in srgb, var(--gc) 18%, #fff);
    border-radius: 999px; padding: 0.08rem 0.42rem; line-height: 1.35; text-align: center; }
  .node-badge { position: absolute; right: -3px; bottom: -3px; width: 19px; height: 19px; border-radius: 50%; background: #fff; color: var(--y-peach); font-size: 0.62rem; display: grid; place-items: center; box-shadow: var(--y-shadow-sm); }
  /* クリックできる人＝立体的に・押せる合図 */
  .node--link { cursor: pointer; transition: transform .25s var(--y-ease); }
  .node--link .node-av { box-shadow: 0 6px 16px color-mix(in srgb, var(--gc) 50%, transparent); outline: 2px solid #fff; outline-offset: 2px; }
  .node--link:hover { transform: translateY(-4px); }
  .node--link:hover .node-name { color: var(--y-peach); }
  .node--link:focus-visible { outline: 3px solid var(--y-peach); outline-offset: 3px; border-radius: 12px; }

  .rel-foot { text-align: center; color: var(--y-muted); font-size: 0.74rem; margin-top: clamp(2rem, 6vw, 3rem); line-height: 1.7; }

  /* メンバー詳細ポップアップ */
  .ymem { position: fixed; inset: 0; z-index: 1000; display: none; place-items: center; padding: 1.2rem;
    background: color-mix(in srgb, var(--y-ink) 45%, transparent); backdrop-filter: blur(4px); }
  .ymem.open { display: grid; }
  .ymem-card { position: relative; background: #fff; border-radius: var(--y-radius); padding: 2rem 1.6rem 1.8rem; max-width: 392px; width: 100%; text-align: center;
    box-shadow: var(--y-shadow); border: 3px solid var(--y-pink); animation: ymem-pop .3s var(--y-ease); }
  @keyframes ymem-pop { from { transform: scale(.9); opacity: 0; } to { transform: scale(1); opacity: 1; } }
  .ymem-av { width: 72px; height: 72px; border-radius: 50%; display: grid; place-items: center; font-weight: 700; font-size: 1.8rem; color: #fff; margin: 0 auto 0.8rem; box-shadow: var(--y-shadow-sm); }
  .ymem-name { font-size: 1.4rem; margin-bottom: 0.5rem; }
  .ymem-rel { display: inline-block; font-size: 0.74rem; font-weight: 700; color: #fff; background: var(--y-peach); padding: 0.22rem 0.8rem; border-radius: 999px; margin: 0 0.25rem 0.4rem; }
  .ymem-rel:empty { display: none; }
  .ymem-sub { display: inline-block; font-size: 0.7rem; font-weight: 700; color: var(--y-ink); background: var(--y-cream-2); padding: 0.2rem 0.7rem; border-radius: 999px; }
  .ymem-sub:empty { display: none; }
  .ymem-note { margin-top: 1rem; color: var(--y-ink-soft); font-size: 0.92rem; line-height: 1.95; text-align: left; }
  .ymem-x { position: fixed; top: clamp(1rem, 4vw, 2rem); right: clamp(1rem, 4vw, 2rem); width: 46px; height: 46px; border-radius: 50%; background: #fff; color: var(--y-ink); font-size: 1.2rem; box-shadow: var(--y-shadow); display: grid; place-items: center; }

  @media (prefers-reduced-motion: reduce) { .ymem-card { animation: none; } }
</style>

<script>
  // ── メンバー詳細モーダル ──
  const modal = document.getElementById("ymem");
  if (modal) {
    const av = document.getElementById("ymemAv")!;
    const nm = document.getElementById("ymemName")!;
    const rel = document.getElementById("ymemRel")!;
    const sub = document.getElementById("ymemSub")!;
    const note = document.getElementById("ymemNote")!;
    const open = (btn: HTMLElement) => {
      const name = btn.dataset.name || "";
      const gc = btn.style.getPropertyValue("--gc") || "var(--y-peach)";
      av.textContent = name.replace(/[\s　]/g, "").charAt(0);
      (av as HTMLElement).style.background = gc;
      nm.textContent = name;
      rel.textContent = btn.dataset.rel || "";
      (rel as HTMLElement).style.background = gc;
      sub.textContent = btn.dataset.sub || "";
      note.textContent = btn.dataset.note || "";
      modal.classList.add("open");
      modal.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
    };
    const close = () => {
      modal.classList.remove("open");
      modal.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
    };
    document.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest(".node--link") as HTMLElement | null;
      if (btn) { open(btn); return; }
      if (e.target === modal || (e.target as HTMLElement).classList.contains("ymem-x")) close();
    });
    document.addEventListener("keydown", (e) => { if (e.key === "Escape") close(); });
  }

  // ── 中心相関図：ハブから各ノードへ“線”をSVGで描く（レスポンシブ再計算） ──
  const SVGNS = "http://www.w3.org/2000/svg";
  // 矩形の中心(cx,cy・幅w/高h)から目標(tx,ty)方向に伸ばした時の、矩形の枠との交点
  function edgePoint(cx: number, cy: number, w: number, h: number, tx: number, ty: number) {
    const dx = tx - cx, dy = ty - cy;
    if (!dx && !dy) return { x: cx, y: cy };
    const sx = dx !== 0 ? (w / 2) / Math.abs(dx) : Infinity;
    const sy = dy !== 0 ? (h / 2) / Math.abs(dy) : Infinity;
    const s = Math.min(sx, sy);
    return { x: cx + dx * s, y: cy + dy * s };
  }
  function drawCor() {
    const cor = document.getElementById("cor");
    const svg = document.getElementById("corSvg");
    const hub = document.getElementById("corHub");
    if (!cor || !svg || !hub) return;
    while (svg.firstChild) svg.removeChild(svg.firstChild);
    // モバイル（SVG非表示）は描かない
    if (getComputedStyle(svg).display === "none") return;
    const cr = cor.getBoundingClientRect();
    svg.setAttribute("viewBox", `0 0 ${cr.width} ${cr.height}`);
    const hb = hub.getBoundingClientRect();
    const hx = hb.left - cr.left + hb.width / 2;
    const hy = hb.top - cr.top + hb.height / 2;
    cor.querySelectorAll<HTMLElement>(".cor-node").forEach((node) => {
      const nb = node.getBoundingClientRect();
      const nx = nb.left - cr.left + nb.width / 2;
      const ny = nb.top - cr.top + nb.height / 2;
      const gc = node.style.getPropertyValue("--gc") || "var(--y-peach)";
      // ハブの枠 → ノードの枠 を結ぶ（カードの間の隙間にだけ線が出るのではっきり見える）
      const p1 = edgePoint(hx, hy, hb.width, hb.height, nx, ny);
      const p2 = edgePoint(nx, ny, nb.width, nb.height, hx, hy);
      const line = document.createElementNS(SVGNS, "line");
      line.setAttribute("x1", String(p1.x));
      line.setAttribute("y1", String(p1.y));
      line.setAttribute("x2", String(p2.x));
      line.setAttribute("y2", String(p2.y));
      line.style.stroke = gc;
      line.setAttribute("stroke-width", "2.6");
      line.setAttribute("stroke-linecap", "round");
      line.setAttribute("stroke-dasharray", "2 6");
      line.setAttribute("opacity", "0.9");
      svg.appendChild(line);
      const heart = document.createElementNS(SVGNS, "text");
      heart.setAttribute("x", String((p1.x + p2.x) / 2));
      heart.setAttribute("y", String((p1.y + p2.y) / 2));
      heart.setAttribute("text-anchor", "middle");
      heart.setAttribute("dominant-baseline", "central");
      heart.setAttribute("font-size", "13");
      heart.style.fill = gc;
      heart.textContent = "♡";
      svg.appendChild(heart);
    });
  }
  let t: number | undefined;
  const schedule = () => { window.clearTimeout(t); t = window.setTimeout(drawCor, 120); };
  window.addEventListener("load", () => { drawCor(); window.setTimeout(drawCor, 350); });
  window.addEventListener("resize", schedule);
  if (document.fonts && document.fonts.ready) document.fonts.ready.then(drawCor);
  drawCor();
</script>
