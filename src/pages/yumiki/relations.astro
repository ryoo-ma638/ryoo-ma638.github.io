---
import Yumiki from "../../layouts/Yumiki.astro";
import Lightbox from "../../components/Lightbox.astro";
import { unit, relations, img } from "../../data/yumiki.ts";
const { keyBonds, generations, groups } = relations;
const initial = (name: string) => name.replace(/[\s　]/g, "").charAt(0);
---
<Yumiki title="つながり — YUMIKI WORLD">
  <section class="y-section rel-page sb-grid">
    <div class="y-container">
      <div class="y-head y-reveal rel-cover sb-taped" style="--tape:var(--y-pink)">
        <span class="rel-cover-glow" aria-hidden="true"></span>
        <span class="sb-tape l" aria-hidden="true"></span>
        <span class="sb-tape r" aria-hidden="true"></span>
        <span class="sb-doodle rel-doodle rel-doodle--a sb-jiggle" aria-hidden="true" style="--cc:var(--y-lav)">✦</span>
        <span class="sb-doodle rel-doodle rel-doodle--b sb-jiggle" aria-hidden="true" style="--cc:var(--y-mint)">♡</span>
        <span class="sb-doodle rel-doodle rel-doodle--c sb-jiggle" aria-hidden="true" style="--cc:var(--y-sky)">✿</span>
        <span class="sb-stamp rel-cover-stamp" style="--cc:var(--y-peach)">♡ Friendship Map</span>
        <span class="y-eyebrow">Connections</span>
        <h1>🤝 弓木さんの<span class="wave">つながり</span></h1>
        <p class="rel-intro">同期との2人旅、軍団、慕う後輩、お世話になった先輩、高校の同級生、番組での共演まで。弓木さんを中心に、人とのつながりを“相関図”にしてみました。</p>
        <p class="rel-hint"><span class="rel-hint-dot" aria-hidden="true">♡</span> マークのついた人は <b>タップでエピソード</b> が読めます</p>
      </div>

      <!-- 軍団 首ンセス -->
      <article class="unit y-reveal" style="--tape:var(--y-butter)">
        <span class="unit-deco" aria-hidden="true">♛</span>
        <span class="unit-crest" aria-hidden="true">♛</span>
        <span class="sb-stamp unit-stamp" style="--cc:var(--y-lav)">♛ Royal Squad</span>
        <div class="unit-head">
          <span class="unit-badge">弓木 奈於 率いる軍団</span>
          <h2 class="unit-name"><span class="sb-mark" style="--cc:var(--y-pink)">{unit.name}</span><small>（{unit.reading}）</small></h2>
          <p class="unit-meta">{unit.formed} 結成 ／ {unit.song}</p>
          <p class="unit-origin">{unit.origin}</p>
          <div class="unit-members">
            <span class="unit-chip unit-chip--leader">👑 {unit.leader.name}<small>軍団長・{unit.leader.gen}</small></span>
            {unit.members.map((m) => (
              <span class="unit-chip">{m.name}<small>{m.gen}</small></span>
            ))}
          </div>
        </div>
        <figure class="sb-cheki sb-taped unit-photo" style="--tape:var(--y-lav)" data-gallery={JSON.stringify([img("kubinsess.jpg")])} data-index="0" data-caption="軍団「首ンセス」" role="button" tabindex="0" aria-label="首ンセスの写真を拡大">
          <span class="sb-tape r" aria-hidden="true"></span>
          <img src={img("kubinsess.jpg")} alt="軍団「首ンセス」の集合写真" loading="lazy" />
          <figcaption>👑 首ンセス・全員集合</figcaption>
        </figure>
        <span class="sb-note unit-note" aria-hidden="true">“首のケアを怠らない”理念がすき</span>
      </article>

      <!-- ★ 中心相関図（縁の深い人を線でつなぐ） -->
      <div class="sb-head rel-head rel-head--1 y-reveal sb-taped" style="--cc:var(--y-pink);--tape:var(--y-pink)">
        <span class="sb-tape l" aria-hidden="true"></span>
        <span class="sb-num sb-head-num" style="--cc:var(--y-pink)">01</span>
        <span class="sb-head-tt">
          <span class="sb-head-eyebrow">Closest bonds</span>
          <h2 class="rel-head-h">弓木さんと、特に縁の深い人たち</h2>
        </span>
        <span class="sb-doodle rel-head-doodle" aria-hidden="true" style="--cc:var(--y-butter)">✿</span>
      </div>
      <div class="cor-legend-wrap y-reveal">
        <div class="sb-sticky cor-legend" style="--cc:var(--y-mint)">
          <span class="cor-legend-ttl" aria-hidden="true">✐ いろ＝関係</span>
          <span class="cor-leg" style="--gc:var(--y-pink)"><i></i>同期</span>
          <span class="cor-leg" style="--gc:var(--y-mint)"><i></i>後輩</span>
          <span class="cor-leg" style="--gc:var(--y-butter)"><i></i>先輩</span>
          <span class="cor-leg" style="--gc:var(--y-lav)"><i></i>高校</span>
          <span class="cor-legend-hint">♡ の線でつながってる人＝とくに縁が深い人。タップでエピソード！</span>
        </div>
      </div>
      <div class="cor y-reveal" id="cor">
        <svg class="cor-svg" id="corSvg" aria-hidden="true" preserveAspectRatio="none"></svg>
        <div class="cor-grid">
          {keyBonds.slice(0, 3).map((p) => (
            <button class="cor-node node--link" data-name={p.name} data-sub={p.cat} data-rel={p.rel} data-note={p.note} style={`--gc:${p.color}`}>
              <span class="cor-rel">{p.rel}</span>
              <span class="cor-av" aria-hidden="true">{initial(p.name)}</span>
              <span class="cor-nm">{p.name}</span>
            </button>
          ))}
          {keyBonds.slice(3, 4).map((p) => (
            <button class="cor-node node--link" data-name={p.name} data-sub={p.cat} data-rel={p.rel} data-note={p.note} style={`--gc:${p.color}`}>
              <span class="cor-rel">{p.rel}</span>
              <span class="cor-av" aria-hidden="true">{initial(p.name)}</span>
              <span class="cor-nm">{p.name}</span>
            </button>
          ))}

          <div class="cor-hub" id="corHub">
            <span class="cor-hub-halo" aria-hidden="true"></span>
            <span class="cor-hub-crown" aria-hidden="true">♛</span>
            <span class="cor-hub-photo">
              <span class="cor-hub-ring" aria-hidden="true"></span>
              <img src={img("arsha/42.jpg")} alt="弓木奈於さん" loading="lazy" onerror="this.src='/assets/yumiki/arsha/42.jpg'" />
            </span>
            <b>弓木 奈於</b>
            <small>ゆみっきー</small>
            <span class="cor-hub-tag" aria-hidden="true">♡ MY OSHI</span>
            <span class="cor-hub-spark s1" aria-hidden="true">✦</span>
            <span class="cor-hub-spark s2" aria-hidden="true">♡</span>
            <span class="cor-hub-spark s3" aria-hidden="true">✿</span>
          </div>

          {keyBonds.slice(4, 8).map((p) => (
            <button class="cor-node node--link" data-name={p.name} data-sub={p.cat} data-rel={p.rel} data-note={p.note} style={`--gc:${p.color}`}>
              <span class="cor-rel">{p.rel}</span>
              <span class="cor-av" aria-hidden="true">{initial(p.name)}</span>
              <span class="cor-nm">{p.name}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- 全員ロスター（世代別） -->
      <div class="sb-head rel-head rel-head--2 y-reveal sb-taped" style="--cc:var(--y-sky);--tape:var(--y-sky)">
        <span class="sb-tape r" aria-hidden="true"></span>
        <span class="sb-num sb-head-num" style="--cc:var(--y-sky)">02</span>
        <span class="sb-head-tt">
          <span class="sb-head-eyebrow">Roster by generation</span>
          <h2 class="rel-head-h rel-head-h--sm">同じ時代を生きる乃木坂46の仲間（現役メンバー）</h2>
        </span>
        <span class="sb-doodle rel-head-doodle" aria-hidden="true" style="--cc:var(--y-mint)">✦</span>
      </div>
      <div class="gen-grid">
        {generations.map((g, gi) => {
          const active = g.members.filter((m) => !m.grad);
          const grads = g.members.filter((m) => m.grad);
          return (
          <div class={`cluster cluster--sb y-reveal cl-tilt-${gi % 3}`} style={`--gc:${g.color}`} data-delay={(gi % 2) + 1}>
            <span class="sb-doodle cluster-doodle" aria-hidden="true">♡</span>
            <h4 class="cluster-title">{g.gen}<small>現役 {active.length}名{grads.length ? `・卒業 ${grads.length}名` : ""}</small></h4>
            <div class="nodes">
              {active.map((m) => (
                m.bond ? (
                  <button class="node node--link" data-name={m.name} data-sub={g.gen} data-rel={m.rel} data-note={m.bond} style={`--gc:${g.color}`}>
                    <span class="node-av" aria-hidden="true">{initial(m.name)}<span class="node-badge">♡</span></span>
                    <span class="node-name">{m.name}</span>
                    {m.rel && <span class="node-rel">{m.rel}</span>}
                  </button>
                ) : (
                  <span class="node">
                    <span class="node-av node-av--plain" style={`--gc:${g.color}`} aria-hidden="true">{initial(m.name)}</span>
                    <span class="node-name">{m.name}</span>
                  </span>
                )
              ))}
            </div>
            {grads.length > 0 && (
              <>
                <p class="cluster-grad-label">卒業メンバー</p>
                <div class="nodes nodes--grad">
                  {grads.map((m) => (
                    <button class="node node--link node--grad" data-name={m.name} data-sub={`${g.gen}・${m.grad}`} data-rel={m.rel} data-note={m.bond} style={`--gc:${g.color}`}>
                      <span class="node-av node-av--grad" aria-hidden="true">{initial(m.name)}<span class="node-badge node-badge--grad">卒</span></span>
                      <span class="node-name">{m.name}</span>
                      <span class="node-rel node-rel--grad">{m.grad}</span>
                    </button>
                  ))}
                </div>
              </>
            )}
          </div>
          );
        })}
      </div>

      <!-- 世代外のつながり -->
      <div class="sb-head rel-head rel-head--3 y-reveal sb-taped" style="--cc:var(--y-lav);--tape:var(--y-lav)">
        <span class="sb-tape l" aria-hidden="true"></span>
        <span class="sb-num sb-head-num" style="--cc:var(--y-lav)">03</span>
        <span class="sb-head-tt">
          <span class="sb-head-eyebrow">Around her</span>
          <h2 class="rel-head-h rel-head-h--sm">弓木さんを支える、まわりの人々</h2>
        </span>
        <span class="sb-note rel-head-note" aria-hidden="true">先輩・同級生・番組のみなさん</span>
      </div>
      <div class="grp-grid">
        {groups.map((g, gi) => (
          <div class={`cluster cluster--sb y-reveal cl-tilt-${(gi + 1) % 3}`} style={`--gc:${g.color}`} data-delay={(gi % 2) + 1}>
            <span class="sb-stamp cluster-stamp" aria-hidden="true">♢ Friends</span>
            <h4 class="cluster-title cluster-title--sm">{g.group}</h4>
            <div class="nodes">
              {g.people.map((p) => (
                p.note ? (
                  <button class="node node--link" data-name={p.name} data-sub={p.role} data-rel={p.rel} data-note={p.note} style={`--gc:${g.color}`}>
                    <span class="node-av" aria-hidden="true">{initial(p.name)}<span class="node-badge">♡</span></span>
                    <span class="node-name">{p.name}</span>
                    {p.rel && <span class="node-rel">{p.rel}</span>}
                  </button>
                ) : (
                  <span class="node">
                    <span class="node-av node-av--plain" style={`--gc:${g.color}`} aria-hidden="true">{initial(p.name)}</span>
                    <span class="node-name">{p.name}</span>
                  </span>
                )
              ))}
            </div>
          </div>
        ))}
      </div>

      <p class="rel-foot y-reveal"><span class="sb-note rel-foot-note">※ メンバー在籍は2026年6月時点。番組での共演・本人やメンバーの発信など、公開されている情報をもとにファンが作成したものです。</span></p>
    </div>
  </section>

  <!-- メンバー詳細ポップアップ -->
  <div id="ymem" class="ymem" aria-hidden="true" role="dialog" aria-modal="true" aria-label="メンバーの詳細">
    <button class="y-x ymem-x" aria-label="閉じる">✕</button>
    <div class="ymem-card" role="document">
      <span class="ymem-av" id="ymemAv"></span>
      <h3 class="ymem-name" id="ymemName"></h3>
      <span class="ymem-rel" id="ymemRel"></span>
      <span class="ymem-sub" id="ymemSub"></span>
      <p class="ymem-note" id="ymemNote"></p>
    </div>
  </div>

  <Lightbox />
</Yumiki>

<style>
  .rel-intro { margin-top: 0.9rem; color: var(--y-ink-soft); font-size: 0.95rem; max-width: 52ch; margin-inline: auto; line-height: 1.85; }
  .rel-hint { margin-top: 0.7rem; font-size: 0.82rem; color: var(--y-ink-soft); background: #fff; border: 1.5px dashed var(--y-line); border-radius: 999px; padding: 0.4rem 1rem; display: inline-block; }
  .rel-hint-dot { color: var(--y-peach); }

  /* 軍団 首ンセス */
  .unit { position: relative; overflow: hidden; margin-bottom: clamp(2.4rem, 7vw, 4rem); border: 2px dashed var(--y-line); border-radius: var(--y-radius);
    padding: clamp(1.6rem, 5vw, 2.6rem); box-shadow: var(--y-shadow-sm); text-align: center;
    background: linear-gradient(150deg, color-mix(in srgb, var(--y-lav) 20%, #fff), color-mix(in srgb, var(--y-sky) 18%, #fff)); }
  .unit-deco { position: absolute; top: -1rem; right: 0.4rem; font-size: 6rem; color: var(--y-butter); opacity: 0.35; pointer-events: none; }
  .unit-head { position: relative; z-index: 1; }
  .unit-badge { display: inline-block; font-weight: 700; font-size: 0.74rem; color: #fff; background: var(--y-peach); padding: 0.32rem 0.95rem; border-radius: 999px; }
  .unit-name { font-size: clamp(1.8rem, 6vw, 2.6rem); margin: 0.6rem 0 0.3rem; }
  .unit-name small { font-size: 0.42em; color: var(--y-muted); font-weight: 500; }
  .unit-meta { font-family: var(--y-font-en); font-weight: 700; font-size: 0.82rem; color: var(--y-rose); }
  .unit-origin { color: var(--y-ink-soft); font-size: 0.9rem; max-width: 56ch; margin: 0.8rem auto 0; line-height: 1.85; }
  .unit-photo { position: relative; z-index: 1; width: min(440px, 90%); margin: 1.5rem auto 0; padding: 0.5rem 0.5rem 1rem; transform: rotate(-1.2deg); cursor: zoom-in; transition: transform 0.35s var(--y-ease), box-shadow 0.35s var(--y-ease); }
  .unit-photo:hover { transform: rotate(0deg) scale(1.02); box-shadow: var(--y-shadow); }
  .unit-photo img { width: 100%; aspect-ratio: 16 / 10; object-fit: cover; border-radius: 3px; }
  .unit-photo figcaption { font-family: var(--y-font-en); font-weight: 700; text-align: center; margin-top: 0.4rem; color: var(--y-ink-soft); font-size: 0.8rem; }
  .unit-members { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.5rem; margin-top: 1.2rem; }
  .unit-chip { display: inline-flex; flex-direction: column; align-items: center; line-height: 1.25; font-weight: 700; font-size: 0.9rem; color: var(--y-ink);
    background: #fff; border: 1.5px solid var(--y-line); border-radius: 14px; padding: 0.45rem 0.9rem; box-shadow: var(--y-shadow-sm); }
  .unit-chip small { font-size: 0.68rem; font-weight: 600; color: var(--y-muted); margin-top: 2px; }
  .unit-chip--leader { background: color-mix(in srgb, var(--y-butter) 30%, #fff); border-color: color-mix(in srgb, var(--y-peach) 40%, #fff); }

  .rel-sec-title { text-align: center; font-size: 1.12rem; margin: clamp(2.4rem, 6vw, 3.4rem) 0 1.4rem; }
  .rel-sec-title::before { content: "♡"; color: var(--y-peach); margin-right: 0.4rem; }

  /* 色の凡例 */
  .cor-legend { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.45rem 0.9rem; margin: -0.4rem auto 1.2rem; }
  .cor-leg { display: inline-flex; align-items: center; gap: 0.35rem; font-size: 0.76rem; font-weight: 700; color: var(--y-ink-soft); }
  .cor-leg i { width: 13px; height: 13px; border-radius: 50%; background: var(--gc); box-shadow: var(--y-shadow-sm); }

  /* ===== 中心相関図 ===== */
  .cor { position: relative; max-width: 780px; margin: 0 auto clamp(1rem, 4vw, 2rem); }
  .cor-svg { position: absolute; inset: 0; width: 100%; height: 100%; z-index: 0; pointer-events: none; overflow: visible; }
  .cor-grid { position: relative; z-index: 1; display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(0.8rem, 3vw, 1.7rem); align-items: center; }

  .cor-hub { display: grid; place-content: center; justify-items: center; gap: 0.2rem; text-align: center;
    background: #fff; border: 3px solid var(--y-peach); border-radius: var(--y-radius); padding: 0.7rem 0.5rem; box-shadow: var(--y-shadow); }
  .cor-hub img { width: clamp(56px, 13vw, 84px); height: clamp(56px, 13vw, 84px); border-radius: 50%; object-fit: cover; object-position: center top; border: 2px solid var(--y-pink); }
  .cor-hub b { font-size: clamp(0.82rem, 2.3vw, 1.05rem); margin-top: 0.3rem; }
  .cor-hub small { font-size: 0.64rem; color: var(--y-muted); font-family: var(--y-font-en); font-weight: 700; }

  .cor-node { display: flex; flex-direction: column; align-items: center; gap: 0.32rem; padding: 0.7rem 0.4rem 0.8rem; cursor: pointer;
    background: color-mix(in srgb, var(--gc) 13%, #fff); border: 1.5px solid color-mix(in srgb, var(--gc) 34%, #fff); border-radius: 16px;
    box-shadow: var(--y-shadow-sm); transition: transform 0.25s var(--y-ease), box-shadow 0.25s var(--y-ease); }
  .cor-node:hover { transform: translateY(-4px); box-shadow: var(--y-shadow); }
  .cor-node:focus-visible { outline: 3px solid var(--y-peach); outline-offset: 3px; }
  .cor-rel { font-size: 0.6rem; font-weight: 700; color: color-mix(in srgb, var(--y-ink) 55%, var(--gc)); background: color-mix(in srgb, var(--gc) 18%, #fff); padding: 0.14rem 0.5rem; border-radius: 999px; line-height: 1.4; }
  .cor-av { width: clamp(38px, 10vw, 50px); height: clamp(38px, 10vw, 50px); border-radius: 50%; display: grid; place-items: center; font-weight: 700; color: var(--y-ink);
    background: var(--gc); font-size: 1.05rem; box-shadow: 0 5px 14px color-mix(in srgb, var(--gc) 50%, transparent); outline: 2px solid #fff; outline-offset: 2px; }
  .cor-nm { font-size: 0.74rem; font-weight: 700; text-align: center; line-height: 1.3; }

  @media (max-width: 700px) {
    .cor-svg { display: none; }
    .cor-grid { grid-template-columns: repeat(2, 1fr); gap: 0.7rem; }
    /* ハブは“縦カード”のまま最上段に中央寄せ。横並び(row)や grid の place-content 依存だと
       一部ブラウザ(iOS Safari 等)で中心がズレ得るため、flex の縦積みで明示的に中央寄せして堅牢化。 */
    .cor-hub { grid-column: 1 / -1; order: -1; justify-self: center; width: min(100%, 230px); margin: 0.4rem auto 0.9rem;
      display: flex; flex-direction: column; align-items: center; gap: 0.15rem; }
    .cor-hub img { width: 66px; height: 66px; }
  }

  /* クラスター共通 */
  .gen-grid, .grp-grid { display: grid; gap: clamp(1.1rem, 3vw, 1.6rem); grid-template-columns: 1fr; }
  @media (min-width: 720px) { .gen-grid { grid-template-columns: repeat(2, 1fr); } .grp-grid { grid-template-columns: repeat(2, 1fr); } }
  .cluster { position: relative; border-radius: var(--y-radius); padding: 1.5rem 1.1rem 1.3rem;
    background: color-mix(in srgb, var(--gc) 11%, #fff); border: 1.5px solid color-mix(in srgb, var(--gc) 28%, #fff); }
  .cluster::before { content: "♡"; position: absolute; top: -13px; left: 50%; transform: translateX(-50%); width: 26px; height: 26px; display: grid; place-items: center;
    border-radius: 50%; background: var(--gc); color: #fff; font-size: 0.78rem; box-shadow: var(--y-shadow-sm); }
  .cluster-title { font-size: 1.12rem; margin-bottom: 1.1rem; text-align: center; display: flex; align-items: baseline; justify-content: center; gap: 0.5rem; }
  .cluster-title--sm { font-size: 0.98rem; line-height: 1.4; }
  .cluster-title small { font-size: 0.7rem; font-weight: 500; color: var(--y-ink-soft); }

  /* メンバーノード（アバター＋名前＋関係ラベル） */
  .nodes { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.9rem 0.55rem; }
  .node { display: flex; flex-direction: column; align-items: center; gap: 0.3rem; width: 5.1rem; padding: 0; border: none; background: none; }
  .node-av { position: relative; width: 50px; height: 50px; border-radius: 50%; display: grid; place-items: center; font-weight: 700; font-size: 1.15rem; color: var(--y-ink);
    background: var(--gc); box-shadow: var(--y-shadow-sm); }
  .node-av--plain { background: color-mix(in srgb, var(--gc) 40%, #fff); color: color-mix(in srgb, var(--y-ink) 70%, var(--gc)); }
  .node-name { font-size: 0.74rem; font-weight: 700; color: var(--y-ink); line-height: 1.3; text-align: center; }
  .node-rel { font-size: 0.58rem; font-weight: 700; color: color-mix(in srgb, var(--y-ink) 55%, var(--gc)); background: color-mix(in srgb, var(--gc) 18%, #fff);
    border-radius: 999px; padding: 0.08rem 0.42rem; line-height: 1.35; text-align: center; }
  .node-badge { position: absolute; right: -3px; bottom: -3px; width: 19px; height: 19px; border-radius: 50%; background: #fff; color: var(--y-peach); font-size: 0.62rem; display: grid; place-items: center; box-shadow: var(--y-shadow-sm); }
  /* 卒業・卒業予定メンバー（現役と分けて表示） */
