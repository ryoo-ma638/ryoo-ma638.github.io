---
import Yumiki from "../../layouts/Yumiki.astro";
import Lightbox from "../../components/Lightbox.astro";
import { profile, timeline, shows, sns, singles, photobook, img } from "../../data/yumiki.ts";
import fs from "node:fs";

// 各シングルの画像（public/assets/yumiki/singles/{no}-{cover|photo|mv}.jpg）が
// 存在すれば解決、無ければ空文字。号番号で対応するので、素材を足すだけで自動反映される。
const sImg = (no: number, kind: "cover" | "photo" | "mv") =>
  fs.existsSync(`public/assets/yumiki/singles/${no}-${kind}.jpg`) ? img(`singles/${no}-${kind}.jpg`) : "";

// 弓木さんのアー写の変遷（研修生〜現在）。public/assets/yumiki/arsha/ に配置（本人提供）。
// 1つのLightboxギャラリーにして「ずらっと」一覧＋拡大で前後にめくれる。
const naoPhotos = [
  { f: "trainee.jpg", short: "研修生", t: "坂道研修生", y: "2019" },
  { f: "join.jpg", short: "加入時", t: "新4期生 加入時", y: "2020" },
  { f: "25.jpg", short: "25th", t: "25th しあわせの保護色", y: "2020" },
  { f: "26.jpg", short: "26th", t: "26th 僕は僕を好きになる", y: "2021" },
  { f: "27.jpg", short: "27th", t: "27th ごめんねFingers crossed", y: "2021" },
  { f: "28.jpg", short: "28th", t: "28th 君に叱られた", y: "2021" },
  { f: "31.jpg", short: "31st", t: "31st ここにはないもの", y: "2022" },
  { f: "34.jpg", short: "34th", t: "34th Monopoly", y: "2023" },
  { f: "35.jpg", short: "35th", t: "35th チャンスは平等", y: "2024" },
  { f: "36.jpg", short: "36th", t: "36th チートデイ", y: "2024" },
  { f: "37.jpg", short: "37th", t: "37th 歩道橋", y: "2024" },
  { f: "38.jpg", short: "38th", t: "38th ネーブルオレンジ", y: "2025" },
  { f: "39.jpg", short: "39th", t: "39th Same numbers", y: "2025" },
  { f: "40.jpg", short: "40th", t: "40th ビリヤニ", y: "2025" },
  { f: "41.jpg", short: "41st", t: "41st 最後に階段を駆け上がったのは？", y: "2026" },
  { f: "42.jpg", short: "42nd", t: "42nd 是非に及ばず", y: "2026" },
];
const naoPhotoSrcs = naoPhotos.map((p) => img(`arsha/${p.f}`));

// 付箋に回す差し色（順番に巡回）
const stickyColors = [
  "var(--y-peach)", "var(--y-sky)", "var(--y-mint)",
  "var(--y-butter)", "var(--y-lav)", "var(--y-pink)",
];
// プロフィール帳らしい「質問」ラベルへの読み替え（事実・値は data のまま）
const factQ: Record<string, string> = {
  "生年月日": "うまれた日は？",
  "出身地": "どこ出身？",
  "所属": "どこにいる人？",
  "ニックネーム": "なんて呼ぶ？",
  "血液型": "血液型は？",
  "星座": "星座は？",
  "身長": "身長は？",
  "サイリウムカラー": "サイリウムは？",
  "趣味": "趣味は？",
  "特技": "特技は？",
  "家族構成": "家族は？",
};
// 趣味・特技には小さな落書きを添える
const doodleKeys = new Set(["趣味", "特技"]);
const factDoodle: Record<string, string> = { "趣味": "✿", "特技": "✦" };
// 年表の節目（大きめに見せる）。data の date と一致するものを強調
const milestoneDates = new Set(["2022.7", "2024.4", "2024.7", "2025.1"]);
// レコード棚プレースホルダの背表紙色（6色を巡回）
const spineColors = [
  "var(--y-peach)", "var(--y-pink)", "var(--y-butter)",
  "var(--y-mint)", "var(--y-lav)", "var(--y-sky)",
];
---
<Yumiki title="プロフィール — YUMIKI WORLD">
  <!-- ===== 観察ノートの表紙的セクション：基本情報（プロフィール帳） ===== -->
  <section class="y-section pf-sheet sb-grid">
    <div class="y-container">
      <div class="sb-head y-reveal">
        <span class="sb-head-num sb-num" style="--cc:var(--y-sky)" aria-hidden="true">01</span>
        <span class="sb-head-tt">
          <span class="sb-head-eyebrow">Profile Note</span>
          <h1>📖 <span class="sb-mark" style="--cc:var(--y-butter)">弓木奈於</span>って、こんな人</h1>
        </span>
        <span class="sb-stamp" style="--cc:var(--y-peach)" aria-hidden="true">♡ MY OSHI</span>
      </div>

      <div class="pf-top">
        <div class="pf-left">
        <!-- 観察写真（チェキ） -->
        <figure class="sb-cheki pf-photo pf-tcard y-reveal sb-taped" style="--tape:var(--y-pink)">
          <span class="sb-tape l" aria-hidden="true"></span>
          <span class="pf-foil" aria-hidden="true">♡ OSHI CARD</span>
          <img src={img("arsha/42.jpg")} alt="弓木奈於さん（42ndシングル アー写）" onerror="this.src='/assets/yumiki/arsha/42.jpg'" />
          <figcaption class="pf-tcard-cap">
            <span class="pf-tcard-name">弓木 奈於 <small>YUMIKI NAO ・ 乃木坂46 4期生</small></span>
            <span class="pf-tcard-pen"><i class="pf-pen" style="background:#ff3b3b" aria-hidden="true"></i><i class="pf-pen" style="background:#9acd32" aria-hidden="true"></i> 赤 × 黄緑</span>
          </figcaption>
          <span class="sb-doodle pf-photo-d1" style="--cc:var(--y-butter)" aria-hidden="true">✦</span>
          <span class="sb-doodle pf-photo-d2" style="--cc:var(--y-peach)" aria-hidden="true">♡</span>
        </figure>

        <!-- 弓木さんのおもしろポイント（左カラムの空白を埋める・すべて事実ベース） -->
        <aside class="pf-fun sb-sticky sb-taped y-reveal" style="--cc:var(--y-peach); --tape:var(--y-butter)" data-delay="2">
          <span class="sb-tape r" aria-hidden="true"></span>
          <h3 class="pf-fun-t">ここが<span class="sb-mark" style="--cc:var(--y-pink)">おもしろい</span> ♡</h3>
          <p class="pf-fun-lead"><b>ドンストップエナジー（ドンエネ）</b><br />ラジオ『沈黙の金曜日』でおなじみ、公式動画にもなった伝説の即興パフォーマンス。</p>
          <a class="pf-fun-link" href="https://www.instagram.com/reel/DJRKfD9TgSm/" target="_blank" rel="noopener noreferrer">▶ ドンエネを見る</a>
          <p class="pf-fun-sub sb-note">弓木語、まだまだあります →</p>
          <div class="pf-fun-tags">
            <span class="sb-stamp" style="--cc:var(--y-sky)">はんなりすっとこどっこい</span>
            <span class="sb-stamp" style="--cc:var(--y-mint)">Alligator🐊</span>
            <span class="sb-stamp" style="--cc:var(--y-lav)">架空の歌</span>
            <span class="sb-stamp" style="--cc:var(--y-butter)">暴れん坊パンダの歌</span>
            <span class="sb-stamp" style="--cc:var(--y-peach)">テネット弓木</span>
          </div>
        </aside>
        </div>

        <!-- プロフィール帳（質問→答えの付箋） -->
        <div class="pf-card y-reveal" data-delay="1">
          <h3 class="pf-name">{profile.name} <small>（{profile.kana}）</small></h3>
          <p class="sb-note pf-note">基本データ、ぜんぶメモしました</p>

          <div class="pf-facts">
            {profile.facts.map((f, i) => (
              <div
                class:list={["pf-fact", { "is-wide": f.k === "趣味" || f.k === "特技" || f.k === "家族構成" || f.k === "サイリウムカラー" }]}
                style={`--cc:${stickyColors[i % stickyColors.length]}; transform: rotate(${(i % 2 === 0 ? -1 : 1) * (1 + (i % 3) * 0.4)}deg)`}
              >
                <dl class="sb-sticky pf-sticky">
                  <dt class="pf-q">{factQ[f.k] ?? f.k}</dt>
                  <dd class="pf-a">
                    {f.k === "サイリウムカラー" ? (
                      <span class="pf-penlight">
                        <span class="pf-swatch" style="background:#ff3b3b" aria-hidden="true"></span>
                        <span class="pf-swatch" style="background:#9acd32" aria-hidden="true"></span>
                        <span>{f.v}</span>
                      </span>
                    ) : f.v}
                    {doodleKeys.has(f.k) && (
                      <span class="sb-doodle pf-fact-d" style={`--cc:${stickyColors[i % stickyColors.length]}`} aria-hidden="true">{factDoodle[f.k]}</span>
                    )}
                  </dd>
                </dl>
              </div>
            ))}
          </div>

          <div class="pf-sns">
            {sns.map((s) => (<a href={s.href} target="_blank" rel="noopener noreferrer" class="y-tag" style="background:var(--y-pink)"><img src={img(s.icon)} alt="" width="18" height="18" />{s.label}</a>))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 活動年表：点線レールを♡ノードが進むロードマップ ===== -->
  <section class="y-section pf-sheet-ruled sb-ruled" style="padding-top:0">
    <div class="y-container y-narrow">
      <div class="sb-head y-reveal">
        <span class="sb-head-num sb-num" style="--cc:var(--y-mint)" aria-hidden="true">02</span>
        <span class="sb-head-tt">
          <span class="sb-head-eyebrow">History</span>
          <h2>🕰️ 活動<span class="sb-mark" style="--cc:var(--y-mint)">年表</span></h2>
        </span>
      </div>
      <p class="sb-note pf-road-note">スタートからここまで、ぜんぶ追いかけた道のり ♡</p>

      <ol class="pf-road">
        {timeline.map((t, i) => (
          <li class:list={["pf-stop", "y-reveal", { "is-mile": milestoneDates.has(t.date) }]} data-delay={(i % 3) + 1}>
            <span class="pf-stop-node" aria-hidden="true">{milestoneDates.has(t.date) ? "★" : "♡"}</span>
            <span class="pf-stop-date">{t.date}</span>
            <span class="pf-stop-text">{t.text}</span>
          </li>
        ))}
        <li class="pf-stop pf-stop--goal y-reveal" aria-hidden="true">
          <span class="pf-stop-node">✦</span>
          <span class="pf-stop-text">これからも、ずっと応援！</span>
        </li>
      </ol>
    </div>
  </section>

  <!-- ===== ディスコグラフィー：レコード棚（ジャケ画像は出さずプレースホルダ） ===== -->
  <section class="y-section pf-sheet sb-grid" style="padding-top:0">
    <div class="y-container">
      <div class="sb-head y-reveal">
        <span class="sb-head-num sb-num" style="--cc:var(--y-peach)" aria-hidden="true">03</span>
        <span class="sb-head-tt">
          <span class="sb-head-eyebrow">Discography</span>
          <h2>💿 参加<span class="sb-mark" style="--cc:var(--y-pink)">シングル</span></h2>
        </span>
      </div>
      <p class="pf-disco-note y-reveal">2020年に乃木坂46へ配属。アンダー期を経て <b>30thで初選抜</b>、<b>35thで初福神</b>。以降もずっと選抜入りを続けています。</p>

      <div class="pf-shelf">
        {singles.map((s, i) => (
          <article
            class:list={["pf-rec", "y-reveal", { "is-fukujin": s.pos === "初福神", "is-debut": s.pos === "初選抜" }]}
            data-delay={(i % 3) + 1}
            style={`--cc:${spineColors[i % spineColors.length]}; transform: rotate(${(i % 2 === 0 ? -1 : 1.2)}deg)`}
            role="button"
            tabindex="0"
            aria-label={`${s.no}th「${s.title}」の詳細を見る`}
            data-no={String(s.no)}
            data-title={s.title}
            data-date={s.date}
            data-pos={s.pos}
            data-desc={s.desc ?? ""}
            data-cover={sImg(s.no, "cover")}
            data-photo={sImg(s.no, "photo")}
            data-mv={sImg(s.no, "mv")}
          >
            <div class:list={["pf-rec-cover", { "has-img": !!sImg(s.no, "cover") }]}>
              {sImg(s.no, "cover") ? (
                <img class="pf-rec-img" src={sImg(s.no, "cover")} alt={`${s.title}（ジャケット）`} loading="lazy" />
              ) : (
                <>
                  <span class="pf-rec-disc" aria-hidden="true"></span>
                  <span class="pf-rec-no sb-num" style={`--cc:${spineColors[i % spineColors.length]}`} aria-hidden="true">{s.no}<small>th</small></span>
                </>
              )}
              {s.pos === "初福神" && <span class="pf-rec-heart" aria-hidden="true">♡</span>}
            </div>
            <div class="pf-rec-info">
              <h3>{s.title}</h3>
              <span class="pf-rec-date">{s.date}</span>
              {s.pos !== "選抜" && (
                <span class:list={["sb-stamp", "pf-rec-pos", { "is-fukujin": s.pos === "初福神" }]} style={`--cc:${s.pos === "初福神" ? "var(--y-peach)" : "var(--y-sky)"}`}>{s.pos}</span>
              )}
            </div>
          </article>
        ))}
      </div>
      <p class="sb-note pf-shelf-note">ジャケットを押すと詳細（ジャケット・弓木さんのアー写・MVカット）。※一部の号はアー写が未掲載です。</p>

      <!-- アー写の変遷：研修生〜現在の弓木さんのアー写をずらっと（押すと拡大＋◀▶で前後めくり） -->
      <div class="pf-arsha">
        <h3 class="pf-arsha-head y-reveal">📸 弓木さんの<span class="sb-mark" style="--cc:var(--y-sky)">アー写</span>の変遷</h3>
        <p class="sb-note pf-arsha-note y-reveal">坂道研修生から最新シングルまで、弓木さんのアー写の移り変わり。押すと大きく見られます（◀▶で次々めくれます）。</p>
        <div class="pf-arsha-strip">
          {naoPhotos.map((p, i) => (
            <figure
              class="pf-arsha-card sb-cheki sb-taped y-reveal"
              data-delay={(i % 3) + 1}
              style={`--tape:${spineColors[i % spineColors.length]}; transform: rotate(${[-2.2, 1.6, -1.2, 2, -1.6, 1.2][i % 6]}deg)`}
              data-gallery={JSON.stringify(naoPhotoSrcs)}
              data-index={i}
              data-caption={`${p.t}（${p.y}）`}
              role="button"
              tabindex="0"
              aria-label={`${p.t} のアー写を拡大`}
            >
              <span class={`sb-tape ${i % 2 === 0 ? "l" : "r"}`} aria-hidden="true"></span>
              <img src={img(`arsha/${p.f}`)} alt={`弓木奈於さん アー写（${p.t}）`} loading="lazy" />
              <figcaption>{p.short} <small>{p.y}</small></figcaption>
            </figure>
          ))}
        </div>
      </div>
    </div>

    <!-- シングル詳細モーダル（クリックで開く：思い出＋ジャケ写＋MVカットの2枚） -->
    <div class="sgl-modal" id="sglModal" aria-hidden="true" role="dialog" aria-modal="true" aria-label="シングルの詳細">
      <div class="sgl-panel">
        <button class="y-x sgl-close" id="sglClose" type="button" aria-label="閉じる">✕</button>
        <span class="sgl-tape sb-tape" aria-hidden="true"></span>
        <p class="sgl-meta"><span class="sgl-no sb-num" id="sglNo"></span><small>th SINGLE</small></p>
        <h3 class="sgl-title" id="sglTitle"></h3>
        <p class="sgl-sub"><span class="sgl-date" id="sglDate"></span><span class="sgl-pos sb-stamp" id="sglPos"></span></p>
        <p class="sgl-desc" id="sglDesc"></p>
        <div class="sgl-imgs">
          <figure class="sgl-shot" id="sglCoverFig">
            <figcaption class="sgl-shot-label">📀 ジャケット</figcaption>
            <div class="sgl-shot-box" id="sglCover"></div>
          </figure>
          <figure class="sgl-shot" id="sglPhotoFig">
            <figcaption class="sgl-shot-label">📸 弓木さんのアー写</figcaption>
            <div class="sgl-shot-box" id="sglPhoto"></div>
          </figure>
          <figure class="sgl-shot" id="sglMvFig">
            <figcaption class="sgl-shot-label">🎬 MVカット</figcaption>
            <div class="sgl-shot-box" id="sglMv"></div>
          </figure>
        </div>
        <p class="sgl-allsoon" id="sglAllSoon">この号の画像は準備中です。</p>
      </div>
    </div>
  </section>

  <!-- ===== 1st写真集『天使だったのか』 ===== -->
  <section class="y-section pf-sheet sb-grid" style="padding-top:0">
    <div class="y-container">
      <div class="sb-head y-reveal">
        <span class="sb-head-num sb-num" style="--cc:var(--y-peach)" aria-hidden="true">04</span>
        <span class="sb-head-tt">
          <span class="sb-head-eyebrow">1st Photobook</span>
          <h2>📸 1st<span class="sb-mark" style="--cc:var(--y-peach)">写真集</span></h2>
        </span>
      </div>
      <div class="pf-pb y-reveal">
        <figure class="sb-cheki sb-taped pf-pb-cover" style="--tape:var(--y-peach)"
          data-gallery={JSON.stringify([img(photobook.cover)])} data-index="0" data-caption={`1st写真集『${photobook.title}』`}
          role="button" tabindex="0" aria-label="写真集の表紙を拡大">
          <span class="sb-tape l" aria-hidden="true"></span>
          <img src={img(photobook.cover)} alt={`弓木奈於 1st写真集『${photobook.title}』表紙`} loading="lazy" />
          <figcaption>📸 1st PHOTOBOOK</figcaption>
        </figure>
        <div class="pf-pb-info">
          <span class="sb-stamp" style="--cc:var(--y-peach)">♡ 夢が叶った一冊</span>
          <h3 class="pf-pb-title">『<span class="sb-mark" style="--cc:var(--y-butter)">{photobook.title}</span>』</h3>
          <p class="pf-pb-desc">{photobook.desc}</p>
          <blockquote class="pf-pb-quote">「{photobook.quote}」<cite>— 弓木奈於（本人コメント）</cite></blockquote>
          <dl class="pf-pb-facts">
            <div><dt>発売</dt><dd>{photobook.release}</dd></div>
            <div><dt>撮影地</dt><dd>{photobook.location}</dd></div>
            <div><dt>撮影</dt><dd>{photobook.photographer}</dd></div>
            <div><dt>仕様</dt><dd>{photobook.spec}</dd></div>
            <div><dt>価格</dt><dd>{photobook.price}</dd></div>
          </dl>
          <p class="pf-pb-note">表紙は{photobook.covers}。発行＝{photobook.publisher}。</p>
          <a class="pf-show-link pf-pb-link" href={photobook.link} target="_blank" rel="noopener noreferrer">公式サイトで見る <span aria-hidden="true">↗</span></a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 主な出演番組：付箋メモのコルクボード ===== -->
  <section class="y-section pf-sheet-ruled sb-ruled" style="padding-top:0">
    <div class="y-container">
      <div class="sb-head y-reveal">
        <span class="sb-head-num sb-num" style="--cc:var(--y-butter)" aria-hidden="true">05</span>
        <span class="sb-head-tt">
          <span class="sb-head-eyebrow">On TV</span>
          <h2>📺 主な<span class="sb-mark" style="--cc:var(--y-butter)">出演番組</span></h2>
        </span>
      </div>

      <!-- 初主演ドラマ『未恋』ハイライト -->
      <div class="pf-drama y-reveal" data-gallery={JSON.stringify([img("drama-miren.jpg")])} data-index="0" data-caption="ドラマ『未恋』初主演" role="button" tabindex="0" aria-label="ドラマ『未恋』の写真を拡大">
        <figure class="sb-cheki sb-taped pf-drama-cheki" style="--tape:var(--y-pink)">
          <span class="sb-tape l" aria-hidden="true"></span>
          <img src={img("drama-miren.jpg")} alt="ドラマ『未恋』の台本を持つ弓木奈於さん" loading="lazy" />
          <figcaption>📖 台本オフショット</figcaption>
        </figure>
        <div class="pf-drama-text">
          <span class="sb-stamp" style="--cc:var(--y-peach)">🎬 初主演ドラマ</span>
          <h3 class="pf-drama-t">ドラマ『<span class="sb-mark" style="--cc:var(--y-pink)">未恋</span>』</h3>
          <p class="pf-drama-d">2025年放送。弓木さんが念願の“初主演”を果たしたドラマ。撮影前、台本を手にしたオフショットです。</p>
        </div>
      </div>

      <div class="pf-shows">
        {shows.map((s, i) => (
          <div
            class="pf-show y-reveal"
            data-delay={(i % 3) + 1}
            style={`--cc:${stickyColors[(i + 2) % stickyColors.length]}; transform: rotate(${(i % 2 === 0 ? -1.4 : 1.2)}deg)`}
          >
            <div class="sb-sticky pf-show-sticky sb-taped" style={`--tape:${stickyColors[(i + 2) % stickyColors.length]}`}>
              <span class="sb-tape" aria-hidden="true"></span>
              <h3>{s.name}</h3>
              <p>{s.desc}</p>
