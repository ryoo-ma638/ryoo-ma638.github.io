        if (src) {
          fig.style.display = "";
          const w = document.createElement("div");
          w.className = "sgl-shot-img";
          w.setAttribute("data-gallery", JSON.stringify(gal));
          w.setAttribute("data-index", String(Math.max(0, gal.indexOf(src))));
          w.setAttribute("data-caption", cap);
          w.setAttribute("role", "button");
          w.setAttribute("tabindex", "0");
          w.setAttribute("aria-label", cap + "を拡大");
          const im = document.createElement("img");
          im.src = src; im.alt = cap; im.loading = "lazy";
          w.appendChild(im);
          box.replaceChildren(w);
        } else {
          fig.style.display = "none";
          box.replaceChildren();
        }
      };
      const open = (el) => {
        const d = el.dataset;
        byId("sglNo").textContent = d.no || "";
        byId("sglTitle").textContent = "『" + (d.title || "") + "』";
        byId("sglDate").textContent = d.date || "";
        const pos = byId("sglPos");
        pos.textContent = d.pos || ""; pos.style.display = d.pos ? "" : "none";
        const desc = byId("sglDesc");
        if (d.desc) { desc.textContent = d.desc; desc.classList.remove("is-soon"); }
        else { desc.textContent = "このシングルの思い出・特徴は準備中です。素材ができ次第ここに載せます。"; desc.classList.add("is-soon"); }
        const no = d.no || "";
        const gal = [d.cover, d.photo, d.mv].filter(Boolean);
        setShot("sglCoverFig", "sglCover", gal, d.cover, no + "th ジャケット");
        setShot("sglPhotoFig", "sglPhoto", gal, d.photo, no + "th 弓木さんのアー写");
        setShot("sglMvFig", "sglMv", gal, d.mv, no + "th MVカット");
        byId("sglAllSoon").style.display = gal.length ? "none" : "";
        lastFocused = document.activeElement;
        modal.classList.add("open"); modal.setAttribute("aria-hidden", "false");
        lockScroll();
        modal.addEventListener("keydown", onTrap);
        const cb = byId("sglClose"); if (cb) cb.focus();
      };
      const close = () => {
        // フォーカスがモーダル内に残っていると aria-hidden が無効になる→先に外す
        const fa = document.activeElement;
        if (fa && modal.contains(fa) && fa.blur) fa.blur();
        modal.classList.remove("open");
        modal.removeEventListener("keydown", onTrap);
        modal.setAttribute("aria-hidden", "true");
        unlockScroll();
        if (lastFocused && lastFocused.focus) lastFocused.focus();
      };
      document.querySelectorAll(".pf-rec").forEach((el) => {
        el.addEventListener("click", () => open(el));
        el.addEventListener("keydown", (e) => { if (e.key === "Enter" || e.key === " ") { e.preventDefault(); open(el); } });
      });
      byId("sglClose").addEventListener("click", close);
      modal.addEventListener("click", (e) => { if (e.target === modal) close(); });
      document.addEventListener("keydown", (e) => { if (e.key === "Escape" && modal.classList.contains("open")) close(); });
    })();
  </script>
