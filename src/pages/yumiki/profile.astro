---
import Yumiki from "../../layouts/Yumiki.astro";
import { profile, timeline, shows, sns, singles, img } from "../../data/yumiki.ts";
---
<Yumiki title="プロフィール — YUMIKI WORLD">
  <section class="y-section">
    <div class="y-container">
      <div class="y-head y-reveal">
        <span class="y-eyebrow">Profile</span>
        <h2>📖 <span class="wave">弓木奈於</span>って、こんな人</h2>
      </div>

      <div class="y-prof-top">
        <div class="y-prof-photo y-card y-reveal">
          <img src={img("nao_main.jpg")} alt="弓木奈於さん" onerror="this.src='/assets/yumiki/yumiki-main.png'" />
        </div>
        <div class="y-prof-info y-card y-reveal" data-delay="1">
          <h3 class="y-prof-name">{profile.name} <small>（{profile.kana}）</small></h3>
          <p class="y-prof-en">{profile.en}</p>
          <dl class="y-facts">
            {profile.facts.map((f) => (<div><dt>{f.k}</dt><dd>{f.v}</dd></div>))}
          </dl>
          <div class="y-prof-sns">
            {sns.map((s) => (<a href={s.href} target="_blank" rel="noopener noreferrer" class="y-tag" style="background:var(--y-pink)"><img src={img(s.icon)} alt="" width="18" height="18" />{s.label}</a>))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="y-section" style="padding-top:0">
    <div class="y-container y-narrow">
      <div class="y-head y-reveal"><span class="y-eyebrow">History</span><h2>🕰️ 活動年表</h2></div>
      <ol class="y-timeline y-card y-reveal">
        {timeline.map((t) => (
          <li><span class="y-t-date">{t.date}</span><span class="y-t-dot"></span><span class="y-t-text">{t.text}</span></li>
        ))}
      </ol>
    </div>
  </section>

  <section class="y-section" style="padding-top:0">
    <div class="y-container">
      <div class="y-head y-reveal"><span class="y-eyebrow">Discography</span><h2>💿 参加<span class="wave">シングル</span></h2></div>
      <p class="y-disco-note y-reveal">2020年に乃木坂46へ配属。アンダー期を経て <b>30thで初選抜</b>、<b>35thで初福神</b>。以降もずっと選抜入りを続けています。</p>
      <div class="y-disco">
        {singles.map((s, i) => (
          <article class="y-single y-reveal" data-delay={(i % 3) + 1}>
            <div class="y-single-cover">
              <img src={`/assets/yumiki/singles/${s.no}.jpg`} alt={`${s.no}thシングル「${s.title}」`} loading="lazy" onerror="this.closest('.y-single-cover').classList.add('noimg')" />
              <span class="y-single-no">{s.no}<small>th</small></span>
              {s.pos !== "選抜" && <span class={`y-single-pos${s.pos === "初福神" ? " is-fukujin" : ""}`}>{s.pos}</span>}
            </div>
            <div class="y-single-info">
              <h3>{s.title}</h3>
              <span class="y-single-date">{s.date}</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="y-section" style="padding-top:0">
    <div class="y-container">
      <div class="y-head y-reveal"><span class="y-eyebrow">On TV</span><h2>📺 主な出演番組</h2></div>
      <div class="y-shows">
        {shows.map((s, i) => (
          <div class="y-show y-card y-reveal" data-delay={(i % 3) + 1}>
            <h3>{s.name}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <style>
    .y-prof-top { display: grid; gap: 2rem; grid-template-columns: 1fr; align-items: start; }
    @media (min-width: 820px) { .y-prof-top { grid-template-columns: 0.8fr 1.2fr; } }
    .y-prof-photo { padding: 10px; transform: rotate(-2deg); }
    .y-prof-photo img { width: 100%; border-radius: 20px; aspect-ratio: 4/5; object-fit: cover; object-position: center top; }
    .y-prof-info { padding: 1.8rem 1.8rem 1.6rem; }
    .y-prof-name { font-size: 1.8rem; }
    .y-prof-name small { font-size: 1rem; color: var(--y-muted); font-weight: 500; }
    .y-prof-en { font-family: var(--y-font-en); font-weight: 700; color: var(--y-peach); letter-spacing: 0.1em; margin-bottom: 1.2rem; }
    .y-facts { display: grid; gap: 0.55rem; }
    .y-facts > div { display: grid; grid-template-columns: 6.4rem 1fr; gap: 0.85rem; align-items: start; }
    .y-facts dt { font-weight: 700; font-size: 0.76rem; color: var(--y-ink); text-align: center; padding: 0.34rem 0.4rem; border-radius: 999px; background: var(--y-cream-2); }
    .y-facts > div:nth-child(6n+1) dt { background: color-mix(in srgb, var(--y-peach) 38%, #fff); }
    .y-facts > div:nth-child(6n+2) dt { background: color-mix(in srgb, var(--y-sky) 40%, #fff); }
    .y-facts > div:nth-child(6n+3) dt { background: color-mix(in srgb, var(--y-mint) 44%, #fff); }
    .y-facts > div:nth-child(6n+4) dt { background: color-mix(in srgb, var(--y-butter) 50%, #fff); }
    .y-facts > div:nth-child(6n+5) dt { background: color-mix(in srgb, var(--y-lav) 42%, #fff); }
    .y-facts > div:nth-child(6n) dt { background: color-mix(in srgb, var(--y-pink) 46%, #fff); }
    .y-facts dd { color: var(--y-ink); font-size: 0.92rem; padding-top: 0.14rem; }
    .y-prof-sns { display: flex; gap: 0.6rem; flex-wrap: wrap; margin-top: 1.4rem; }
    .y-prof-sns .y-tag { gap: 0.4rem; }

    .y-timeline { position: relative; padding: 1.6rem 1.8rem; }
    .y-timeline li { display: grid; grid-template-columns: 4.5rem auto 1fr; gap: 1rem; align-items: center; padding: 0.7rem 0; border-bottom: 2px dotted var(--y-line); }
    .y-timeline li:last-child { border-bottom: none; }
    .y-t-date { font-family: var(--y-font-en); font-weight: 700; color: var(--y-peach); font-size: 0.85rem; }
    .y-t-dot { width: 11px; height: 11px; border-radius: 50%; background: var(--y-mint); border: 2px solid #fff; box-shadow: 0 0 0 2px var(--y-mint); }
    .y-t-text { color: var(--y-ink); font-size: 0.92rem; }

    .y-shows { display: grid; gap: 1.2rem; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
    .y-show { padding: 1.5rem; border-left: 6px solid var(--y-butter); transition: transform .3s var(--y-ease), box-shadow .3s var(--y-ease); }
    .y-show:hover { transform: translateY(-4px); box-shadow: var(--y-shadow); }
    .y-show:nth-child(5n+1) { border-left-color: var(--y-peach); }
    .y-show:nth-child(5n+2) { border-left-color: var(--y-sky); }
    .y-show:nth-child(5n+3) { border-left-color: var(--y-mint); }
    .y-show:nth-child(5n+4) { border-left-color: var(--y-lav); }
    .y-show:nth-child(5n) { border-left-color: var(--y-pink); }
    .y-show h3 { font-size: 1.2rem; margin-bottom: 0.3rem; }
    .y-show p { color: var(--y-ink-soft); font-size: 0.9rem; }

    /* ディスコグラフィー（参加シングル） */
    .y-disco-note { text-align: center; color: var(--y-ink-soft); font-size: 0.92rem; max-width: 52ch; margin: 0 auto 1.8rem; line-height: 1.8; }
    .y-disco-note b { color: var(--y-peach); }
    .y-disco { display: grid; gap: 1.4rem 1.1rem; grid-template-columns: repeat(2, 1fr); }
    @media (min-width: 620px) { .y-disco { grid-template-columns: repeat(3, 1fr); } }
    @media (min-width: 920px) { .y-disco { grid-template-columns: repeat(4, 1fr); } }
    .y-single { text-align: center; transition: transform 0.3s var(--y-ease); }
    .y-single:nth-child(odd) { transform: rotate(-1deg); }
    .y-single:nth-child(even) { transform: rotate(1deg); }
    .y-single:hover { transform: rotate(0) translateY(-5px); }
    .y-single-cover { position: relative; aspect-ratio: 1; border-radius: 14px; overflow: hidden; background: var(--y-cream-2); border: 4px solid #fff; box-shadow: var(--y-shadow-sm); }
    .y-single-cover img { width: 100%; height: 100%; object-fit: cover; }
    .y-single-cover.noimg { display: grid; place-items: center; background: linear-gradient(135deg, color-mix(in srgb, var(--y-pink) 22%, #fff), color-mix(in srgb, var(--y-lav) 22%, #fff)); }
    .y-single-cover.noimg img { display: none; }
    .y-single-cover.noimg::after { content: "♪"; font-size: 2rem; color: var(--y-peach); opacity: 0.7; }
    .y-single-no { position: absolute; top: 8px; left: 8px; font-family: var(--y-font-en); font-weight: 700; font-size: 0.92rem; color: var(--y-ink); background: rgba(255,255,255,0.92); padding: 0.12rem 0.5rem; border-radius: 999px; box-shadow: var(--y-shadow-sm); }
    .y-single-no small { font-size: 0.62em; }
    .y-single-pos { position: absolute; bottom: 8px; right: 8px; font-weight: 700; font-size: 0.64rem; color: #fff; background: var(--y-sky); padding: 0.2rem 0.5rem; border-radius: 999px; box-shadow: var(--y-shadow-sm); }
    .y-single-pos.is-fukujin { background: var(--y-peach); }
    .y-single-info { margin-top: 0.6rem; }
    .y-single-info h3 { font-size: 0.9rem; line-height: 1.45; margin-bottom: 0.1rem; }
    .y-single-date { font-family: var(--y-font-en); font-weight: 700; font-size: 0.72rem; color: var(--y-muted); }
  </style>
</Yumiki>
