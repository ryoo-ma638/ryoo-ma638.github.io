---
import Yumiki from "../../layouts/Yumiki.astro";
import { memories, img } from "../../data/yumiki.ts";
---
<Yumiki title="思い出 — YUMIKI WORLD">
  <section class="y-section">
    <div class="y-container">
      <div class="y-head y-reveal">
        <span class="y-eyebrow">Memories</span>
        <h2>💭 推し活の<span class="wave">思い出</span></h2>
      </div>

      <h3 class="y-sub y-reveal">🎤 ライブの思い出</h3>
      <div class="y-mem-grid">
        {memories.lives.map((m, i) => (
          <article class="y-mem y-card y-reveal" data-delay={(i % 3) + 1}>
            <div class="y-mem-photo"><img src={img(m.img)} alt={m.title} loading="lazy" onerror="this.closest('.y-mem-photo').classList.add('noimg')" /></div>
            <div class="y-mem-body">
              <span class="y-mem-date">{m.date}</span>
              <h4>{m.title}</h4>
              <p>{m.text}</p>
            </div>
          </article>
        ))}
      </div>

      <h3 class="y-sub y-reveal">🤝 リアルミーグリの思い出</h3>
      <div class="y-mem-grid">
        {memories.meet.map((m) => (
          <article class="y-mem y-card y-reveal">
            <div class="y-mem-photo"><img src={img(m.img)} alt={m.title} loading="lazy" onerror="this.closest('.y-mem-photo').classList.add('noimg')" /></div>
            <div class="y-mem-body">
              <span class="y-mem-date">{m.date}</span>
              <h4>{m.title}</h4>
              <p>{m.text}</p>
            </div>
          </article>
        ))}
      </div>

      <h3 class="y-sub y-reveal">🎵 その他の思い出</h3>
      <div class="y-mem-grid small">
        {memories.others.map((m, i) => (
          <article class="y-mem y-card y-reveal" data-delay={(i % 3) + 1}>
            <div class="y-mem-photo"><img src={img(m.img)} alt={m.title} loading="lazy" onerror="this.closest('.y-mem-photo').classList.add('noimg')" /></div>
            <div class="y-mem-body">
              <h4>{m.title}</h4>
              <p>{m.text}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <style>
    .y-sub { font-size: 1.4rem; margin: 2.5rem 0 1.3rem; }
    .y-mem-grid { display: grid; gap: 1.5rem; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); margin-bottom: 1rem; }
    .y-mem { display: flex; flex-direction: column; transition: transform .35s var(--y-ease); }
    .y-mem:hover { transform: translateY(-5px) rotate(-0.6deg); box-shadow: var(--y-shadow); }
    .y-mem-photo { aspect-ratio: 16/10; overflow: hidden; background: var(--y-cream-2); }
    .y-mem-photo img { width: 100%; height: 100%; object-fit: cover; }
    .y-mem-photo.noimg img { display: none; }
    .y-mem-photo.noimg::after { content: "✿"; display: grid; place-items: center; height: 100%; font-size: 2.5rem; color: var(--y-pink); }
    .y-mem-body { padding: 1.3rem 1.4rem 1.5rem; }
    .y-mem-date { font-family: var(--y-font-en); font-weight: 700; font-size: 0.78rem; color: var(--y-peach); }
    .y-mem-body h4 { font-size: 1.15rem; margin: 0.3rem 0 0.6rem; }
    .y-mem-body p { color: var(--y-ink-soft); font-size: 0.9rem; }
  </style>
</Yumiki>
