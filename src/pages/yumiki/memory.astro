---
import Yumiki from "../../layouts/Yumiki.astro";
import Lightbox from "../../components/Lightbox.astro";
import { memories, img } from "../../data/yumiki.ts";
const livesImgs = memories.lives.map((m) => img(m.img));
const meetImgs = memories.meet.map((m) => img(m.img));
const othersImgs = memories.others.map((m) => img(m.img));
---
<Yumiki title="思い出 — YUMIKI WORLD">
  <section class="y-section">
    <div class="y-container">
      <div class="y-head y-reveal">
        <span class="y-eyebrow">Memories</span>
        <h2>💭 推し活の<span class="wave">思い出</span></h2>
      </div>

      <!-- ライブ：タイムライン演出 -->
      <h3 class="y-sub y-reveal">🎤 ライブの思い出</h3>
      <div class="y-tl">
        {memories.lives.map((m, i) => (
          <div class="y-tl-item y-reveal" data-delay={(i % 3) + 1}>
            <span class="y-tl-node" aria-hidden="true">♡</span>
            <span class="y-tl-date">{m.date}</span>
            <article class="y-mem y-card">
              <div class="y-mem-photo" data-gallery={JSON.stringify(livesImgs)} data-index={i} data-caption={m.title} role="button" tabindex="0" aria-label={`${m.title} の写真を拡大`}>
                <img src={img(m.img)} alt={m.title} loading="lazy" onerror="this.closest('.y-mem-photo').classList.add('noimg')" />
              </div>
              <div class="y-mem-body">
                <h4>{m.title}</h4>
                <p>{m.text}</p>
              </div>
            </article>
          </div>
        ))}
      </div>

      <h3 class="y-sub y-reveal">🤝 リアルミーグリの思い出</h3>
      <div class="y-mem-grid y-mem-grid--narrow">
        {memories.meet.map((m, i) => (
          <article class="y-mem y-card y-reveal">
            <div class="y-mem-photo" data-gallery={JSON.stringify(meetImgs)} data-index={i} data-caption={m.title} role="button" tabindex="0" aria-label={`${m.title} の写真を拡大`}>
              <img src={img(m.img)} alt={m.title} loading="lazy" onerror="this.closest('.y-mem-photo').classList.add('noimg')" />
            </div>
            <div class="y-mem-body">
              <span class="y-mem-date">{m.date}</span>
              <h4>{m.title}</h4>
              <p>{m.text}</p>
            </div>
          </article>
        ))}
      </div>

      <h3 class="y-sub y-reveal">🎵 その他の思い出</h3>
      <div class="y-mem-grid small">
        {memories.others.map((m, i) => (
          <article class="y-mem y-card y-reveal" data-delay={(i % 3) + 1}>
            <div class="y-mem-photo" data-gallery={JSON.stringify(othersImgs)} data-index={i} data-caption={m.title} role="button" tabindex="0" aria-label={`${m.title} の写真を拡大`}>
              <img src={img(m.img)} alt={m.title} loading="lazy" onerror="this.closest('.y-mem-photo').classList.add('noimg')" />
            </div>
            <div class="y-mem-body">
              <h4>{m.title}</h4>
              <p>{m.text}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <Lightbox />

  <style>
    .y-sub { font-size: 1.4rem; margin: 2.5rem 0 1.3rem; }

    /* ライブのタイムライン */
    .y-tl { position: relative; padding-left: 2.4rem; }
    .y-tl::before { content: ""; position: absolute; left: 0.7rem; top: 0.4rem; bottom: 0.4rem; width: 3px; border-radius: 3px; background: linear-gradient(var(--y-peach), var(--y-lav), var(--y-sky)); }
    .y-tl-item { position: relative; margin-bottom: 1.6rem; }
    .y-tl-node { position: absolute; left: -2.4rem; top: 0.2rem; width: 1.5rem; height: 1.5rem; display: grid; place-items: center; border-radius: 50%; background: #fff; color: var(--y-peach); font-size: 0.8rem; box-shadow: var(--y-shadow-sm); transform: translateX(0.04rem); }
    .y-tl-date { display: inline-block; font-family: var(--y-font-en); font-weight: 700; font-size: 0.8rem; color: var(--y-peach); margin-bottom: 0.5rem; }
    .y-tl .y-mem { display: grid; grid-template-columns: 1fr; }
    @media (min-width: 720px) { .y-tl .y-mem { grid-template-columns: 0.9fr 1.1fr; align-items: stretch; } }

    .y-mem-grid { display: grid; gap: 1.5rem; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); margin-bottom: 1rem; }
    .y-mem-grid--narrow { max-width: 520px; }
    .y-mem { overflow: hidden; transition: transform .35s var(--y-ease); }
    .y-mem:hover { transform: translateY(-5px) rotate(-0.6deg); box-shadow: var(--y-shadow); }
    .y-mem-photo { aspect-ratio: 4/3; overflow: hidden; background: var(--y-cream-2); cursor: zoom-in; }
    .y-tl .y-mem-photo { aspect-ratio: auto; min-height: 180px; }
    .y-mem-photo img { width: 100%; height: 100%; object-fit: cover; object-position: center top; transition: transform .5s var(--y-ease); }
    .y-mem-photo:hover img { transform: scale(1.06); }
    .y-mem-photo.noimg img { display: none; }
    .y-mem-photo.noimg::after { content: "✿"; display: grid; place-items: center; height: 100%; font-size: 2.5rem; color: var(--y-pink); }
    .y-mem-body { padding: 1.3rem 1.4rem 1.5rem; }
    .y-mem-date { font-family: var(--y-font-en); font-weight: 700; font-size: 0.78rem; color: var(--y-peach); }
    .y-mem-body h4 { font-size: 1.15rem; margin: 0.3rem 0 0.6rem; }
    .y-mem-body p { color: var(--y-ink-soft); font-size: 0.9rem; }
  </style>
</Yumiki>
