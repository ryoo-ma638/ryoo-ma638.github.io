---
import Yumiki from "../../layouts/Yumiki.astro";
import Lightbox from "../../components/Lightbox.astro";
import { memories, img } from "../../data/yumiki.ts";
const livesImgs = memories.lives.map((m) => img(m.img));
const meetImgs = memories.meet.map((m) => img(m.img));
const othersImgs = memories.others.map((m) => img(m.img));
---
<Yumiki title="思い出 — YUMIKI WORLD">
  <section class="y-section">
    <div class="y-container">
      <div class="y-head y-reveal">
        <span class="y-eyebrow">Memories</span>
        <h2>💭 推し活の<span class="wave">思い出</span></h2>
      </div>

      <!-- ライブ：コンパクトなタイムライン（写真は縦でも全体表示） -->
      <h3 class="y-sub y-reveal">🎤 ライブの思い出</h3>
      <div class="y-tl">
        {memories.lives.map((m, i) => (
          <div class="y-tl-item y-reveal" data-delay={(i % 3) + 1}>
            <span class="y-tl-node" aria-hidden="true">♡</span>
            <article class="y-mem y-card">
              <div class="y-mem-photo" style={`--mbg:url(${img(m.img)})`} data-gallery={JSON.stringify(livesImgs)} data-index={i} data-caption={m.title} role="button" tabindex="0" aria-label={`${m.title} の写真を拡大`}>
                <img src={img(m.img)} alt={m.title} loading="lazy" onerror="this.closest('.y-mem-photo').classList.add('noimg')" />
              </div>
              <div class="y-mem-body">
                <span class="y-mem-date">{m.date}</span>
                <h4>{m.title}</h4>
                <p>{m.text}</p>
              </div>
            </article>
          </div>
        ))}
      </div>

      <h3 class="y-sub y-reveal">🤝 リアルミーグリの思い出</h3>
      <div class="y-mem-grid y-mem-grid--narrow">
        {memories.meet.map((m, i) => (
          <article class="y-mem y-card y-reveal y-mem--row">
            <div class="y-mem-photo" style={`--mbg:url(${img(m.img)})`} data-gallery={JSON.stringify(meetImgs)} data-index={i} data-caption={m.title} role="button" tabindex="0" aria-label={`${m.title} の写真を拡大`}>
              <img src={img(m.img)} alt={m.title} loading="lazy" onerror="this.closest('.y-mem-photo').classList.add('noimg')" />
            </div>
            <div class="y-mem-body">
              <span class="y-mem-date">{m.date}</span>
              <h4>{m.title}</h4>
              <p>{m.text}</p>
            </div>
          </article>
        ))}
      </div>

      <h3 class="y-sub y-reveal">🎵 その他の思い出</h3>
      <div class="y-mem-grid">
        {memories.others.map((m, i) => (
          <article class="y-mem y-card y-reveal" data-delay={(i % 3) + 1}>
            <div class="y-mem-photo y-mem-photo--wide" style={`--mbg:url(${img(m.img)})`} data-gallery={JSON.stringify(othersImgs)} data-index={i} data-caption={m.title} role="button" tabindex="0" aria-label={`${m.title} の写真を拡大`}>
              <img src={img(m.img)} alt={m.title} loading="lazy" onerror="this.closest('.y-mem-photo').classList.add('noimg')" />
            </div>
            <div class="y-mem-body">
              <h4>{m.title}</h4>
              <p>{m.text}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <Lightbox />

  <style>
    .y-sub { font-size: 1.4rem; margin: 2.5rem 0 1.3rem; }

    /* タイムライン（コンパクト） */
    .y-tl { position: relative; padding-left: 2.2rem; max-width: 760px; }
    .y-tl::before { content: ""; position: absolute; left: 0.65rem; top: 0.4rem; bottom: 0.4rem; width: 3px; border-radius: 3px; background: linear-gradient(var(--y-peach), var(--y-lav), var(--y-sky)); }
    .y-tl-item { position: relative; margin-bottom: 1.2rem; }
    .y-tl-node { position: absolute; left: -2.2rem; top: 0.9rem; width: 1.4rem; height: 1.4rem; display: grid; place-items: center; border-radius: 50%; background: #fff; color: var(--y-peach); font-size: 0.75rem; box-shadow: var(--y-shadow-sm); z-index: 1; }

    /* 写真＋本文を横並び（コンパクト）。写真は縦でも全体表示 */
    .y-mem { overflow: hidden; transition: transform .35s var(--y-ease), box-shadow .35s var(--y-ease); }
    .y-mem:hover { transform: translateY(-4px); box-shadow: var(--y-shadow); }
    .y-tl .y-mem, .y-mem--row { display: grid; grid-template-columns: 130px 1fr; align-items: stretch; }
    @media (min-width: 600px) { .y-tl .y-mem, .y-mem--row { grid-template-columns: 180px 1fr; } }

    .y-mem-photo { position: relative; overflow: hidden; background: var(--y-cream-2); cursor: zoom-in; aspect-ratio: 3 / 4; }
    .y-mem-photo--wide { aspect-ratio: 4 / 3; }
    .y-mem-photo::before { content: ""; position: absolute; inset: 0; background-image: var(--mbg); background-size: cover; background-position: center; filter: blur(16px) brightness(0.92) saturate(1.1); transform: scale(1.1); z-index: 0; }
    .y-mem-photo img { position: relative; z-index: 1; width: 100%; height: 100%; object-fit: contain; transition: transform .5s var(--y-ease); }
    .y-mem-photo:hover img { transform: scale(1.04); }
    .y-mem-photo.noimg::before { display: none; }
    .y-mem-photo.noimg img { display: none; }
    .y-mem-photo.noimg::after { content: "✿"; display: grid; place-items: center; height: 100%; font-size: 2.2rem; color: var(--y-pink); }

    .y-mem-body { padding: 1.1rem 1.3rem 1.2rem; }
    .y-mem-date { font-family: var(--y-font-en); font-weight: 700; font-size: 0.76rem; color: var(--y-peach); }
    .y-mem-body h4 { font-size: 1.08rem; margin: 0.25rem 0 0.5rem; line-height: 1.4; }
    .y-mem-body p { color: var(--y-ink-soft); font-size: 0.88rem; line-height: 1.7; }

    .y-mem-grid { display: grid; gap: 1.3rem; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); }
    .y-mem-grid--narrow { max-width: 560px; margin-bottom: 1rem; }
    /* その他は写真上・本文下のカード */
    .y-mem-grid:not(.y-mem-grid--narrow) .y-mem { display: flex; flex-direction: column; }
  </style>
</Yumiki>
