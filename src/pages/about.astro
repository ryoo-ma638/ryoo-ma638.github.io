---
import Base from "../layouts/Base.astro";
import Lightbox from "../components/Lightbox.astro";

// 事実のみ。資格・職歴のねつ造は厳禁。
const skills = [
  { group: "CG・映像", items: ["C++ / OpenGL・GLUT（CG制作）", "Maya", "映像表現（CG・MV）"], c: "var(--c-red)" },
  { group: "グラフィック", items: ["Illustrator", "Photoshop"], c: "var(--c-violet)" },
  { group: "画像処理", items: ["C++ / OpenCV（映像処理）", "Python / OpenCV", "オプティカルフロー・物体追跡"], c: "var(--c-cyan)" },
  { group: "Web", items: ["HTML / CSS", "JavaScript（学習中）", "Astro（このサイト）"], c: "var(--c-blue)" },
];

// 経歴：2006年の誕生から現在、そしてこれから。ドットは虹色に進行（＝出せる色が増えていく）。
const timeline = [
  { num: "2006", tag: "誕生", title: "名古屋に生まれる", text: "1月1日、名古屋市で生まれる。", c: "var(--c-violet)" },
  { num: "2012", tag: "小学校時代", title: "ムードメーカー、そして児童会長", text: "クラスを明るくする盛り上げ役。児童会長を務め、人をまとめ、場をつくる楽しさを知る。", c: "var(--c-blue)" },
  { num: "2018", tag: "中学校時代", title: "野球と、生徒会長", text: "野球チームに所属。生徒会長として学校を盛り上げ、リーダーとしての土台をつくる。", c: "var(--c-cyan)" },
  { num: "2021", tag: "高校時代", title: "学業に励んだ3年間", text: "進路を見据えながら、3年間しっかりと学業に打ち込む。", c: "var(--c-green)" },
  { num: "2024", tag: "愛知工業大学 入学", title: "情報科学部へ", text: "情報科学部に入学（コンピュータシステム専攻・KKA）。", c: "var(--c-yellow)" },
  { num: "2025", tag: "転機", title: "転専攻、そしてCEED", text: "ものづくりへの興味から、メディア情報専攻（KX）へ転専攻。マルチクリエイティブサークル CEED に所属する。", c: "var(--c-orange)" },
  { num: "2026", tag: "現在", title: "研究室と、副部長", text: "水野慎士研究室（CGメディア）でCG・画像処理を専門に。CEED副部長として、60名規模のサークルを牽引している。", c: "var(--c-red)" },
  { num: "これから", tag: "Future", title: "つくって、光を放つ。", text: "いろんなことに挑戦したい。人生は一度きりだから、後悔のないよう、たくさんの壁を越えていく。", c: "var(--accent-ink)", future: true },
];

// 信条（座右の銘・尊敬する人・原点・流儀）— すべて本人の言葉に基づく
const credo = [
  { tag: "尊敬する人", title: "戸塚優斗選手（スノーボード）", text: "2026年の冬季オリンピック金メダリスト。怪我を乗り越えて挑み続けるその姿に、勇気をもらった。自分も頑張ろう、と思える存在。", c: "var(--c-cyan)" },
  { tag: "ものづくりの原点", title: "「やりたい」に、突き進む", text: "「自分がやりたい」という気持ちに、ただ突き進んできた。その積み重ねが、今の自分をつくっている。", c: "var(--c-blue)" },
  { tag: "制作の流儀", title: "満足するまで、諦めない", text: "自分を、作品を客観視する。厳しい評価を受け止めてから、納得のいくものに仕上がるまで徹底的に。最後は根気と、根性。", c: "var(--c-violet)" },
];

// 一問一答（人となり）
const qa = [
  { q: "ONE WORD / 一言で言うと", a: "真面目バカ。" },
  { q: "FILMS / 好きな映画", a: "『スター・ウォーズ』『バック・トゥ・ザ・フューチャー』。感性に、新しい気づきとひらめきをくれた。" },
  { q: "DRAMA / 好きなドラマ", a: "『ROOKIES（ルーキーズ）』。" },
  { q: "DRAGONS / 中日の推し", a: "捕手・加藤匠馬選手。かつては堂上直倫選手。" },
  { q: "OSHI / 推しのきっかけ", a: "TBS『ラヴィット！』で弓木奈於さんの面白さと可愛らしさに惹かれ、乃木坂46の虜に。" },
  { q: "DAYS OFF / 休日", a: "寝る。推し活。新しいことに挑戦する。つくりたいものをつくる。" },
  { q: "FOOD / 好きな食べ物", a: "餃子・お寿司・焼肉。" },
  { q: "HOME / 落ち着く場所", a: "家。" },
];

// 取扱説明書（友人の評価より、"言っていい範囲"＝いいところを抜粋）
const traits = [
  { t: "好きなものに一直線", d: "「好き」と決めたものに、最上級の熱を注ぐ。", c: "var(--c-violet)" },
  { t: "行動力のかたまり", d: "飛び込む勇気が強い。別サークルでも転専攻でも、友達をつくってやり切る。", c: "var(--c-blue)" },
  { t: "こだわりが強い", d: "納得いくまで加筆・修正。自分のセンスと価値観で、ものをつくる。", c: "var(--c-cyan)" },
  { t: "“見せるもの”で輝く", d: "人に見せる制作になると、本気のギアが入る。実際、選ばれることも多い。", c: "var(--c-green)" },
  { t: "裏表がない", d: "喜怒哀楽が全部、顔に出る。リアクションが大きくて面白い。", c: "var(--c-yellow)" },
  { t: "猪突猛進", d: "関わることに全力。一生懸命で、元気いっぱい。", c: "var(--c-orange)" },
  { t: "基本、やさしい", d: "頼まれごとは、大抵引き受ける。", c: "var(--c-red)" },
  { t: "人懐っこい", d: "すぐ人に近づいて話しかける。元気な犬みたい。", c: "var(--c-violet)" },
];

// 実績ハイライト（すべて事実・ガクチカ準拠）
const highlights = [
  { n: "60名", l: "規模へ拡大", d: "CEED副部長として「誰も置いてけぼりにしない」体制づくりを進め、サークルを60名規模のコミュニティへ。", href: "/ceed", c: "var(--c-green)" },
  { n: "企業賞", l: "ハッカソン", d: "シスハックで割り勘アプリ「Settlo」を開発し、企業賞を受賞。", href: "/works#cat-web", c: "var(--c-blue)" },
  { n: "出展", l: "TGS 他", d: "体感型ゲーム「虫歯アニマルズ」をデザイン・造形で担当。東京ゲームショウ・ゲームマーケット・安城Eフェスで出展。", href: "/works#cat-cg", c: "var(--c-red)" },
  { n: "接客", l: "ビール売り子", d: "バンテリンドームナゴヤで、ビールの売り子として活動。通る声・笑顔・野球トークで「応援したくなる接客」を工夫している。", href: null, c: "var(--c-orange)" },
];
---

<Base title="About — Osaki Ryoma" description="名古屋のムードメーカーから、ものづくりの人へ。愛知工業大学 情報科学部 メディア情報専攻・水野慎士研究室の大崎稜馬。CG・映像・グラフィック・画像処理・Web・企画を横断する歩みと、その人となり。座右の銘は「謙虚」。">
  <!-- ============ ヒーロー ============ -->
  <section class="ab-hero" data-accent="var(--c-violet)">
    <div class="container">
      <div class="ab-hero-grid">
        <div class="ab-hero-text">
          <p class="eyebrow reveal">About — 自己紹介</p>
          <h1 class="ab-name reveal" data-delay="1">
            <span class="line-mask"><span>大崎 稜馬</span></span>
            <span class="ab-roman">Osaki&nbsp;Ryoma</span>
          </h1>
          <p class="ab-role reveal" data-delay="2">
            愛知工業大学 情報科学部 メディア情報専攻／<span class="accent">水野慎士研究室</span><br />
            CG・映像・グラフィック・画像処理・Web・企画を横断するクリエイター。
          </p>
          <p class="ab-lead reveal" data-delay="2">
            ひとつの専門に絞らず、面白いと思ったものに片っ端から手を出してきました。
            CGから映像、グラフィック、Web、そして企画まで——
            <span class="accent">手を広げるほど、出せる色が増えていく。</span>
            そう信じて、つくり続けています。
          </p>
        </div>
        <figure class="ab-portrait reveal" data-delay="2">
          <div class="ab-portrait-media" style="--bg-img:url('/assets/about/portrait.jpg')"
               data-gallery='["/assets/about/portrait.jpg"]' data-caption="大崎 稜馬 — Osaki Ryoma" tabindex="0" role="button" aria-label="ポートレートを拡大">
            <img src="/assets/about/portrait.jpg" alt="大崎稜馬のポートレート" loading="eager" />
          </div>
          <figcaption class="ab-portrait-cap">ものをつくる人。<span>応援する人。</span></figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- ============ これまで（経歴タイムライン） ============ -->
  <section class="section section--alt" data-accent="var(--c-blue)">
    <div class="container narrow">
      <div class="sec-head reveal">
        <span class="eyebrow">Biography</span>
        <h2 class="sec-title">これまでの、話。</h2>
        <p class="sec-sub">名古屋のムードメーカーが、ものづくりに出会うまで。そして、これから。</p>
      </div>
      <ol class="tl">
        {timeline.map((t) => (
          <li class:list={["tl-item", "reveal", { future: t.future }]} style={`--dot:${t.c}`}>
            <span class="tl-num">{t.num}</span>
            <div class="tl-body">
              <span class="tl-tag">{t.tag}</span>
              <h3 class="tl-title">{t.title}</h3>
              <p class="tl-text">{t.text}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ============ 信条（座右の銘・尊敬する人・原点・流儀） ============ -->
  <section class="section" data-accent="var(--c-cyan)">
    <div class="container">
      <div class="sec-head center reveal">
        <span class="eyebrow" style="justify-content:center">Credo — 信条</span>
      </div>
      <div class="motto reveal">
        <span class="motto-label">座右の銘</span>
        <p class="motto-word">「謙虚」</p>
        <p class="motto-reason">中学の野球部時代に、繰り返し言われてきた言葉。そして、尊敬する大先輩・栗林良吏選手（広島東洋カープ）が大切にしている言葉でもある。</p>
      </div>
      <div class="credo-cards">
        {credo.map((c, i) => (
          <div class="credo-card reveal" data-delay={(i % 3) + 1} style={`--cc:${c.c}`}>
            <span class="tl-tag">{c.tag}</span>
            <h3 class="credo-title">{c.title}</h3>
            <p class="credo-text">{c.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ つくる以外のわたし（人となり） ============ -->
  <section class="section section--alt" data-accent="var(--c-green)">
    <div class="container">
      <div class="sec-head reveal">
        <span class="eyebrow">Beyond Work</span>
        <h2 class="sec-title">つくる以外の、わたし。</h2>
        <p class="sec-sub">つくる原動力は、夢中になれる「好き」があること。盛り上げ役の血は、現場でも変わりません。</p>
      </div>

      <div class="persona-photos">
        <figure class="pcard reveal" data-delay="1" style="--cc:var(--c-blue)">
          <div class="pcard-media" style="--bg-img:url('/assets/about/baseball.jpg')"
               data-gallery='["/assets/about/baseball.jpg"]' data-caption="バンテリンドームナゴヤにて — 中日ドラゴンズを応援。" tabindex="0" role="button" aria-label="写真を拡大">
            <img src="/assets/about/baseball.jpg" alt="バンテリンドームで中日ドラゴンズを応援する大崎稜馬" loading="lazy" />
            <span class="pcard-chip">⚾ 野球観戦</span>
          </div>
          <figcaption class="pcard-body">
            <h3 class="pcard-title">中日ドラゴンズと、バンテリンドーム</h3>
            <p class="pcard-text">生まれも育ちも名古屋。中日ドラゴンズのファンとして球場へ。推しは捕手の加藤匠馬選手（かつては堂上直倫選手）。スタンドで浴びる熱気が、明日への活力です。</p>
          </figcaption>
        </figure>

        <figure class="pcard reveal" data-delay="2" style="--cc:var(--c-violet)">
          <div class="pcard-media" style="--bg-img:url('/assets/about/oshikatsu.jpg')"
               data-gallery='["/assets/about/oshikatsu.jpg"]' data-caption="14th YEAR BIRTHDAY LIVE — 弓木奈於さんを応援。" tabindex="0" role="button" aria-label="写真を拡大">
            <img src="/assets/about/oshikatsu.jpg" alt="ライブ会場でタオルを掲げて推し活をする大崎稜馬" loading="lazy" />
            <span class="pcard-chip">💜 推し活</span>
          </div>
          <figcaption class="pcard-body">
            <h3 class="pcard-title">乃木坂46・弓木奈於さんの応援</h3>
            <p class="pcard-text">『ラヴィット！』をきっかけに乃木坂46の虜に。応援する熱が高じて、ファンサイト「YUMIKI WORLD」を自作するほど。"好き"が、そのまま制作の原動力になりました。</p>
            <a class="pcard-link" href="/yumiki/">YUMIKI WORLD を見る <span aria-hidden="true">↗</span></a>
          </figcaption>
        </figure>
      </div>

      <div class="persona-band reveal" data-delay="1">
        <div class="band-mark" aria-hidden="true">応援</div>
        <div class="band-body">
          <span class="tl-tag">課外活動 — Beer Vendor</span>
          <p class="band-quote">「応援したくなる」を、めざして。</p>
          <p class="band-text">
            バンテリンドームナゴヤで、ビールの売り子として活動。通る声と笑顔、そして野球の話題で、
            球場での時間がもっと楽しくなるような接客を心がけています。
          </p>
          <a class="pcard-link" href="https://uriko-v-dome-ryoma.vercel.app" target="_blank" rel="noopener noreferrer">売り子 応援サイト <span aria-hidden="true">↗</span></a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ もっと知る（一問一答＋取扱説明書） ============ -->
  <section class="section" data-accent="var(--c-yellow)">
    <div class="container">
      <div class="sec-head reveal">
        <span class="eyebrow">More About Me</span>
        <h2 class="sec-title">もっと、知る。</h2>
      </div>

      <dl class="qa">
        {qa.map((item, i) => (
          <div class="qa-item reveal" data-delay={(i % 3) + 1}>
            <dt class="qa-q">{item.q}</dt>
            <dd class="qa-a">{item.a}</dd>
          </div>
        ))}
      </dl>

      <div class="torisetsu reveal">
        <div class="torisetsu-head">
          <h3 class="torisetsu-title">大崎稜馬 取扱説明書</h3>
          <span class="torisetsu-note">※ 友人の評価より、いいところを抜粋</span>
        </div>
        <ul class="traits">
          {traits.map((tr, i) => (
            <li class="trait reveal" data-delay={(i % 3) + 1} style={`--cc:${tr.c}`}>
              <span class="trait-dot" aria-hidden="true"></span>
              <span class="trait-t">{tr.t}</span>
              <span class="trait-d">{tr.d}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- ============ できること（スキル） ============ -->
  <section class="section section--alt" data-accent="var(--c-orange)">
    <div class="container">
      <div class="sec-head reveal">
        <span class="eyebrow">Skills</span>
        <h2 class="sec-title">できること。</h2>
      </div>
      <div class="skills">
        {skills.map((s, i) => (
          <div class="skill-card reveal" data-delay={(i % 3) + 1}>
            <span class="skill-bar" style={`background:${s.c}`}></span>
            <h3 class="skill-h">{s.group}</h3>
            <ul>{s.items.map((it) => <li>{it}</li>)}</ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ 主な実績（ハイライト） ============ -->
  <section class="section" data-accent="var(--c-red)">
    <div class="container">
      <div class="sec-head reveal">
        <span class="eyebrow">Highlights</span>
        <h2 class="sec-title">主な実績。</h2>
      </div>
      <div class="highlights">
        {highlights.map((h, i) => {
          const Tag = h.href ? "a" : "div";
          return (
            <Tag class:list={["hl", "reveal", { "hl--link": !!h.href }]} href={h.href ?? undefined} data-delay={(i % 4) + 1} style={`--hc:${h.c}`}>
              <span class="hl-num">{h.n}</span>
              <span class="hl-label">{h.l}</span>
              <p class="hl-desc">{h.d}</p>
              {h.href && <span class="hl-arrow">詳しく ↗</span>}
            </Tag>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ============ 締め ============ -->
  <section class="section ab-cta" data-accent="var(--c-violet)">
    <div class="container narrow center reveal">
      <span class="eyebrow" style="justify-content:center">Let's Create</span>
      <p class="ab-cta-line">一緒に、<span class="spectrum-text">何か</span>つくりましょう。</p>
      <div class="ab-cta-btns">
        <a href="/works" class="btn btn--primary">作品を見る →</a>
        <a href="/ceed" class="btn btn--ghost">CEEDでの活動 →</a>
        <a href="/contact" class="btn btn--ghost">連絡する →</a>
      </div>
    </div>
  </section>

  <Lightbox />

  <style>
    /* ====== ヒーロー ====== */
    .ab-hero { position: relative; padding-top: calc(72px + var(--space-5)); padding-bottom: var(--space-6); overflow: hidden; }
    .ab-hero-grid { display: grid; gap: clamp(2rem, 5vw, 4.5rem); grid-template-columns: 1fr; align-items: center; }
    @media (min-width: 880px) { .ab-hero-grid { grid-template-columns: 1.3fr 0.7fr; } }
    .ab-name { font-family: var(--font-mincho); font-weight: 800; line-height: 1; margin: 0.5rem 0 1.3rem; letter-spacing: 0.01em; }
    .ab-name .line-mask > span { font-size: clamp(2.8rem, 8.5vw, 6.2rem); display: block; }
    .ab-roman { display: block; font-family: var(--font-display); font-size: clamp(0.9rem, 2vw, 1.4rem); color: var(--muted); font-weight: 500; letter-spacing: 0.22em; margin-top: 0.7rem; }
    .ab-role { color: var(--fg); font-size: clamp(1rem, 1.5vw, 1.2rem); line-height: 1.7; margin-bottom: 1.2rem; font-weight: 500; }
    .ab-lead { max-width: 54ch; color: var(--fg-soft); font-size: clamp(0.98rem, 1.3vw, 1.12rem); line-height: 1.9; }

    .ab-portrait { position: relative; margin: 0; display: flex; flex-direction: column; gap: 0.9rem; max-width: 420px; width: 100%; justify-self: center; }
    /* 背後にスペクトラムの光を放つ（“光を放つ”＝ブランド／モノクロをやめ色で品よく） */
    .ab-portrait::before { content: ""; position: absolute; left: 50%; top: 44%; width: 122%; height: 92%; transform: translate(-50%, -50%); z-index: 0; background: radial-gradient(50% 50% at 50% 50%, color-mix(in srgb, var(--c-violet) 55%, transparent), color-mix(in srgb, var(--c-blue) 22%, transparent) 55%, transparent 76%); filter: blur(44px); opacity: 0.5; pointer-events: none; }
    .ab-portrait-media { position: relative; z-index: 1; aspect-ratio: 4 / 5; border-radius: var(--radius); overflow: hidden; border: 1px solid color-mix(in srgb, var(--fg) 14%, transparent); box-shadow: 0 30px 70px rgba(0,0,0,0.45); }
    .ab-portrait-media::before { content: ""; position: absolute; inset: 0; background: var(--bg-img) center/cover no-repeat; filter: blur(30px) brightness(0.55) saturate(1.2); transform: scale(1.25); }
    .ab-portrait-media img { position: relative; width: 100%; height: 100%; object-fit: cover; object-position: center 28%; filter: contrast(1.04) saturate(1.06); transition: transform 0.6s var(--ease); }
    /* 上品な額装：内側の細枠＋下に向けたわずかな陰影 */
    .ab-portrait-media::after { content: ""; position: absolute; inset: 0; z-index: 2; box-shadow: inset 0 0 0 1px rgba(255,255,255,0.08), inset 0 -60px 60px -40px rgba(0,0,0,0.5); pointer-events: none; }
    .ab-portrait-cap { font-family: var(--font-mincho); font-size: 1rem; color: var(--fg-soft); letter-spacing: 0.04em; text-align: center; position: relative; z-index: 1; }
    .ab-portrait-cap span { color: var(--accent-ink); }

    /* ====== セクション見出し（明朝） ====== */
    .sec-head { margin-bottom: var(--space-4); }
    .sec-head.center { text-align: center; }
